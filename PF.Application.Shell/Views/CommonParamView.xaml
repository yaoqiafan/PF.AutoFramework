<UserControl
    x:Class="PF.Application.Shell.Views.CommonParamView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Application.Shell.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:CommonParamsInstence="clr-namespace:PF.Application.Shell.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <pf:PropertyGrid
            x:Name="proptey"
            SelectedObject="{Binding Params}"
            ShowSortButton="True" />
        <Border
            Grid.Row="1"
            Margin="10,0"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
            <Button
                Width="300"
                Height="30"
                HorizontalAlignment="Stretch"
                pf:IconElement.Geometry="{StaticResource ClockGeometry}"
                Command="{Binding SaveCommmand}"
                Content="保存"
                Style="{StaticResource ButtonPrimary}" />
        </Border>

    </Grid>
</UserControl>
