<UserControl
    x:Class="PF.Modules.Parameter.Dialog.ParamChangeDialog_Common"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:PF.Modules.Parameter.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:tokens="clr-namespace:PF.Core.Constants;assembly=PF.Core"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />

            <RowDefinition Height="auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition  />
        </Grid.ColumnDefinitions>


        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Height="30"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            Text="参数类别：" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Height="30"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            Text="名称：" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Height="30"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            Text="参数描述：" />
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Height="30"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            Text="参数类型：" />




        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            Height="30"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            IsReadOnly="True"
            Text="{Binding SelectedParameter.Category}" />
        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Height="30"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            IsReadOnly="True"
            Text="{Binding SelectedParameter.Name}" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Height="30"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            IsReadOnly="True"
            Text="{Binding SelectedParameter.Description}" />
        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            Height="30"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSize.H2.Title}"
            IsReadOnly="True"
            Text="{Binding SelectedParameter.TypeFullName}" />


        <pf:PropertyGrid
            Grid.Row="4"
            Grid.ColumnSpan="2"
            pf:TitleElement.TitleWidth="80"
            FontSize="{DynamicResource FontSize.H2.Title}"
            SelectedObject="{Binding ValueInstance}"
            ShowSortButton="False" />



        <Grid
            Grid.Row="5"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Height="40"
                    Margin="10,0,10,0"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    FontSize="{DynamicResource FontSize.H2.Title}"
                    Style="{StaticResource ButtonWarning}" />
                <Button
                    Width="80"
                    Height="40"
                    Margin="10,0,10,0"
                    Command="{Binding ConfirmCommand}"
                    Content="确认"
                    FontSize="{DynamicResource FontSize.H2.Title}"
                    Style="{StaticResource ButtonPrimary}" />
            </StackPanel>
        </Grid>
    </Grid>


</UserControl>
