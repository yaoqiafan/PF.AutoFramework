<UserControl
    x:Class="PF.Modules.Logging.Views.LogManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PF.Modules.Logging.Converter"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Margin="0,0,0,20"
                FontSize="{DynamicResource FontSize.H1.Large}"
                FontWeight="Light"
                Text="日志归档管理" />



            <pf:Card
                Grid.Row="1"
                VerticalAlignment="Stretch"
                Header="磁盘历史日志查询">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="0,0,0,10"
                        BorderBrush="#EEE"
                        BorderThickness="0,0,0,1">
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel
                                Margin="0,0,20,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="时间范围：" />
                                <DatePicker Width="120" SelectedDate="{Binding StartDate}" />
                                <TextBlock
                                    Margin="5,0"
                                    VerticalAlignment="Center"
                                    Text=" - " />
                                <DatePicker Width="120" SelectedDate="{Binding EndDate}" />
                            </StackPanel>

                            <Button
                                Height="30"
                                Padding="20,0"
                                Command="{Binding QueryHistoryCommand}"
                                Content="🔍 从磁盘读取"
                                IsEnabled="{Binding IsQuerying, Converter={StaticResource Boolean2BooleanReConverter}}"
                                Style="{StaticResource ButtonPrimary}" />
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,15,0"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Text="等级：" />
                            <ComboBox
                                Width="100"
                                ItemsSource="{Binding FilterLevels}"
                                SelectedItem="{Binding SelectedFilterLevel}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Margin="0,0,15,0"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Text="分类：" />
                            <ComboBox
                                Width="150"
                                ItemsSource="{Binding FilterCategories}"
                                SelectedItem="{Binding SelectedFilterCategory}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Text="筛选：" />
                            <pf:SearchBar
                                Width="250"
                                pf:InfoElement.Placeholder="在结果中搜索内容..."
                                Text="{Binding QueryKeyword, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Button
                            Grid.Column="3"
                            Command="{Binding ExportLogsCommand}"
                            Content="📤 导出当前结果"
                            ToolTip="将当前筛选出的日志导出为 CSV" />
                    </Grid>

                    <DataGrid
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        BorderThickness="1"
                        EnableRowVirtualization="True"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding DataList}"
                        RowHeight="NaN">
                        <DataGrid.RowStyle>
                            <Style BasedOn="{StaticResource DataGridRowStyle}" TargetType="DataGridRow">
                                <Setter Property="MinHeight" Value="36" />
                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                <Setter Property="Height" Value="Auto" />
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="170"
                                Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}"
                                Header="时间" />

                            <DataGridTemplateColumn Width="80" Header="等级">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="5,2"
                                            HorizontalAlignment="Left"
                                            Background="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="{DynamicResource FontSize.Caption.Mini}"
                                                FontWeight="SemiBold"
                                                Foreground="Black"
                                                Text="{Binding Level}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding Category}"
                                FontWeight="Medium"
                                Header="分类" />

                            <DataGridTemplateColumn Width="*" Header="消息内容">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Padding="5"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap"
                                            ToolTip="{Binding Message}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Visibility="{Binding IsQuerying, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <pf:LoadingCircle Width="50" Height="50" />
                            <TextBlock
                                Margin="0,15,0,0"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                Foreground="#666"
                                Text="正在扫描文件..." />
                        </StackPanel>
                    </Grid>

                </Grid>

            <pf:Card.Footer>
                    <Grid Margin="10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  分页控件  -->
                        <pf:Pagination
                            Grid.Column="0"
                            Height="30"
                            HorizontalAlignment="Left"
                            IsJumpEnabled="True"
                            MaxPageCount="{Binding MaxPageCount}"
                            PageIndex="{Binding PageIndex}">
                            <pf:Interaction.Triggers>
                                <pf:EventTrigger EventName="PageUpdated">
                                    <pf:EventToCommand Command="{Binding PageUpdatedCmd}" PassEventArgsToCommand="True" />
                                </pf:EventTrigger>
                            </pf:Interaction.Triggers>
                        </pf:Pagination>

                        <!--  状态信息  -->
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="#666"
                            Text="{Binding QueryStatusMessage}" />

                        <!--  每页条数  -->
                        <StackPanel
                            Grid.Column="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="每页显示：" />
                            <ComboBox
                                Width="70"
                                Height="30"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                SelectedValue="{Binding PageSize}">
                                <sys:Int32>20</sys:Int32>
                                <sys:Int32>50</sys:Int32>
                                <sys:Int32>100</sys:Int32>
                                <sys:Int32>200</sys:Int32>
                            </ComboBox>
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="条" />
                        </StackPanel>
                    </Grid>
                </pf:Card.Footer>

            </pf:Card>

        </Grid>
    </pf:TransitioningContentControl>
</UserControl>