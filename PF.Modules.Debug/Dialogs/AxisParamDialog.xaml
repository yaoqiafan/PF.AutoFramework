<UserControl
    x:Class="PF.Modules.Debug.Dialogs.AxisParamDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.Debug.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    Width="600"
    MaxHeight="800"
    FontSize="{DynamicResource FontSize.H2.Title}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="45" />
        </Grid.RowDefinitions>

        <pf:PropertyGrid SelectedObject="{Binding ParamInstence}" />


        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="40"
                Margin="10,0,10,0"
                Command="{Binding CancelCommand}"
                Content="取消"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Style="{StaticResource ButtonWarning}" />
            <Button
                Width="80"
                Height="40"
                Margin="10,0,10,0"
                Command="{Binding ConfirmCommand}"
                Content="确认"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Style="{StaticResource ButtonPrimary}" />
        </StackPanel>
    </Grid>
</UserControl>
