<UserControl
    x:Class="PF.Modules.Debug.Views.StationDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:tokens="clr-namespace:PF.Core.Constants;assembly=PF.Core"
    xmlns:vm="clr-namespace:PF.Modules.Debug.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── 左侧工站导航列表 ──────────────────────────────────────────── -->
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="3"
                Grid.Column="0"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="6">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="12,12,12,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="工站列表" />
                    <Separator
                        DockPanel.Dock="Top"
                        Margin="8,0"
                        Background="{DynamicResource BorderColorBrush}" />
                    <ListBox
                        Margin="4,4"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding NavItems}"
                        SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                       
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:StationNavItem}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- 状态指示条 -->
                                    <Border
                                        Width="3"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Background="{DynamicResource PrimaryColorBrush}"
                                        CornerRadius="1.5" />
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="Medium"
                                            Text="{Binding Title}" />
                                        <TextBlock
                                            FontSize="{DynamicResource FontSize.Caption.Mini}"
                                            Text="{Binding StationName}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── 右侧内容区域 ─────────────────────────────────────────────── -->
            <Border
                Grid.Column="2"
                CornerRadius="6">
                <ContentControl prism:RegionManager.RegionName="{x:Static tokens:NavigationConstants+Regions.StationContentRegion}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ContentControl">
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="36"
                                                        Text="&#xE71B;" />
                                                    <TextBlock
                                                        Margin="0,8,0,0"
                                                        HorizontalAlignment="Center"
                                                        FontSize="{DynamicResource FontSize.Body.Standard}"
                                                        Text="请从左侧列表选择工站进行调试" />
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>
