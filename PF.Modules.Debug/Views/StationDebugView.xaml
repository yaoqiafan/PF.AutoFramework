<UserControl
    x:Class="PF.Modules.Debug.Views.StationDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:PF.Modules.Debug.Models"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:tokens="clr-namespace:PF.Core.Constants;assembly=PF.Core"
    xmlns:vm="clr-namespace:PF.Modules.Debug.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  ── 左侧面板 ──────────────────────────────────────────────────  -->
            <Border
                Grid.Column="0"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="3"
                CornerRadius="6">
                <DockPanel>

                    <!--  标题  -->
                    <TextBlock
                        Margin="12,12,12,20"
                        DockPanel.Dock="Top"
                        FontSize="{DynamicResource FontSize.H1.Large}"
                        FontWeight="SemiBold"
                        Text="总工站调试" />

                    <!--  主控状态卡片  -->
                    <Grid Margin="8,0,8,0" DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,3,0">
                            <StackPanel>
                                <TextBlock Text="主控状态" />
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Fill="{Binding StatusBrush}" />
                                    <TextBlock Text="{Binding ControllerState}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Margin="3,0,0,0">
                            <StackPanel>
                                <TextBlock Text="运行模式" />
                                <TextBlock Text="{Binding CurrentMode}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  最近报警  -->
                    <TextBlock
                        Height="auto"
                        Margin="12,5,12,0"
                        DockPanel.Dock="Top"
                        FontSize="{DynamicResource FontSize.H2.Title}"
                        Foreground="{DynamicResource LightWarningBrush}"
                        Text="{Binding LastAlarmMessage, StringFormat='报警: {0}'}"
                        TextTrimming="WordEllipsis"
                        ToolTip="{Binding LastAlarmMessage}" />

                    <Separator
                        Margin="8,10"
                        Background="{DynamicResource BorderColorBrush}"
                        DockPanel.Dock="Top" />

                    <!--  控制指令  -->
                    <TextBlock
                        Margin="12,0,12,4"
                        DockPanel.Dock="Top"
                        Text="全局控制指令" />

                    <UniformGrid
                        Margin="8,0,8,0"
                        Columns="2"
                        DockPanel.Dock="Top">
                        <Button
                            Margin="3"
                            HorizontalAlignment="Stretch"
                            Command="{Binding InitializeAllCommand}"
                            Content="全线初始化" />
                        <Button
                            Margin="3"
                            HorizontalAlignment="Stretch"
                            Command="{Binding StartAllCommand}"
                            Content="▶ 启动" />
                        <Button
                            Margin="3"
                            HorizontalAlignment="Stretch"
                            Command="{Binding PauseAllCommand}"
                            Content="⏸ 暂停" />
                        <Button
                            Margin="3"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ResumeAllCommand}"
                            Content="▶ 恢复" />
                        <Button
                            Margin="3"
                            HorizontalAlignment="Stretch"
                            Command="{Binding StopAllCommand}"
                            Content="⏹ 停止" />
                        <Button
                            Margin="3"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ResetAllCommand}"
                            Content="⟳ 复位" />

                    </UniformGrid>

                    <Button
                        Margin="3"
                        HorizontalAlignment="Stretch"
                        Command="{Binding EmergencyStopCommand}"
                        Content="⚠ 急停"
                        DockPanel.Dock="Top"
                        Style="{DynamicResource ButtonWarning}" />

                    <Separator
                        Margin="8,6"
                        Background="{DynamicResource BorderColorBrush}"
                        DockPanel.Dock="Top" />

                    <!--  工站列表标题  -->
                    <TextBlock
                        Margin="12,0,12,4"
                        DockPanel.Dock="Top"
                        Text="工站列表" />




                    <ListBox
                        Margin="4,0,4,4"
                        Background="Transparent"
                        BorderBrush="{DynamicResource TextIconBrush}"
                        BorderThickness="1"
                        ItemsSource="{Binding NavItems}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectedItem="{Binding SelectedItem, Mode=TwoWay}">



                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:StationNavItem}">
                                <Border
                                    Padding="10,8"
                                    Background="{DynamicResource ThirdlyRegionColorBrush}"
                                    CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  状态指示点  -->
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Fill="{Binding StateBrush}" />

                                        <!--  工站名 + 步序  -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="Medium"
                                                Foreground="{DynamicResource PrimaryTextColorBrush}"
                                                Text="{Binding Title}" />
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="{DynamicResource SecondaryTextColorBrush}"
                                                Text="{Binding StepDescription}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!--  状态标签  -->
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{Binding StateBrush}"
                                            Text="{Binding State}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>
            <Border
                Grid.Column="2"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="3"
                CornerRadius="6">
                <DockPanel>
                    <TextBlock
                        Margin="12,0,12,6"
                        DockPanel.Dock="Top"
                        Text="流水线信号量" />

                    <!--  信号量树：Scope 节点 → Signal 叶子，右键可释放/复位单个信号量  -->
                    <TreeView
                        x:Name="SyncTreeView"
                        Margin="4,0,4,4"
                        Background="Transparent"
                        BorderBrush="{DynamicResource TextIconBrush}"
                        BorderThickness="1"
                        DockPanel.Dock="Top"
                        ItemsSource="{Binding ScopeNodes}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <TreeView.Resources>
                            <!--  Scope（工站）节点模板：可折叠的分组头  -->
                            <HierarchicalDataTemplate DataType="{x:Type models:ScopeTreeNode}" ItemsSource="{Binding Signals}">
                                <TextBlock
                                    Padding="2,3"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource SecondaryTextColorBrush}"
                                    Text="{Binding ScopeName}" />
                            </HierarchicalDataTemplate>

                            <!--  Signal（信号量）叶子节点模板：状态指示 + 右键菜单  -->
                            <DataTemplate DataType="{x:Type models:SignalTreeNode}">
                                <StackPanel
                                    Margin="0,1"
                                    Orientation="Horizontal"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <!--
                                        Tag 绑定到 TreeView 的 DataContext（即 StationDebugViewModel）。
                                        ContextMenu 与视觉树断开连接，通过 PlacementTarget.Tag 访问 VM 命令；
                                        通过 PlacementTarget.DataContext 访问当前 SignalTreeNode 参数。
                                    -->
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.ReleaseSignalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                Header="释放（计数 +1）" />
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.ResetSignalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                Header="复位至初始值" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>

                                    <Ellipse
                                        x:Name="StatusDot"
                                        Width="8"
                                        Height="8"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Fill="#4CAF50" />
                                    <TextBlock
                                        x:Name="TxtStatus"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#4CAF50"
                                        Text="{Binding StatusText}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding CurrentCount}" Value="0">
                                        <Setter TargetName="StatusDot" Property="Fill" Value="#F44336" />
                                        <Setter TargetName="TxtStatus" Property="Foreground" Value="#F44336" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>
            <!--  ── 右侧内容区域 ───────────────────────────────────────────────  -->
            <Border Grid.Column="3" CornerRadius="5">
                <ContentControl prism:RegionManager.RegionName="{x:Static tokens:NavigationConstants+Regions.StationContentRegion}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ContentControl">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="36"
                                                        Text="&#xE71B;" />
                                                    <TextBlock
                                                        Margin="0,8,0,0"
                                                        HorizontalAlignment="Center"
                                                        FontSize="{DynamicResource FontSize.Body.Standard}"
                                                        Text="请从左侧列表选择工站进行调试" />
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>

        </Grid>
    </pf:TransitioningContentControl>
</UserControl>
