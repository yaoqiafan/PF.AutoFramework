<UserControl
    x:Class="PF.Modules.Debug.Views.AxisDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True"
    d:DesignHeight="800"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,15" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
                        <TextBlock Text="⚙️" FontSize="24" Foreground="{DynamicResource TextIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DeviceName}" FontSize="22" FontWeight="Bold"  />
                        <TextBlock Text="{Binding DeviceDescription}" FontSize="13"  Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="通讯状态:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Border Padding="8,4" CornerRadius="4" Background="#10B981">
                            <TextBlock Text="{Binding IsConnected, StringFormat='{}{0}'}" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="实时位置 (DRO)" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,10"/>
                            <Border Background="#E2E8F0" CornerRadius="6" Padding="15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentPosition, StringFormat=\{0:F3\}}" FontSize="36" FontWeight="Heavy" Foreground="#4ADE80" FontFamily="Consolas"/>
                                    <TextBlock Text=" mm" FontSize="16" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="8,0,0,6"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="IO 状态监控" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,15,0,10"/>
                            <UniformGrid Columns="2" Margin="0,5">
                                <CheckBox Content="轴已使能 (SVON)" IsChecked="{Binding IsEnabled, Mode=OneWay}" IsHitTestVisible="False" Margin="0,5"/>
                                <CheckBox Content="正在运动 (BUSY)" IsChecked="{Binding IsMoving, Mode=OneWay}" IsHitTestVisible="False" Margin="0,5" Foreground="#0284C7"/>
                                <CheckBox Content="正限位 (PEL)" IsChecked="{Binding IsPositiveLimit, Mode=OneWay}" IsHitTestVisible="False" Margin="0,5" Foreground="#EF4444"/>
                                <CheckBox Content="负限位 (NEL)" IsChecked="{Binding IsNegativeLimit, Mode=OneWay}" IsHitTestVisible="False" Margin="0,5" Foreground="#EF4444"/>
                                <CheckBox Content="驱动器报警 (ALM)" IsChecked="{Binding IsAlarm, Mode=OneWay}" IsHitTestVisible="False" Margin="0,5" Foreground="#EF4444"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel>
                            <TextBlock Text="设备启停" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,10"/>
                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <Button Height="36" Margin="0,0,5,5" Command="{Binding ConnectCommand}" Content="连接硬件" Style="{DynamicResource ButtonDefault}" />
                                <Button Height="36" Margin="5,0,0,5" Command="{Binding DisconnectCommand}" Content="断开连接" Style="{DynamicResource ButtonDefault}" />
                                <Button Height="36" Margin="0,5,5,0" Command="{Binding EnableCommand}" Content="伺服使能 (ON)" Style="{DynamicResource ButtonPrimary}" />
                                <Button Height="36" Margin="5,5,0,0" Command="{Binding DisableCommand}" Content="断开使能 (OFF)" Style="{DynamicResource ButtonWarning}" />
                            </UniformGrid>

                            <Button Height="40" Margin="0,5" Command="{Binding HomeCommand}" Content="执行回零 (HOME)" Style="{DynamicResource ButtonSuccess}" />
                            <Button Height="45" Margin="0,5" Command="{Binding StopCommand}" Content="急 停 (E-STOP)" FontSize="16" FontWeight="Bold" Style="{DynamicResource ButtonDanger}" />
                            <Button Height="36" Margin="0,5" Command="{Binding ResetCommand}" Content="报警复位 (RESET)" Style="{DynamicResource ButtonDefault}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" Text="绝对目标(mm):" />
                                <TextBox Grid.Column="1" Height="36" Margin="0,0,20,0" VerticalContentAlignment="Center" Text="{Binding TargetPosition}" />
                                <TextBlock Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center" Text="速度(mm/s):" />
                                <TextBox Grid.Column="3" Height="36" Margin="0,0,20,0" VerticalContentAlignment="Center" Text="{Binding AbsVelocity}" />
                                <Button Grid.Column="4" Height="36" Command="{Binding MoveAbsoluteCommand}" Content="绝对运动" Style="{DynamicResource ButtonPrimary}" />
                            </Grid>
                        </Border>

                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" Text="相对距离(mm):" />
                                <TextBox Grid.Column="1" Height="36" Margin="0,0,20,0" VerticalContentAlignment="Center" Text="{Binding RelativeDistance}" />
                                <TextBlock Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center" Text="速度(mm/s):" />
                                <TextBox Grid.Column="3" Height="36" Margin="0,0,20,0" VerticalContentAlignment="Center" Text="{Binding RelVelocity}" />
                                <Button Grid.Column="4" Height="36" Command="{Binding MoveRelativeCommand}" Content="相对运动" Style="{DynamicResource ButtonPrimary}" />
                            </Grid>
                        </Border>

                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Height="40" Command="{Binding JogNegativeCommand}" Content="◀ JOG -" FontSize="14" FontWeight="Bold" Style="{DynamicResource ButtonDefault}" />
                                <TextBlock Grid.Column="2" Margin="20,0,10,0" VerticalAlignment="Center" Text="点动速度(mm/s):" />
                                <TextBox Grid.Column="3" Height="36" Margin="0,0,20,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="{Binding JogVelocity}" />
                                <Button Grid.Column="4" Height="40" Command="{Binding JogPositiveCommand}" Content="JOG + ▶" FontSize="14" FontWeight="Bold" Style="{DynamicResource ButtonDefault}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="预设点表 (Point Table)" FontSize="14" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                <TextBlock Text="在此维护工艺坐标，解耦代码与位置" FontSize="12" Foreground="#94A3B8" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderBrush="#E2E8F0" BorderThickness="1" RowHeight="35"
                                      ItemsSource="{Binding PointTable}" SelectedItem="{Binding SelectedPoint}" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="50" Binding="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}" Header="序号" />
                                    <DataGridTextColumn Width="120" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Header="点位名称" />
                                    <DataGridTextColumn Width="110" Binding="{Binding TargetPosition, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}" Header="目标位置(mm)" />
                                    <DataGridTextColumn Width="90" Binding="{Binding Speed, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Header="速度" />
                                    <DataGridTextColumn Width="*" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Header="备注说明" />
                                    <DataGridTemplateColumn Width="90" Header="快速移动">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Height="26" Width="70" Content="移动到" 
                                                        Command="{Binding DataContext.GoToPointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        Style="{DynamicResource ButtonPrimary}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <Button Height="32" Padding="15,0" Margin="0,0,10,0" Command="{Binding AddPointCommand}" Content="新增当前位置" Style="{DynamicResource ButtonSuccess}" />
                                <Button Height="32" Padding="15,0" Margin="0,0,10,0" Command="{Binding DeletePointCommand}" Content="删除选中" Style="{DynamicResource ButtonDanger}" />
                                <Button Height="32" Padding="25,0" Command="{Binding SavePointsCommand}" Content="保存修改到本地" Style="{DynamicResource ButtonPrimary}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>