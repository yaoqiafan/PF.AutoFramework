<UserControl x:Class="PF.Modules.Debug.Views.HardwareDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hardwareAxis="clr-namespace:PF.Core.Interfaces.Hardware.Motor.Basic;assembly=PF.Core"
             xmlns:hardwareIO="clr-namespace:PF.Core.Interfaces.Hardware.IO.Basic;assembly=PF.Core"
             xmlns:models="clr-namespace:PF.Modules.Debug.Models"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:selectors="clr-namespace:PF.Modules.Debug.Selectors"
             >

    <UserControl.Resources>
        <DataTemplate x:Key="AxisPanelTemplate">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding DeviceName, StringFormat='运动轴调试 - {0}'}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="IOPanelTemplate">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding DeviceName, StringFormat='IO调试 - {0}'}" />
            </StackPanel>
        </DataTemplate>

        <selectors:DeviceTemplateSelector x:Key="MyHardwareSelector"
                                          AxisTemplate="{StaticResource AxisPanelTemplate}"
                                          IOTemplate="{StaticResource IOPanelTemplate}" />
    </UserControl.Resources>

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="5">
                <TreeView BorderThickness="3" ItemsSource="{Binding TreeNodes}" SelectedItemChanged="TreeView_SelectedItemChanged" Style="{StaticResource TreeView.Small}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:DebugTreeNode}" ItemsSource="{Binding Children}">
                            <StackPanel Margin="0,4" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" FontSize="14" Text="{Binding NodeName}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <Border Grid.Column="2" CornerRadius="5">
                <ContentControl Content="{Binding SelectedNode.Payload}" ContentTemplateSelector="{StaticResource MyHardwareSelector}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNode.Payload}" Value="{x:Null}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ContentControl">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="Gray" Text="请选择具体硬件设备进行调试" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>