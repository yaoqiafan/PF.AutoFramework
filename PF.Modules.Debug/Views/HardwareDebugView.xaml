<UserControl
    x:Class="PF.Modules.Debug.Views.HardwareDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="clr-namespace:PF.Modules.Debug.Models"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:selectors="clr-namespace:PF.Modules.Debug.Selectors"
    xmlns:tokens="clr-namespace:PF.Core.Constants;assembly=PF.Core"
   >
    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="5">
                <TreeView
                    BorderThickness="3"
                    ItemsSource="{Binding TreeNodes}"
                    SelectedItemChanged="TreeView_SelectedItemChanged"
                    Style="{StaticResource TreeView.Small}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:DebugTreeNode}" ItemsSource="{Binding Children}">
                            <StackPanel Margin="0,4" Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="{Binding NodeName}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <Border Grid.Column="2" CornerRadius="5">
                <ContentControl Grid.Row="0" prism:RegionManager.RegionName="{x:Static tokens:NavigationConstants+Regions.DebugViewRegion}" />
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>