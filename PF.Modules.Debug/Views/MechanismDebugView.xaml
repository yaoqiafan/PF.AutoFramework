<UserControl
    x:Class="PF.Modules.Debug.Views.MechanismDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.Debug.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:tokens="clr-namespace:PF.Core.Constants;assembly=PF.Core"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="5"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="3">
                <DockPanel>
                    <TextBlock Margin="12,12,12,4"
                               DockPanel.Dock="Top"
                               FontSize="{DynamicResource FontSize.H1.Large}"
                               FontWeight="SemiBold"
                               Text="模组调试" />

                    <ListBox Margin="4,0,4,4"
                             Background="Transparent"
                             BorderBrush="{DynamicResource TextIconBrush}"
                             BorderThickness="1"
                             ItemsSource="{Binding NavItems}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8"
                                        Background="{DynamicResource ThirdlyRegionColorBrush}"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  状态指示点  -->
                                        <Ellipse Grid.Column="0"
                                                 Width="8" Height="8"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding StateBrush}" />

                                        <!--  模组名称  -->
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource PrimaryTextColorBrush}"
                                                   Text="{Binding Title}" />

                                        <!--  状态标签  -->
                                        <TextBlock Grid.Column="2"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding StateBrush}"
                                                   Text="{Binding StateText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="5">
                <ContentControl prism:RegionManager.RegionName="{x:Static tokens:NavigationConstants+Regions.MechanismContentRegion}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ContentControl">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                                    Foreground="Gray"
                                                    Text="请选择具体硬件设备进行调试" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>
