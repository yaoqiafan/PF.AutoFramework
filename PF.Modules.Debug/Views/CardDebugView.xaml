<UserControl
    x:Class="PF.Modules.Debug.Views.CardDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True"
    d:DesignHeight="500"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── 顶部：设备头部信息卡 ────────────────────────────────────────── -->
            <Border
                Grid.Row="0"
                Margin="0,0,0,15"
                Padding="15"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 板卡图标 -->
                    <Border
                        Grid.Column="0"
                        Width="48"
                        Height="48"
                        Margin="0,0,15,0"
                        CornerRadius="8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.H1.Large}"
                            Foreground="{DynamicResource TextIconBrush}"
                            Text="&#xE7FC;" />
                    </Border>

                    <!-- 设备名称 + 描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="{DynamicResource FontSize.H2.Title}"
                            FontWeight="Bold"
                            Text="{Binding DeviceName}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Text="{Binding DeviceDescription}" />
                    </StackPanel>

                    <!-- 操作按钮 -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Height="32"
                            Margin="0,0,10,0"
                            Command="{Binding ConnectCommand}"
                            Content="连接板卡"
                            Style="{DynamicResource ButtonDefault}" />
                        <Button
                            Height="32"
                            Margin="0,0,10,0"
                            Command="{Binding DisconnectCommand}"
                            Content="断开连接"
                            Style="{DynamicResource ButtonDefault}" />
                        <Button
                            Height="32"
                            Command="{Binding ResetCommand}"
                            Content="板卡复位"
                            Style="{DynamicResource ButtonWarning}" />
                    </StackPanel>

                    <!-- 状态指示 -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                        <!-- 连接状态 -->
                        <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.Body.Small}"
                                Foreground="#64748B"
                                Text="通讯：" />
                            <Ellipse
                                Width="10"
                                Height="10"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Fill="{Binding ConnectionBrush}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.Body.Small}"
                                FontWeight="SemiBold"
                                Text="{Binding ConnectionText}" />
                        </StackPanel>
                        <!-- 报警状态 -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.Body.Small}"
                                Foreground="#64748B"
                                Text="报警：" />
                            <Ellipse
                                Width="10"
                                Height="10"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Fill="{Binding AlarmBrush}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.Body.Small}"
                                FontWeight="SemiBold"
                                Text="{Binding AlarmText}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 下方：板卡规格看板 ─────────────────────────────────────────── -->
            <Border
                Grid.Row="1"
                Padding="20"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="#475569"
                        Text="板卡规格（Motion Card Specification）" />

                    <!-- 四项统计 -->
                    <UniformGrid Columns="4" Rows="1">

                        <Border Margin="0,0,10,0" Padding="16,14" CornerRadius="8" Background="{DynamicResource SecondaryRegionColorBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Text="{Binding CardIndex}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Body.Small}"
                                    Foreground="#64748B"
                                    Text="槽位索引 (CardIndex)" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,10,0" Padding="16,14" CornerRadius="8" Background="{DynamicResource SecondaryRegionColorBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Text="{Binding AxisCount}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Body.Small}"
                                    Foreground="#64748B"
                                    Text="运动控制轴数 (AxisCount)" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,10,0" Padding="16,14" CornerRadius="8" Background="{DynamicResource SecondaryRegionColorBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Text="{Binding InputCount}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Body.Small}"
                                    Foreground="#64748B"
                                    Text="数字输入端口 (DI Count)" />
                            </StackPanel>
                        </Border>

                        <Border Padding="16,14" CornerRadius="8" Background="{DynamicResource SecondaryRegionColorBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Text="{Binding OutputCount}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Body.Small}"
                                    Foreground="#64748B"
                                    Text="数字输出端口 (DO Count)" />
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- 子设备提示 -->
                    <Border
                        Margin="0,16,0,0"
                        Padding="12,10"
                        Background="#0D3B82F6"
                        BorderBrush="#3B82F6"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="#3B82F6"
                                Text="ℹ" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.Body.Small}"
                                Foreground="#3B82F6"
                                Text="该板卡挂载的轴（Axis）和 IO 控制器（IOController）已列于左侧设备树中，点击子节点可跳转到对应的专项调试界面。" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>
