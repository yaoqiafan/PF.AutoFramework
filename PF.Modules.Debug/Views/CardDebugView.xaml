<UserControl
    x:Class="PF.Modules.Debug.Views.CardDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:vm="clr-namespace:PF.Modules.Debug.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── 左侧板卡列表 ──────────────────────────────────────────────── -->
            <Border
                Grid.Column="0"
                Background="{DynamicResource SecondaryRegionColorBrush}"
                CornerRadius="6">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="12,12,12,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="控制卡列表" />
                    <Separator
                        DockPanel.Dock="Top"
                        Margin="8,0"
                        Background="{DynamicResource BorderColorBrush}" />
                    <ListBox
                        Margin="4,4"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding Cards}"
                        SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="2,2" />
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CardNavItem}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border
                                        Width="3"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Background="{DynamicResource PrimaryColorBrush}"
                                        CornerRadius="1.5" />
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Text="{Binding Title}"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── 右侧详情面板 ──────────────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- 无板卡选中时的占位提示 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedCard}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="36"
                        Text="&#xE7F4;" />
                    <TextBlock
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Text="请从左侧列表选择控制卡进行调试" />
                </StackPanel>

                <!-- 有板卡选中时的详情面板 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedCard}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Margin="4">

                        <!-- ── 板卡标题卡 ──────────────────────────────────── -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="18,14"
                            Background="{DynamicResource SecondaryRegionColorBrush}"
                            CornerRadius="8">
                            <StackPanel>
                                <TextBlock
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Text="{Binding CardName}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="12"
                                    Text="{Binding DeviceId, StringFormat='设备 ID: {0}'}" />
                            </StackPanel>
                        </Border>

                        <!-- ── 状态指示卡（连接 + 报警并排） ─────────────── -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 连接状态 -->
                            <Border
                                Grid.Column="0"
                                Padding="16,14"
                                Background="{DynamicResource SecondaryRegionColorBrush}"
                                CornerRadius="8">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource SecondaryTextColorBrush}"
                                        Text="连接状态" />
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse
                                            Width="12"
                                            Height="12"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Fill="{Binding ConnectionBrush}" />
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding ConnectionText}"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 报警状态 -->
                            <Border
                                Grid.Column="2"
                                Padding="16,14"
                                Background="{DynamicResource SecondaryRegionColorBrush}"
                                CornerRadius="8">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource SecondaryTextColorBrush}"
                                        Text="报警状态" />
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse
                                            Width="12"
                                            Height="12"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Fill="{Binding AlarmBrush}" />
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding AlarmText}"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ── 板卡规格信息 ────────────────────────────────── -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="16,14"
                            Background="{DynamicResource SecondaryRegionColorBrush}"
                            CornerRadius="8">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,12"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="板卡规格" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="26"
                                            FontWeight="Bold"
                                            Text="{Binding CardIndex}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                                            Text="槽位索引" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="26"
                                            FontWeight="Bold"
                                            Text="{Binding AxisCount}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                                            Text="轴数量" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="26"
                                            FontWeight="Bold"
                                            Text="{Binding InputCount}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                                            Text="DI 端口数" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="26"
                                            FontWeight="Bold"
                                            Text="{Binding OutputCount}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                                            Text="DO 端口数" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── 基础测试命令 ───────────────────────────────── -->
                        <Border
                            Padding="16,14"
                            Background="{DynamicResource SecondaryRegionColorBrush}"
                            CornerRadius="8">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,12"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="基础测试命令" />
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Width="140"
                                        Height="38"
                                        Margin="0,0,12,0"
                                        Command="{Binding ReconnectCommand}"
                                        Content="重新连接"
                                        Style="{DynamicResource ButtonDefault}" />
                                    <Button
                                        Width="140"
                                        Height="38"
                                        Command="{Binding ResetCommand}"
                                        Content="复位板卡"
                                        Style="{DynamicResource ButtonDefault}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>
