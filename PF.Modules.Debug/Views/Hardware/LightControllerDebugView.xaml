<UserControl
    x:Class="PF.Modules.Debug.Views.Hardware.LightControllerDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.Debug.Views.Hardware"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                Margin="0,0,0,15"
                Padding="15"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="48"
                        Height="48"
                        Margin="0,0,15,0"
                        CornerRadius="8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Foreground="{DynamicResource TextIconBrush}"
                            Text="📷" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding DeviceName}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="#64748B"
                            Text="{Binding DeviceDescription}" />
                    </StackPanel>

                    <Border
                        Grid.Column="2"
                        Padding="15,0"
                        VerticalAlignment="Center"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1,0,0,0">
                        <UniformGrid
                            VerticalAlignment="Center"
                            Columns="2"
                            Rows="2">
                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                <TextBlock Foreground="#64748B" Text="COM 地址: " />
                                <TextBlock FontWeight="SemiBold" Text="{Binding COMAdress}" />
                            </StackPanel>



                        </UniformGrid>
                    </Border>

                    <StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            Text="通讯状态:" />
                        <Border Padding="8,4" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EF4444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="#02AD8B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding IsConnected, StringFormat='{}{0}'}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=" AUTO" />
                    <ColumnDefinition Width=" *" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Margin="0,0,0,15"
                    Padding="15"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#475569"
                            Text="设备启停" />
                        <UniformGrid Margin="0,0,0,10" Columns="2">
                            <Button
                                Height="36"
                                Margin="0,0,5,5"
                                Command="{Binding ConnectCommand}"
                                Content="连接硬件"
                                Style="{DynamicResource ButtonDefault}" />
                            <Button
                                Height="36"
                                Margin="5,0,0,5"
                                Command="{Binding DisconnectCommand}"
                                Content="断开连接"
                                Style="{DynamicResource ButtonDefault}" />
                        </UniformGrid>
                        <Button
                            Height="36"
                            Margin="0,5"
                            Command="{Binding ResetCommand}"
                            Content="清除报警 (RESET)"
                            Style="{DynamicResource ButtonWarning}" />
                    </StackPanel>
                </Border>


                <Border
                    Grid.Column=" 1"
                    Margin="0,0,0,15"
                    Padding="15"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height=" *" />
                            <RowDefinition Height=" *" />
                            <RowDefinition Height=" *" />
                            <RowDefinition Height=" *" />
                        </Grid.RowDefinitions>

                        <!--  通道1  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=" 100" />
                                <ColumnDefinition Width=" *" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="通道1" />
                            <Slider
                                Grid.Column=" 1"
                                Height=" auto"
                                VerticalAlignment="Center"
                                Maximum=" 255"
                                Minimum=" 0"
                                Value="{Binding LightValue1, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Column=" 2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="{Binding LightValue1}" />
                        </Grid>

                        <Grid Grid.Row=" 1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=" 100" />
                                <ColumnDefinition Width=" *" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="通道2" />
                            <Slider
                                Grid.Column=" 1"
                                Height=" auto"
                                VerticalAlignment="Center"
                                Maximum=" 255"
                                Minimum=" 0"
                                Value="{Binding LightValue2, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Column=" 2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="{Binding LightValue2}" />
                        </Grid>

                        <Grid Grid.Row=" 2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=" 100" />
                                <ColumnDefinition Width=" *" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="通道3" />
                            <Slider
                                Grid.Column=" 1"
                                Height=" auto"
                                VerticalAlignment="Center"
                                Maximum=" 255"
                                Minimum=" 0"
                                Value="{Binding LightValue3, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Column=" 2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="{Binding LightValue3}" />
                        </Grid>

                        <Grid Grid.Row=" 3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=" 100" />
                                <ColumnDefinition Width=" *" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="通道4" />
                            <Slider
                                Grid.Column=" 1"
                                Height=" auto"
                                VerticalAlignment="Center"
                                Maximum=" 255"
                                Minimum=" 0"
                                Value="{Binding LightValue4, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Column=" 2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="25 "
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="{Binding LightValue4}" />
                        </Grid>

                    </Grid>
                </Border>
            </Grid>







        </Grid>



    </pf:TransitioningContentControl>

</UserControl>
