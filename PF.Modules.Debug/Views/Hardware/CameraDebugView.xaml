<UserControl
    x:Class="PF.Modules.Debug.Views.CameraDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="800"
    d:DesignWidth="1100"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,15"
                Padding="15"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="48"
                        Height="48"
                        Margin="0,0,15,0"
                        CornerRadius="8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Foreground="{DynamicResource TextIconBrush}"
                            Text="📷" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding DeviceName}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Text="{Binding DeviceDescription}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            Text="报警状态:" />


                        <Border
                            Margin="0,0,15,0"
                            Padding="8,4"
                            CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EF4444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                            <Setter Property="Background" Value="#02AD8B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding IsAlarm, StringFormat='{}{0}'}" />
                        </Border>


                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            Text="通讯状态:" />
                        <Border
                            Margin="0,0,15,0"
                            Padding="8,4"
                            CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EF4444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="#02AD8B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding IsConnected, StringFormat='{}{0}'}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        Padding="15"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="设备启停" />
                            <UniformGrid Margin="0,0,0,10" Columns="2">
                                <Button
                                    Height="36"
                                    Margin="0,0,5,5"
                                    Command="{Binding ConnectCommand}"
                                    Content="连接硬件"
                                    Style="{DynamicResource ButtonDefault}" />
                                <Button
                                    Height="36"
                                    Margin="5,0,0,5"
                                    Command="{Binding DisconnectCommand}"
                                    Content="断开连接"
                                    Style="{DynamicResource ButtonDefault}" />
                            </UniformGrid>
                            <Button
                                Height="36"
                                Margin="0,5"
                                Command="{Binding ResetCommand}"
                                Content="清除报警 (RESET)"
                                Style="{DynamicResource ButtonWarning}" />
                            <Button
                                Height="36"
                                Margin="0,5"
                                Command="{Binding SimulateAlarmCommand}"
                                Content="模拟报警测试"
                                Style="{DynamicResource ButtonDanger}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Padding="15"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,10,0,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="智能相机操作" />

                            <!--<Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>-->
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,10,10,0"
                                VerticalAlignment="Center"
                                Text="程式号:" />
                            <pf:SearchComboBox
                                Grid.Column="1"
                                Margin="0,10,10,0"
                                ItemsSource="{Binding CameraPrograms}"
                                SelectedItem="{Binding TargetJob}" />
                            <Button
                                Grid.Column="2"
                                Height="32"
                                Margin="0,10,0,0"
                                Command="{Binding ChangeJobCommand}"
                                Content="切换程序"
                                Style="{DynamicResource ButtonPrimary}" />
                            <!--</Grid>-->

                            <Button
                                Height="45"
                                Margin="0,10,0,0"
                                Command="{Binding TriggerCommand}"
                                Content="触发 (TRIGGER)"
                                FontSize="16"
                                FontWeight="Bold"
                                Style="{DynamicResource ButtonSuccess}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="15"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="读取结果 (Result/Barcode)" />
                            <TextBox
                                Height="80"
                                FontFamily="Consolas"
                                FontSize="16"
                                Foreground="#0284C7"
                                IsReadOnly="True"
                                Text="{Binding ResultText, Mode=OneWay}"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Padding="15"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="#94A3B8"
                            Text="[图片回显区域预留]" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>