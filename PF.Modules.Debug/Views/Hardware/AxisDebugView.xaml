<UserControl
    x:Class="PF.Modules.Debug.Views.AxisDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="800"
    d:DesignWidth="1100"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,15"
                Padding="15"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="48"
                        Height="48"
                        Margin="0,0,15,0"
                        CornerRadius="8">
                        <Button Style="{StaticResource ButtonCustom}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.H1.Large}"
                            Foreground="{DynamicResource TextIconBrush}"
                            Content="⚙️" Command="{Binding ShowAxisParamDialog}"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="{DynamicResource FontSize.H2.Title}"
                            FontWeight="Bold"
                            Text="{Binding DeviceName}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Text="{Binding DeviceDescription}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            Text="通讯状态:" />
                        <Border
                            Padding="8,4"
                            Background="#10B981"
                            CornerRadius="4">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding IsConnected, StringFormat='{}{0}'}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        Padding="15"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="实时位置 (DRO)" />
                            <Border
                                Padding="15"
                                Background="#E2E8F0"
                                CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="36"
                                        FontWeight="Heavy"
                                        Foreground="#4ADE80"
                                        Text="{Binding CurrentPosition}" />
                                    <TextBlock
                                        Margin="8,0,0,6"
                                        VerticalAlignment="Bottom"
                                        FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                        Foreground="#94A3B8"
                                        Text=" um" />
                                </StackPanel>
                            </Border>

                            <TextBlock
                                Margin="0,15,0,10"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="IO 状态监控" />
                            <UniformGrid Margin="0,5" Columns="2">
                                <CheckBox
                                    Margin="0,5"
                                    Content="轴已使能 (SVON)"
                                    IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <TextBlock />
                                <CheckBox
                                    Margin="0,5"
                                    Content="运动中 (BUSY)"
                                    Foreground="#0284C7"
                                    IsChecked="{Binding IsMoving, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <CheckBox
                                    Margin="0,5"
                                    Content="回零中 (HOME)"
                                    Foreground="#0284C7"
                                    IsChecked="{Binding IsMoving, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <CheckBox
                                    Margin="0,5"
                                    Content="正限位 (PEL)"
                                    Foreground="#EF4444"
                                    IsChecked="{Binding IsPositiveLimit, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <TextBlock />
                                <CheckBox
                                    Margin="0,5"
                                    Content="原点 (ORG)"
                                    Foreground="{DynamicResource  LightPrimaryBrush}"
                                    IsChecked="{Binding IsNegativeLimit, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <TextBlock />
                                <CheckBox
                                    Margin="0,5"
                                    Content="负限位 (NEL)"
                                    Foreground="#EF4444"
                                    IsChecked="{Binding IsNegativeLimit, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                                <TextBlock />
                                <CheckBox
                                    Margin="0,5"
                                    Content="驱动器报警 (ALM)"
                                    Foreground="#EF4444"
                                    IsChecked="{Binding IsAlarm, Mode=OneWay}"
                                    IsHitTestVisible="False" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Padding="15"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                FontWeight="SemiBold"
                                Foreground="#475569"
                                Text="设备启停" />
                            <UniformGrid Margin="0,0,0,10" Columns="2">
                                <Button
                                    Height="36"
                                    Margin="0,0,5,5"
                                    Command="{Binding ConnectCommand}"
                                    Content="连接硬件"
                                    Style="{DynamicResource ButtonDefault}" />
                                <Button
                                    Height="36"
                                    Margin="5,0,0,5"
                                    Command="{Binding DisconnectCommand}"
                                    Content="断开连接"
                                    Style="{DynamicResource ButtonDefault}" />
                                <Button
                                    Height="36"
                                    Margin="0,5,5,0"
                                    Command="{Binding EnableCommand}"
                                    Content="伺服使能 (ON)"
                                    Style="{DynamicResource ButtonPrimary}" />
                                <Button
                                    Height="36"
                                    Margin="5,5,0,0"
                                    Command="{Binding DisableCommand}"
                                    Content="断开使能 (OFF)"
                                    Style="{DynamicResource ButtonWarning}" />
                            </UniformGrid>

                            <Button
                                Height="40"
                                Margin="0,5"
                                Command="{Binding HomeCommand}"
                                Content="执行回零 (HOME)"
                                Style="{DynamicResource ButtonSuccess}" />
                            <Button
                                Height="45"
                                Margin="0,5"
                                Command="{Binding StopCommand}"
                                Content="急 停 (E-STOP)"
                                FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                FontWeight="Bold"
                                Style="{DynamicResource ButtonDanger}" />
                            <Button
                                Height="36"
                                Margin="0,5"
                                Command="{Binding ResetCommand}"
                                Content="报警复位 (RESET)"
                                Style="{DynamicResource ButtonDefault}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Border
                            Margin="0,0,0,10"
                            Padding="15"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Text="绝对目标(mm):" />
                                <TextBox
                                    Grid.Column="1"
                                    Height="36"
                                    Margin="0,0,20,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding TargetPosition}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Text="速度(mm/s):" />
                                <TextBox
                                    Grid.Column="3"
                                    Height="36"
                                    Margin="0,0,20,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding AbsVelocity}" />
                                <Button
                                    Grid.Column="4"
                                    Height="36"
                                    Command="{Binding MoveAbsoluteCommand}"
                                    Content="绝对运动"
                                    Style="{DynamicResource ButtonPrimary}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,0,0,10"
                            Padding="15"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Text="相对距离(mm):" />
                                <TextBox
                                    Grid.Column="1"
                                    Height="36"
                                    Margin="0,0,20,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding RelativeDistance}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Text="速度(mm/s):" />
                                <TextBox
                                    Grid.Column="3"
                                    Height="36"
                                    Margin="0,0,20,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding RelVelocity}" />
                                <Button
                                    Grid.Column="4"
                                    Height="36"
                                    Command="{Binding MoveRelativeCommand}"
                                    Content="相对运动"
                                    Style="{DynamicResource ButtonPrimary}" />
                            </Grid>
                        </Border>

                        <Border
                            Padding="15"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Grid.Column="0"
                                    Height="40"
                                    Command="{Binding JogNegativeCommand}"
                                    Content="◀ JOG -"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="Bold"
                                    Style="{DynamicResource ButtonDefault}">

                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                            <i:InvokeCommandAction Command="{Binding AxisStop}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Button>
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="20,0,10,0"
                                    VerticalAlignment="Center"
                                    Text="点动速度(mm/s):" />
                                <TextBox
                                    Grid.Column="3"
                                    Height="36"
                                    Margin="0,0,20,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding JogVelocity}" />
                                <Button
                                    Grid.Column="4"
                                    Height="40"
                                    Command="{Binding JogPositiveCommand}"
                                    Content="JOG + ▶"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="Bold"
                                    Style="{DynamicResource ButtonDefault}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                            <i:InvokeCommandAction Command="{Binding AxisStop}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="15"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Margin="0,0,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="SemiBold"
                                    Foreground="#475569"
                                    Text="预设点表 (Point Table)" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Body.Small}"
                                    Foreground="#94A3B8"
                                    Text="在此维护工艺坐标，解耦代码与位置" />
                            </StackPanel>

                            <DataGrid
                                Grid.Row="1"
                                AutoGenerateColumns="False"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                ItemsSource="{Binding PointTable}"
                                RowHeight="35"
                                SelectedItem="{Binding SelectedPoint}"
                                SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="50"
                                        Binding="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}"
                                        Header="序号" />
                                    <DataGridTextColumn
                                        Width="120"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        Header="点位名称" />
                                    <DataGridTextColumn
                                        Width="110"
                                        Binding="{Binding TargetPosition, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}"
                                        Header="目标位置(mm)" />
                                    <DataGridTextColumn
                                        Width="90"
                                        Binding="{Binding Speed, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}"
                                        Header="速度" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                        Header="备注说明" />
                                    <DataGridTemplateColumn Width="90" Header="快速移动">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Width="70"
                                                    Height="26"
                                                    Command="{Binding DataContext.GoToPointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Content="移动到"
                                                    Style="{DynamicResource ButtonPrimary}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel
                                Grid.Row="2"
                                Margin="0,15,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Height="32"
                                    Margin="0,0,10,0"
                                    Padding="15,0"
                                    Command="{Binding AddPointCommand}"
                                    Content="新增当前位置"
                                    Style="{DynamicResource ButtonSuccess}" />
                                <Button
                                    Height="32"
                                    Margin="0,0,10,0"
                                    Padding="15,0"
                                    Command="{Binding DeletePointCommand}"
                                    Content="删除选中"
                                    Style="{DynamicResource ButtonDanger}" />
                                <Button
                                    Height="32"
                                    Padding="25,0"
                                    Command="{Binding SavePointsCommand}"
                                    Content="保存修改到本地"
                                    Style="{DynamicResource ButtonPrimary}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>