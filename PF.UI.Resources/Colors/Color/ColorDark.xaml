    <Color x:Key="TitleColor">#EEEEEE</Color>
    <Color x:Key="SecondaryTitleColor">#00C79A</Color>

    <Color x:Key="DefaultColor">#3E3E42</Color>
    <Color x:Key="DarkDefaultColor">#2D2D30</Color>

    <Color x:Key="AccentColor">#00C79A</Color>
    <Color x:Key="DarkAccentColor">#009977</Color>

    <Color x:Key="DarkMaskColor">#80000000</Color>
    <Color x:Key="DarkOpacityColor">#40000000</Color>
