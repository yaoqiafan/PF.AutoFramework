    <Color x:Key="LightWarningColor">#4D3B14</Color>
    <Color x:Key="WarningColor">#CCA700</Color>
    <Color x:Key="DarkWarningColor">#A88800</Color>

    <Color x:Key="LightInfoColor">#1A3A52</Color>
    <Color x:Key="InfoColor">#3794FF</Color>
    <Color x:Key="DarkInfoColor">#0078D4</Color>

    <Color x:Key="LightSuccessColor">#1A3D24</Color>
