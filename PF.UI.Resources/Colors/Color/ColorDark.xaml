<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PF.UI.Resources"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <Color x:Key="LightPrimaryColor">#33CEAC</Color>
    <Color x:Key="PrimaryColor">#00C79A</Color>
    <Color x:Key="DarkPrimaryColor">#009977</Color>
    <Color x:Key="DeepDarkPrimaryColor">#0F2922</Color>
    <Color x:Key="LightDangerColor">#4D1D1D</Color>
