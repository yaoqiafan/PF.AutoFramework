<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.UserControls.RecipeDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    FontSize="{DynamicResource FontSize.H2.Title}"
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Button
                    MinHeight="35"
                    Padding="20,0"
                    Command="{Binding SwitchRecipeCommand}"
                    Content="切换工位" />
                <Button
                    MinHeight="35"
                    Margin="15,0,0,0"
                    Padding="20,0"
                    Command="{Binding OpenScannerSoftwareCommand}"
                    Content="打开扫码枪软件" />
                <Button
                    MinHeight="35"
                    Margin="15,0,0,0"
                    Padding="20,0"
                    Command="{Binding OpenCameraSoftwareCommand}"
                    Content="打开相机软件" />
            </StackPanel>
            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="当前工位：" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource FontSize.H1.Large}"
                    FontWeight="Bold"
                    Foreground="#0284C7"
                    Text="{Binding CurrentStation}" />
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== 左列：三轴卡片 + 设备控制 ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 视觉X轴卡片 -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="{DynamicResource FontSize.Body.Standard}"
                            FontWeight="SemiBold"
                            Text="视觉 X 轴" />
                        <Border
                            Margin="0,0,0,6"
                            Padding="8,4"
                            Background="#F1F5F9"
                            CornerRadius="4">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    FontWeight="Heavy"
                                    Foreground="#4ADE80"
                                    Text="{Binding XAxisCurrentPosition}" />
                                <TextBlock
                                    Margin="5,0,0,4"
                                    VerticalAlignment="Bottom"
                                    FontSize="{DynamicResource FontSize.Caption.Mini}"
                                    Foreground="#94A3B8"
                                    Text="um" />
                            </StackPanel>
                        </Border>
                        <UniformGrid Margin="0,0,0,6" Columns="5">
                            <CheckBox Content="使能" IsChecked="{Binding XAxisIsEnabled, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="运动" Foreground="#0284C7" IsChecked="{Binding XAxisIsMoving, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="正限" Foreground="#EF4444" IsChecked="{Binding XAxisIsPosLimit, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="负限" Foreground="#EF4444" IsChecked="{Binding XAxisIsNegLimit, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="报警" Foreground="#EF4444" IsChecked="{Binding XAxisIsAlarm, Mode=OneWay}" IsHitTestVisible="False" />
                        </UniformGrid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="32" Content="◀ JOG-" FontWeight="Bold" Style="{DynamicResource ButtonDefault}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding XJogNegativeCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding XAxisStopCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" Text="速度:" />
                            <TextBox
                                Grid.Column="2"
                                Height="30"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Text="{Binding XAxisJogVelocity, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="3"
                                Height="32"
                                Margin="4,0"
                                Command="{Binding XAxisStopCommand}"
                                Content="停止"
                                Style="{DynamicResource ButtonDanger}" />
                            <Button Grid.Column="4" Height="32" Content="JOG+ ▶" FontWeight="Bold" Style="{DynamicResource ButtonDefault}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding XJogPositiveCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding XAxisStopCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 视觉Y轴卡片 -->
                <Border
                    Grid.Row="1"
                    Margin="0,0,0,6"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="{DynamicResource FontSize.Body.Standard}"
                            FontWeight="SemiBold"
                            Text="视觉 Y 轴" />
                        <Border
                            Margin="0,0,0,6"
                            Padding="8,4"
                            Background="#F1F5F9"
                            CornerRadius="4">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    FontWeight="Heavy"
                                    Foreground="#4ADE80"
                                    Text="{Binding YAxisCurrentPosition}" />
                                <TextBlock
                                    Margin="5,0,0,4"
                                    VerticalAlignment="Bottom"
                                    FontSize="{DynamicResource FontSize.Caption.Mini}"
                                    Foreground="#94A3B8"
                                    Text="um" />
                            </StackPanel>
                        </Border>
                        <UniformGrid Margin="0,0,0,6" Columns="5">
                            <CheckBox Content="使能" IsChecked="{Binding YAxisIsEnabled, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="运动" Foreground="#0284C7" IsChecked="{Binding YAxisIsMoving, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="正限" Foreground="#EF4444" IsChecked="{Binding YAxisIsPosLimit, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="负限" Foreground="#EF4444" IsChecked="{Binding YAxisIsNegLimit, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="报警" Foreground="#EF4444" IsChecked="{Binding YAxisIsAlarm, Mode=OneWay}" IsHitTestVisible="False" />
                        </UniformGrid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="32" Content="◀ JOG-" FontWeight="Bold" Style="{DynamicResource ButtonDefault}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding YJogNegativeCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding YAxisStopCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" Text="速度:" />
                            <TextBox
                                Grid.Column="2"
                                Height="30"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Text="{Binding YAxisJogVelocity, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="3"
                                Height="32"
                                Margin="4,0"
                                Command="{Binding YAxisStopCommand}"
                                Content="停止"
                                Style="{DynamicResource ButtonDanger}" />
                            <Button Grid.Column="4" Height="32" Content="JOG+ ▶" FontWeight="Bold" Style="{DynamicResource ButtonDefault}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding YJogPositiveCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding YAxisStopCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 视觉Z轴卡片 -->
                <Border
                    Grid.Row="2"
                    Margin="0,0,0,6"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="{DynamicResource FontSize.Body.Standard}"
                            FontWeight="SemiBold"
                            Text="视觉 Z 轴" />
                        <Border
                            Margin="0,0,0,6"
                            Padding="8,4"
                            Background="#F1F5F9"
                            CornerRadius="4">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    FontWeight="Heavy"
                                    Foreground="#4ADE80"
                                    Text="{Binding ZAxisCurrentPosition}" />
                                <TextBlock
                                    Margin="5,0,0,4"
                                    VerticalAlignment="Bottom"
                                    FontSize="{DynamicResource FontSize.Caption.Mini}"
                                    Foreground="#94A3B8"
                                    Text="um" />
                            </StackPanel>
                        </Border>
                        <UniformGrid Margin="0,0,0,6" Columns="5">
                            <CheckBox Content="使能" IsChecked="{Binding ZAxisIsEnabled, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="运动" Foreground="#0284C7" IsChecked="{Binding ZAxisIsMoving, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="正限" Foreground="#EF4444" IsChecked="{Binding ZAxisIsPosLimit, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="负限" Foreground="#EF4444" IsChecked="{Binding ZAxisIsNegLimit, Mode=OneWay}" IsHitTestVisible="False" />
                            <CheckBox Content="报警" Foreground="#EF4444" IsChecked="{Binding ZAxisIsAlarm, Mode=OneWay}" IsHitTestVisible="False" />
                        </UniformGrid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="32" Content="◀ JOG-" FontWeight="Bold" Style="{DynamicResource ButtonDefault}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding ZJogNegativeCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding ZAxisStopCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" Text="速度:" />
                            <TextBox
                                Grid.Column="2"
                                Height="30"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Text="{Binding ZAxisJogVelocity, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="3"
                                Height="32"
                                Margin="4,0"
                                Command="{Binding ZAxisStopCommand}"
                                Content="停止"
                                Style="{DynamicResource ButtonDanger}" />
                            <Button Grid.Column="4" Height="32" Content="JOG+ ▶" FontWeight="Bold" Style="{DynamicResource ButtonDefault}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding ZJogPositiveCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding ZAxisStopCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 设备控制（简化）-->
            </Grid>

            <!-- ===== 右列：调试步骤 + 扫码 + OCR + 光源 ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 模组调试步骤 -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                FontWeight="SemiBold"
                                Text="模组调试（顺序流程）" />
                            <Button
                                HorizontalAlignment="Right"
                                Command="{Binding ResetDebugStepsCommand}"
                                Content="重 置"
                                Style="{DynamicResource ButtonDefault}" />
                        </Grid>
                        <Border
                            Margin="0,0,0,8"
                            Padding="8,5"
                            Background="#F0F9FF"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="{DynamicResource FontSize.Caption.Mini}"
                                Foreground="#0369A1"
                                Text="{Binding DebugStepMessage}"
                                TextWrapping="Wrap" />
                        </Border>

                        <!-- Step 0：移动挡料X轴到待机位 -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <Border Width="22" Height="22" VerticalAlignment="Center" Background="{Binding Step0Brush}" CornerRadius="11">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" FontWeight="Bold" Foreground="White" Text="0" />
                            </Border>
                            <TextBlock Grid.Column="1" Margin="8,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Text="移动挡料X轴到待机位" />
                            <Button
                                Grid.Column="2"
                                Height="28"
                                VerticalAlignment="Center"
                                Command="{Binding Step0MoveStopperToStandbyCommand}"
                                Content="执行"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>

                        <!-- Step 1：切换生产状态 -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <Border Width="22" Height="22" VerticalAlignment="Center" Background="{Binding Step1Brush}" CornerRadius="11">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" FontWeight="Bold" Foreground="White" Text="1" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock FontSize="{DynamicResource FontSize.Body.Small}" Text="切换生产状态" />
                                <TextBlock Margin="0,2,0,0" FontSize="{DynamicResource FontSize.Caption.Mini}" Foreground="#475569" Text="{Binding RecipeWaferSizeText}" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                Height="28"
                                VerticalAlignment="Center"
                                Command="{Binding Step1SwitchProductionCommand}"
                                Content="执行"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>

                        <!-- Step 2：切换至指定层 -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <Border Width="22" Height="22" VerticalAlignment="Center" Background="{Binding Step2Brush}" CornerRadius="11">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" FontWeight="Bold" Foreground="White" Text="2" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock FontSize="{DynamicResource FontSize.Body.Small}" Text="切换至指定层" />
                                <StackPanel Margin="0,2" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" Text="层数：" />
                                    <TextBox
                                        Width="48"
                                        Height="22"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        FontSize="{DynamicResource FontSize.Caption.Mini}"
                                        Text="{Binding TargetLayerNumber, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                Height="28"
                                VerticalAlignment="Center"
                                Command="{Binding Step2SwitchLayerCommand}"
                                Content="执行"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>

                        <!-- Step 3：拉料流程测试 -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <Border Width="22" Height="22" VerticalAlignment="Center" Background="{Binding Step3Brush}" CornerRadius="11">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" FontWeight="Bold" Foreground="White" Text="3" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock FontSize="{DynamicResource FontSize.Body.Small}" Text="拉料流程测试" />
                                <TextBlock Margin="0,2,0,0" FontSize="{DynamicResource FontSize.Caption.Mini}" Foreground="#94A3B8" Text="（自动关闭凸片检测）" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                Height="28"
                                VerticalAlignment="Center"
                                Command="{Binding Step3PullMaterialCommand}"
                                Content="执行"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>

                        <!-- Step 4：推料流程测试 -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <Border Width="22" Height="22" VerticalAlignment="Center" Background="{Binding Step4Brush}" CornerRadius="11">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Caption.Mini}" FontWeight="Bold" Foreground="White" Text="4" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock FontSize="{DynamicResource FontSize.Body.Small}" Text="推料流程测试" />
                                <TextBlock Margin="0,2,0,0" FontSize="{DynamicResource FontSize.Caption.Mini}" Foreground="#94A3B8" Text="（自动关闭凸片检测）" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                Height="28"
                                VerticalAlignment="Center"
                                Command="{Binding Step4PushMaterialCommand}"
                                Content="执行"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 扫码调试 -->
                <Border
                    Grid.Row="1"
                    Margin="0,0,0,6"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                FontWeight="SemiBold"
                                Text="扫码调试" />
                            <TextBox
                                Height="36"
                                FontFamily="Consolas"
                                FontSize="{DynamicResource FontSize.H2.Title}"
                                IsReadOnly="True"
                                Text="{Binding ScanResult}"
                                TextAlignment="Center" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Width="80"
                            Height="36"
                            Margin="12,22,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding TriggerScanCommand}"
                            Content="触发扫码"
                            Style="{DynamicResource ButtonDefault}" />
                    </Grid>
                </Border>

                <!-- OCR调试 -->
                <Border
                    Grid.Row="2"
                    Margin="0,0,0,6"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                FontWeight="SemiBold"
                                Text="OCR 调试" />
                            <TextBox
                                Height="36"
                                FontFamily="Consolas"
                                FontSize="{DynamicResource FontSize.H2.Title}"
                                IsReadOnly="True"
                                Text="{Binding OcrResult}"
                                TextAlignment="Center" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Width="80"
                            Height="36"
                            Margin="12,22,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding TriggerOcrCommand}"
                            Content="触发 OCR"
                            Style="{DynamicResource ButtonDefault}" />
                    </Grid>
                </Border>

                <!-- 光源控制 -->
                <Border
                    Grid.Row="3"
                    Padding="12,10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{DynamicResource FontSize.Body.Standard}"
                            FontWeight="SemiBold"
                            Foreground="#475569"
                            Text="光源控制" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Text="红外光" />
                            <Slider Grid.Column="1" Maximum="255" Minimum="0" Value="{Binding InfraredLightValue, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Text="{Binding InfraredLightValue}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Text="条光" />
                            <Slider Grid.Column="1" Maximum="255" Minimum="0" Value="{Binding WhiteLightValue, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Text="{Binding WhiteLightValue}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部：当前工位配方点位 + 多轴运动 + 同步调整 -->
        <Border
            Grid.Row="2"
            Margin="0,0,0,5"
            Padding="15,10"
            Background="#F8FAFC"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 点位显示 -->
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" FontWeight="SemiBold" Foreground="#475569" Text="当前工位配方点位：" />
                    <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Foreground="#475569" Text="X = " />
                    <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="{DynamicResource FontSize.Body.Standard}" FontWeight="Bold" Foreground="#1E293B" Text="{Binding RecipePosX, StringFormat=F3}" />
                    <TextBlock Margin="18,0,0,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Foreground="#475569" Text="Y = " />
                    <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="{DynamicResource FontSize.Body.Standard}" FontWeight="Bold" Foreground="#1E293B" Text="{Binding RecipePosY, StringFormat=F3}" />
                    <TextBlock Margin="18,0,0,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSize.Body.Small}" Foreground="#475569" Text="Z = " />
                    <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="{DynamicResource FontSize.Body.Standard}" FontWeight="Bold" Foreground="#1E293B" Text="{Binding RecipePosZ, StringFormat=F3}" />
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button
                        MinHeight="32"
                        Padding="18,0"
                        Command="{Binding GetAndUpdateRecipeXYZCommand}"
                        Content="获取当前轴位置"
                        Style="{DynamicResource ButtonDefault}" />
                    <Button
                        MinHeight="32"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        Command="{Binding MoveToRecipeXYZCommand}"
                        Content="移动到配方点位（XYZ）"
                        Style="{DynamicResource ButtonPrimary}" />
                    <Button
                        MinHeight="32"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        Command="{Binding SyncAdjustCommand}"
                        Content="同步调整"
                        Style="{DynamicResource ButtonDefault}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部对话框按钮 -->
        <Grid Grid.Row="3">
            <Button
                x:Name="BtnMiniMode"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                MinHeight="35"
                Padding="20,0"
                Click="BtnMiniMode_Click"
                Content="迷你模式"
                Style="{DynamicResource ButtonSuccess}" />
            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    MinHeight="35"
                    Padding="25,0"
                    Command="{Binding CancelCommand}"
                    Content="取消" />
                <Button
                    MinHeight="35"
                    Margin="15,0,0,0"
                    Padding="25,0"
                    Command="{Binding ConfirmCommand}"
                    Content="应用" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
