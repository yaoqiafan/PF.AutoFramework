<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.UserControls.RecipeDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="850"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition MaxHeight="740" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button
                MinHeight="35"
                Margin="0,0,0,0"
                Padding="25,0"
                Command="{Binding SwitchRecipeCommand}"
                Content="切换工位" />

            <Button
                MinHeight="35"
                Margin="25,0,0,0"
                Padding="25,0"
                Command="{Binding OpenScannerSoftwareCommand}"
                Content="打开扫码枪软件" />
            <Button
                MinHeight="35"
                Margin="25,0,0,0"
                Padding="25,0"
                Command="{Binding OpenCameraSoftwareCommand}"
                Content="打开相机软件" />
        </StackPanel>


        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinHeight="35"
                Margin="0,0,0,0"
                Padding="25,0"
                Command="{Binding CancelCommand}"
                Content="取消" />

            <Button
                MinHeight="35"
                Margin="25,0,0,0"
                Padding="25,0"
                Command="{Binding ConfirmCommand}"
                Content="应用" />
        </StackPanel>



        <pf:Card Grid.Row="1" Width="900">
            <Border Margin="10" CornerRadius="4,4,0,0">
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Margin="0,0,0,15"
                            Padding="15"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="SemiBold"
                                    Text="实时位置 (DRO)" />
                                <Border
                                    Padding="15"
                                    Background="#E2E8F0"
                                    CornerRadius="6">
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="36"
                                            FontWeight="Heavy"
                                            Foreground="#4ADE80"
                                            Text="{Binding CurrentPosition}" />
                                        <TextBlock
                                            Margin="8,0,0,6"
                                            VerticalAlignment="Bottom"
                                            FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                            Foreground="#94A3B8"
                                            Text=" um" />
                                    </StackPanel>
                                </Border>

                                <TextBlock
                                    Margin="0,15,0,10"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="SemiBold"
                                    Text="IO 状态监控" />
                                <UniformGrid Margin="0,5" Columns="2">
                                    <CheckBox
                                        Margin="0,5"
                                        Content="轴已使能 (SVON)"
                                        IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                        IsHitTestVisible="False" />
                                    <CheckBox
                                        Margin="0,5"
                                        Content="正在运动 (BUSY)"
                                        Foreground="#0284C7"
                                        IsChecked="{Binding IsMoving, Mode=OneWay}"
                                        IsHitTestVisible="False" />
                                    <CheckBox
                                        Margin="0,5"
                                        Content="正限位 (PEL)"
                                        Foreground="#EF4444"
                                        IsChecked="{Binding IsPositiveLimit, Mode=OneWay}"
                                        IsHitTestVisible="False" />
                                    <CheckBox
                                        Margin="0,5"
                                        Content="负限位 (NEL)"
                                        Foreground="#EF4444"
                                        IsChecked="{Binding IsNegativeLimit, Mode=OneWay}"
                                        IsHitTestVisible="False" />
                                    <CheckBox
                                        Margin="0,5"
                                        Content="驱动器报警 (ALM)"
                                        Foreground="#EF4444"
                                        IsChecked="{Binding IsAlarm, Mode=OneWay}"
                                        IsHitTestVisible="False" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Padding="15"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="SemiBold"
                                    Foreground="#475569"
                                    Text="设备启停" />
                                <UniformGrid Margin="0,0,0,10" Columns="2">
                                    <Button
                                        Height="36"
                                        Margin="0,0,5,5"
                                        Command="{Binding ConnectCommand}"
                                        Content="连接硬件"
                                        Style="{DynamicResource ButtonDefault}" />
                                    <Button
                                        Height="36"
                                        Margin="5,0,0,5"
                                        Command="{Binding DisconnectCommand}"
                                        Content="断开连接"
                                        Style="{DynamicResource ButtonDefault}" />
                                    <Button
                                        Height="36"
                                        Margin="0,5,5,0"
                                        Command="{Binding EnableCommand}"
                                        Content="伺服使能 (ON)"
                                        Style="{DynamicResource ButtonPrimary}" />
                                    <Button
                                        Height="36"
                                        Margin="5,5,0,0"
                                        Command="{Binding DisableCommand}"
                                        Content="断开使能 (OFF)"
                                        Style="{DynamicResource ButtonWarning}" />
                                </UniformGrid>

                                <Button
                                    Height="40"
                                    Margin="0,5"
                                    Command="{Binding HomeCommand}"
                                    Content="执行回零 (HOME)"
                                    Style="{DynamicResource ButtonSuccess}" />
                                <Button
                                    Height="45"
                                    Margin="0,5"
                                    Command="{Binding StopCommand}"
                                    Content="急 停 (E-STOP)"
                                    FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                    FontWeight="Bold"
                                    Style="{DynamicResource ButtonDanger}" />
                                <Button
                                    Height="36"
                                    Margin="0,5"
                                    Command="{Binding ResetCommand}"
                                    Content="报警复位 (RESET)"
                                    Style="{DynamicResource ButtonDefault}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Border
                                Margin="0,0,0,10"
                                Padding="15"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="绝对目标(um):" />
                                    <TextBox
                                        Grid.Column="1"
                                        Height="36"
                                        Margin="0,0,20,0"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding TargetPosition}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="速度(um/s):" />
                                    <TextBox
                                        Grid.Column="3"
                                        Height="36"
                                        Margin="0,0,20,0"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding AbsVelocity}" />
                                    <Button
                                        Grid.Column="4"
                                        Height="36"
                                        Command="{Binding MoveAbsoluteCommand}"
                                        Content="绝对运动"
                                        Style="{DynamicResource ButtonPrimary}" />
                                </Grid>
                            </Border>

                            <Border
                                Margin="0,0,0,10"
                                Padding="15"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="相对距离(um):" />
                                    <TextBox
                                        Grid.Column="1"
                                        Height="36"
                                        Margin="0,0,20,0"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding RelativeDistance}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="速度(um/s):" />
                                    <TextBox
                                        Grid.Column="3"
                                        Height="36"
                                        Margin="0,0,20,0"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding RelVelocity}" />
                                    <Button
                                        Grid.Column="4"
                                        Height="36"
                                        Command="{Binding MoveRelativeCommand}"
                                        Content="相对运动"
                                        Style="{DynamicResource ButtonPrimary}" />
                                </Grid>
                            </Border>

                            <Border
                                Padding="15"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        Grid.Column="0"
                                        Height="40"
                                        Content="◀ JOG -"
                                        FontSize="{DynamicResource FontSize.Body.Standard}"
                                        FontWeight="Bold"
                                        Style="{DynamicResource ButtonDefault}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding JogNegativeCommand}" />
                                            </i:EventTrigger>
                                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding AxisStopCommand}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Button>
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="20,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="点动速度(um/s):" />
                                    <TextBox
                                        Grid.Column="3"
                                        Height="36"
                                        Margin="0,0,20,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding JogVelocity}" />
                                    <Button
                                        Grid.Column="4"
                                        Height="40"
                                        Content="JOG + ▶"
                                        FontSize="{DynamicResource FontSize.Body.Standard}"
                                        FontWeight="Bold"
                                        Style="{DynamicResource ButtonDefault}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding JogPositiveCommand}" />
                                            </i:EventTrigger>
                                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding AxisStopCommand}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Border
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            Padding="15"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6">

                            <ScrollViewer>
                                <StackPanel>
                                    <pf:Card Height="180" BorderBrush="{DynamicResource ControlDefultBrush}">
                                        <pf:Card.Header>
                                            <Grid>
                                                <StackPanel Margin="10" Orientation="Horizontal">
                                                    <TextBlock
                                                        HorizontalAlignment="Left"
                                                        Style="{DynamicResource TextBlockLargeBold}"
                                                        Text="当前程式当前轴点位："
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />

                                                </StackPanel>
                                            </Grid>
                                        </pf:Card.Header>

                                        <Border>

                                            <TextBox
                                                Margin="5"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                FontSize="40"
                                                Text="{Binding RecipeAxisPosition, StringFormat={}{0:F3}}"
                                                TextAlignment="Center" />
                                        </Border>

                                        <pf:Card.Footer>
                                            <pf:ButtonGroup Margin="10">
                                                <Button Command="{Binding MoveToRecipePositionCommand}" Content="移动到" />
                                                <Button Command="{Binding GetCurrentPositionCommand}" Content="获取当前轴位置" />
                                                <Button Command="{Binding UpdateRecipePositionCommand}" Content="更新" />
                                            </pf:ButtonGroup>
                                        </pf:Card.Footer>
                                    </pf:Card>

                                    <pf:Card
                                        Height="180"
                                        Margin="0,10,0,0"
                                        BorderBrush="{DynamicResource ControlDefultBrush}">
                                        <pf:Card.Header>
                                            <Grid>
                                                <StackPanel Margin="10" Orientation="Horizontal">
                                                    <TextBlock
                                                        HorizontalAlignment="Left"
                                                        Style="{DynamicResource TextBlockLargeBold}"
                                                        Text="扫码调试："
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />

                                                </StackPanel>
                                            </Grid>
                                        </pf:Card.Header>

                                        <Border>

                                            <TextBox
                                                Margin="5"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                FontSize="40"
                                                IsReadOnly="True"
                                                Text="{Binding ScanResult}"
                                                TextAlignment="Center" />
                                        </Border>

                                        <pf:Card.Footer>
                                            <pf:ButtonGroup Margin="10">
                                                <Button Command="{Binding TriggerScanCommand}" Content="触发扫码" />
                                            </pf:ButtonGroup>
                                        </pf:Card.Footer>
                                    </pf:Card>


                                    <pf:Card
                                        Height="180"
                                        Margin="0,10,0,0"
                                        BorderBrush="{DynamicResource ControlDefultBrush}">
                                        <pf:Card.Header>
                                            <Grid>
                                                <StackPanel Margin="10" Orientation="Horizontal">
                                                    <TextBlock
                                                        HorizontalAlignment="Left"
                                                        Style="{DynamicResource TextBlockLargeBold}"
                                                        Text="OCR调试："
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />

                                                </StackPanel>
                                            </Grid>
                                        </pf:Card.Header>

                                        <Border>

                                            <TextBox
                                                Margin="5"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                FontSize="40"
                                                IsReadOnly="True"
                                                Text="{Binding OcrResult}"
                                                TextAlignment="Center" />
                                        </Border>

                                        <pf:Card.Footer>
                                            <pf:ButtonGroup Margin="10">
                                                <Button Command="{Binding TriggerOcrCommand}" Content="触发OCR" />
                                            </pf:ButtonGroup>
                                        </pf:Card.Footer>
                                        
                                    </pf:Card>
                                    

                                </StackPanel>
                            </ScrollViewer>


                        </Border>
                    </Grid>
                </Grid>


            </Border>
            <pf:Card.Footer>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition/>
                    </Grid.RowDefinitions>


                    <StackPanel Margin="10" Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockLargeBold}"
                                Text="当前轴："
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                            <ComboBox
                                MinWidth="100"
                                Margin="0,0,25,0"
                                HorizontalAlignment="Left"
                                DisplayMemberPath="DeviceName"
                                ItemsSource="{Binding AxisList}"
                                SelectedItem="{Binding SelectedAxis}" />
                        </StackPanel>


                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockLargeBold}"
                                Text="当前工位："
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                MinWidth="80"
                                Margin="0,0,0,0"
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockLargeBold}"
                                Text="{Binding CurrentStation}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </StackPanel>
                    </StackPanel>


                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <Button
                            MinHeight="35"
                            Margin="10"
                            Padding="25,0"
                            Command="{Binding SyncAdjustCommand}"
                            Content="同步调整" />
                    </StackPanel>



                    <StackPanel
                        Grid.Row="1"
                        Margin="10"
                        Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockLargeBold}"
                                Text="当前程式点位："
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockLargeBold}"
                                Text="{Binding CurrentRecipePosition, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>



                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal">
                            <Button
                                MinHeight="35"
                                Margin="10"
                                Padding="25,0"
                                Command="{Binding MoveToRecipePositionCommand}"
                                Content="移动到当前点位" />
                        </StackPanel>

                    </StackPanel>

                    <StackPanel Grid.Row=" 2" Margin=" 10"  >
                        <Grid >
                            <Grid.RowDefinitions  >
                                <RowDefinition />
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid >
                                <Grid.ColumnDefinitions >
                                    <ColumnDefinition Width=" 100"/>
                                    <ColumnDefinition Width=" *"/>
                                    <ColumnDefinition Width=" 100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="红外光" Style="{DynamicResource TextBlockLargeBold}"/>
                                <Slider Grid.Column=" 1" Maximum=" 255" Minimum=" 0"   Value="{Binding InfraredLightValue, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding InfraredLightValue}"  Grid.Column=" 2" Style="{DynamicResource TextBlockLargeBold}"/>
                            </Grid>

                            <Grid  Grid.Row=" 1">
                                <Grid.ColumnDefinitions >
                                    <ColumnDefinition Width=" 100"/>
                                    <ColumnDefinition Width=" *"/>
                                    <ColumnDefinition Width=" 100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="条光" Style="{DynamicResource TextBlockLargeBold}"/>
                                <Slider Grid.Column=" 1" Maximum=" 255" Minimum=" 0"   Value="{Binding WhiteLightValue, UpdateSourceTrigger=PropertyChanged}"   />
                                <TextBlock  Grid.Column=" 2" Text="{Binding WhiteLightValue}" Style="{DynamicResource TextBlockLargeBold}"/>
                            </Grid>

                        </Grid>
                        

                     

                    </StackPanel>
                    
                    

                </Grid>
            </pf:Card.Footer>
        </pf:Card>
    </Grid>
</UserControl>
