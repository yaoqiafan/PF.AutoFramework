<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.UserControls.ZoomableImageViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid x:Name="ViewportGrid" 
          ClipToBounds="True"
          MouseWheel="OnMouseWheel"
          MouseLeftButtonDown="OnMouseLeftButtonDown"
          MouseLeftButtonUp="OnMouseLeftButtonUp"
          MouseMove="OnMouseMove">

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="复原 (Reset)" Click="MenuItem_Reset_Click" />
                <Separator />
                <MenuItem Header="另存为原图... (Save As)" Click="MenuItem_SaveAs_Click" />
            </ContextMenu>
        </Grid.ContextMenu>

        <Grid x:Name="TransformRoot" RenderTransformOrigin="0,0">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ImageScaleTransform" />
                    <TranslateTransform x:Name="ImageTranslateTransform" />
                </TransformGroup>
            </Grid.RenderTransform>

            <Image x:Name="MainImage" Stretch="Uniform" />

            <Border Margin="15" Padding="8,5" CornerRadius="4" Background="{DynamicResource  DarkOpacityBrush}"  
                    HorizontalAlignment="Left" VerticalAlignment="Top" IsHitTestVisible="False"
                    >
                <ContentPresenter Content="{Binding AnnotationContent, RelativeSource={RelativeSource AncestorType=UserControl}}" >
                    <ContentPresenter.Resources>
                        <DataTemplate DataType="{x:Type sys:String}">
                            <TextBlock Background="Transparent" Text="{Binding}" Foreground="White" FontWeight="Bold" FontSize="{DynamicResource FontSize.Body.Small}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ContentPresenter.Resources>
                </ContentPresenter>
            </Border>
        </Grid>
    </Grid>
</UserControl>
