<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.UserControls.ZoomableImageViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid
        x:Name="ViewportGrid"
        ClipToBounds="True"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseMove="OnMouseMove"
        MouseWheel="OnMouseWheel">

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Click="MenuItem_Reset_Click" Header="复原 (Reset)" />
                <Separator />
                <MenuItem Click="MenuItem_SaveAs_Click" Header="另存为原图... (Save As)" />
            </ContextMenu>
        </Grid.ContextMenu>

        <!--  真实图片层：可随鼠标缩放/平移  -->
        <Grid x:Name="TransformRoot" RenderTransformOrigin="0,0">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ImageScaleTransform" />
                    <TranslateTransform x:Name="ImageTranslateTransform" />
                </TransformGroup>
            </Grid.RenderTransform>

            <Image
                x:Name="MainImage"
                Stretch="Uniform"
                Visibility="Collapsed" />

            <Border
                Margin="15"
                Padding="8,5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{DynamicResource DarkOpacityBrush}"
                CornerRadius="4"
                IsHitTestVisible="False">
                <ContentPresenter Content="{Binding AnnotationContent, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ContentPresenter.Resources>
                        <DataTemplate DataType="{x:Type sys:String}">
                            <TextBlock
                                Background="Transparent"
                                FontSize="{DynamicResource FontSize.Body.Small}"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding}"
                                TextWrapping="Wrap" />
                        </DataTemplate>
                    </ContentPresenter.Resources>
                </ContentPresenter>
            </Border>
        </Grid>

        <!--  占位图层：在无有效图片时居中显示固定尺寸图标，不受缩放/平移影响  -->
        <Image
            x:Name="PlaceholderImage"
            Width="100"
            Height="100"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsHitTestVisible="False"
            Stretch="Uniform"
            Visibility="Visible" />
    </Grid>
</UserControl>
