<UserControl x:Class="PF.WorkStation.AutoOcr.UI.UserControls.AssociateProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="5">
            <Button Content="➕ 添加配方" Click="BtnAdd_Click" 
                    Style="{DynamicResource ButtonPrimary}"
                    Padding="15,6" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
            <Button Content="✖ 删除选中" Click="BtnDelete_Click" 
                    Background="#444444" Foreground="White" 
                    Padding="15,6" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="ItemListView" 
                  ItemsSource="{Binding InternalList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  Margin="5"  BorderThickness="1" 
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=LostFocus}"  HorizontalAlignment="Stretch"
                             MinHeight="28" VerticalContentAlignment="Center" />
                </DataTemplate>
            </ListView.ItemTemplate>
            
        </ListView>
    </Grid>
</UserControl>