<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.UserControls.AssociateProductListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="5" Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Padding="15,6"
                BorderThickness="0"
                Click="BtnAdd_Click"
                Content="➕ 添加配方"
                Cursor="Hand"
                Style="{DynamicResource ButtonPrimary}" />
            <Button
                Padding="15,6"
                Background="#444444"
                BorderThickness="0"
                Click="BtnDelete_Click"
                Content="✖ 删除选中"
                Cursor="Hand"
                Foreground="White" />
        </StackPanel>

        <ListView
            x:Name="ItemListView"
            Grid.Row="1"
            Margin="5"
            BorderThickness="1"
            ItemsSource="{Binding InternalList, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBox
                        MinHeight="28"
                        HorizontalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        Text="{Binding Value, UpdateSourceTrigger=LostFocus}" />
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
    </Grid>
</UserControl>