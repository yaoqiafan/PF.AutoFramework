<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.UserControls.WaferSlotDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:PF.WorkStation.AutoOcr.UI.Converters"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinWidth="500"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Standard}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Padding="24" Background="{DynamicResource RegionColorBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="220" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题行：层号 + 状态徽章  -->
            <Grid Grid.Row="0">
                <TextBlock
                    FontSize="{DynamicResource FontSize.H1.Large}"
                    FontWeight="Bold"
                    Text="{Binding DisplayIndex, StringFormat=第 {0} 层  检测详情}" />
                <Border
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Padding="12,4"
                    CornerRadius="4"
                    Background="{Binding StatusBrush}">
                    <TextBlock
                        FontSize="{DynamicResource FontSize.H3.Subtitle}"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding StatusText}" />
                </Border>
            </Grid>

            <Separator Grid.Row="1" Margin="0,2" Background="{DynamicResource BorderBrush}" Opacity="0.5" />

            <!--  检测数据表格  -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  检测时间 / 客户批次  -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="检测时间：" FontWeight="SemiBold" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetectionTime}" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="客户批次：" FontWeight="SemiBold" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding CustomerBatch}" />

                <!--  OCR 值 / 条码  -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="OCR 值：" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OcrText}" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="条　码：" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Barcode1}" />

                <!--  操作员 / 配方名称  -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="操作员：" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OperatorId}" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="配方名称：" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding RecipeName}" />

                <!--  匹配结果  -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="匹配结果：" FontWeight="SemiBold" />
                <Border
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,6"
                    Padding="10,2"
                    HorizontalAlignment="Left"
                    CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#E8F5E9" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                    <Setter Property="Background" Value="#FFEBEE" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="✓  OK" />
                                <Setter Property="Foreground" Value="#2E7D32" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                        <Setter Property="Text" Value="✗  NG" />
                                        <Setter Property="Foreground" Value="#C62828" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!--  错误信息（仅 NG 时显示）  -->
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    Margin="0,4,0,0"
                    Text="错误信息："
                    FontWeight="SemiBold"
                    VerticalAlignment="Top"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Margin="0,4,0,0"
                    Foreground="#C62828"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <!--  原图预览  -->
            <local:ZoomableImageViewer
                Grid.Row="4"
                AnnotationContent="{Binding DetectionData}"
                Source="{Binding ImagePath}" />

            <!--  关闭按钮  -->
            <Button
                Grid.Row="6"
                Height="36"
                MinWidth="90"
                HorizontalAlignment="Right"
                Command="{Binding CancelCommand}"
                Content="关  闭"
                Style="{DynamicResource ButtonDefault}" />
        </Grid>
    </Border>
</UserControl>
