<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.WorkStations.AutoOCRMachineControllerDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:PF.WorkStation.AutoOcr.UI.ViewModels.WorkStations"
    d:DesignHeight="800"
    d:DesignWidth="820"
    mc:Ignorable="d"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThirdlyRegionColorBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColorBrush}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColorBrush}" />
        </Style>
        <Style x:Key="CtrlButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="EStopButton" TargetType="Button" BasedOn="{StaticResource CtrlButton}">
            <Setter Property="Background" Value="{DynamicResource DangerColorBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" Width="780">

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  区块1：机台主控状态看板                                        -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="{DynamicResource FontSize.Body.Standard}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource PrimaryColorBrush}"
                Text="● 机台主控状态" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!-- 主控状态 -->
                <Border Grid.Column="0" Margin="0,0,5,0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="主控状态" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse
                                Width="10"
                                Height="10"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Fill="{Binding StatusBrush}" />
                            <TextBlock Style="{StaticResource ValueText}" Text="{Binding ControllerState}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 运行模式 -->
                <Border Grid.Column="1" Margin="3,0,3,0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="运行模式" />
                        <TextBlock Style="{StaticResource ValueText}" Text="{Binding CurrentMode}" />
                    </StackPanel>
                </Border>

                <!-- 子工站数量 -->
                <Border Grid.Column="2" Margin="3,0,3,0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="子工站总数" />
                        <TextBlock Style="{StaticResource ValueText}" Text="{Binding SubStationItems.Count}" />
                    </StackPanel>
                </Border>

                <!-- 最近报警信息 -->
                <Border Grid.Column="3" Margin="5,0,0,0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="最近报警" />
                        <TextBlock
                            FontSize="11"
                            Text="{Binding LastAlarmMessage}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap"
                            ToolTip="{Binding LastAlarmMessage}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource ValueText}">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColorBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LastAlarmMessage}" Value="无">
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 机台级控制按钮 -->
            <Border
                Margin="0,6,0,0"
                Padding="14,12"
                Background="{DynamicResource SecondaryRegionColorBrush}"
                BorderBrush="{DynamicResource BorderColorBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        Foreground="{DynamicResource SecondaryTextColorBrush}"
                        Text="机台全局控制指令" />
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Style="{StaticResource CtrlButton}"
                            Command="{Binding InitializeAllCommand}"
                            Content="全线初始化"
                            ToolTip="依次初始化所有子工站，完成后进入 Idle" />
                        <Separator Width="1" Margin="8,4" Background="{DynamicResource BorderColorBrush}" />
                        <Button
                            Style="{StaticResource CtrlButton}"
                            Command="{Binding StartAllCommand}"
                            Content="▶ 全线启动" />
                        <Button
                            Style="{StaticResource CtrlButton}"
                            Command="{Binding PauseAllCommand}"
                            Content="⏸ 全线暂停" />
                        <Button
                            Style="{StaticResource CtrlButton}"
                            Command="{Binding ResumeAllCommand}"
                            Content="▶ 全线恢复" />
                        <Button
                            Style="{StaticResource CtrlButton}"
                            Command="{Binding StopAllCommand}"
                            Content="⏹ 全线停止" />
                        <Separator Width="1" Margin="8,4" Background="{DynamicResource BorderColorBrush}" />
                        <Button
                            Style="{StaticResource CtrlButton}"
                            Command="{Binding ResetAllCommand}"
                            Content="⟳ 全线复位"
                            ToolTip="依次复位所有子工站并重置流水线信号量" />
                        <Button
                            Style="{StaticResource EStopButton}"
                            Command="{Binding EmergencyStopCommand}"
                            Content="⚠ 急停"
                            ToolTip="立即触发全局急停（软件切入 Alarm + 硬件下电制动）" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  区块2：子工站状态列表                                          -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TextBlock
                Margin="0,20,0,8"
                FontSize="{DynamicResource FontSize.Body.Standard}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource PrimaryColorBrush}"
                Text="● 子工站状态" />

            <Border
                Padding="0"
                Background="{DynamicResource SecondaryRegionColorBrush}"
                BorderBrush="{DynamicResource BorderColorBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <ItemsControl ItemsSource="{Binding SubStationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="1"
                                Padding="14,10"
                                BorderBrush="{DynamicResource BorderColorBrush}"
                                BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 工站名称 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Fill="{Binding StateBrush}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource PrimaryTextColorBrush}"
                                            Text="{Binding StationName}" />
                                    </StackPanel>

                                    <!-- 状态 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                                            Text="状态机状态" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{Binding StateBrush}"
                                            Text="{Binding State}" />
                                    </StackPanel>

                                    <!-- 步序描述 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                                            Text="当前步序" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="{DynamicResource PrimaryTextColorBrush}"
                                            Text="{Binding StepDescription}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  区块3：流水线信号量状态                                        -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <TextBlock
                Margin="0,20,0,8"
                FontSize="{DynamicResource FontSize.Body.Standard}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource PrimaryColorBrush}"
                Text="● 流水线信号量" />

            <Border
                Padding="14,12"
                Background="{DynamicResource SecondaryRegionColorBrush}"
                BorderBrush="{DynamicResource BorderColorBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <!-- 有信号量时显示列表 -->
                    <ItemsControl ItemsSource="{Binding SignalItems}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SignalItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="220" ItemHeight="70" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="5"
                                    Padding="12,8"
                                    Background="{DynamicResource ThirdlyRegionColorBrush}"
                                    BorderBrush="{DynamicResource BorderColorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource PrimaryTextColorBrush}"
                                            Text="{Binding SignalName}"
                                            TextTrimming="CharacterEllipsis" />
                                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource SecondaryTextColorBrush}"
                                                Text="初始值: " />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource PrimaryTextColorBrush}"
                                                Text="{Binding InitialCount}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                FontSize="11"
                                                Foreground="{DynamicResource SecondaryTextColorBrush}"
                                                Text="状态: " />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource PrimaryColorBrush}"
                                                Text="{Binding StatusText}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 无信号量时显示提示 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SignalItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                            Text="暂无已注册信号量" />
                        <TextBlock
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextColorBrush}"
                            Text="在 WorkstationSignals.cs 中定义信号量常量并在 AutoOCRMachineController 中注册后，此处将自动显示信号量状态。"
                            TextWrapping="Wrap"
                            MaxWidth="500" />
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
