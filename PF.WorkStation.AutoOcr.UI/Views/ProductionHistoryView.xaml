<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.ProductionHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style
            x:Key="FilterLabelStyle"
            BasedOn="{StaticResource TextBlockBaseStyle}"
            TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </UserControl.Resources>

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,20"
                FontSize="{DynamicResource FontSize.H1.Large}"
                FontWeight="Light"
                Text="生产历史记录" />

            <pf:Card
                Grid.Row="1"
                VerticalAlignment="Stretch"
                Header="历史数据查询">

                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="0,0,0,15"
                        BorderBrush="#EEE"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="600" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <pf:DateTimeSelector
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource BackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CheckBoxHeight="30"
                                EndTime="{Binding EndTime, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                ShowCheckBox="False"
                                StartTime="{Binding StartTime, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                Style="{StaticResource DateTimeSelectorCardHorizontalStyle}" />

                            <Grid
                                Grid.Column="1"
                                Margin="10,0"
                                VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource FilterLabelStyle}"
                                    Text="晶圆 ID:" />
                                <TextBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Height="32"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding FilterWaferId, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Style="{StaticResource FilterLabelStyle}"
                                    Text="内部批次:" />
                                <TextBox
                                    Grid.Row="0"
                                    Grid.Column="4"
                                    Height="32"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding FilterInternalBatchId, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Style="{StaticResource FilterLabelStyle}"
                                    Text="产品型号:" />
                                <TextBox
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Height="32"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding FilterProductModel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="3"
                                    Style="{StaticResource FilterLabelStyle}"
                                    Text="比对结果:" />
                                <ComboBox
                                    Grid.Row="2"
                                    Grid.Column="4"
                                    Height="32"
                                    VerticalContentAlignment="Center"
                                    SelectedValue="{Binding FilterIsMatch}"
                                    SelectedValuePath="Tag">
                                    <ComboBoxItem Content="全部" Tag="{x:Null}" />
                                    <ComboBoxItem Content="完成 (OK)" Tag="True" />
                                    <ComboBoxItem Content="异常 (NG)" Tag="False" />
                                </ComboBox>
                            </Grid>

                            <StackPanel
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Vertical">
                                <Button
                                    Width="200"
                                    Height="32"
                                    Margin="10"
                                    Command="{Binding SearchCommand}"
                                    Content=" 🔍 查询数据"
                                    Style="{StaticResource ButtonPrimary}" />

                                <Button
                                    Width="200"
                                    Height="32"
                                    Margin="10"
                                    Command="{Binding ClearFiltersCommand}"
                                    Content=" 🗑️ 清空条件" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <DataGrid
                            AutoGenerateColumns="False"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="All"
                            HorizontalGridLinesBrush="#E0E0E0"
                            IsReadOnly="True"
                            ItemsSource="{Binding DataList}"
                            RowHeight="36"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding RecordTime, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}"
                                    Header="记录时间" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.InternalBatchId}"
                                    Header="内部批次号" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.CustomerBatch}"
                                    Header="客户批次" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.WaferId}"
                                    Header="晶圆ID" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.ProductModel}"
                                    Header="产品型号" />

                                <DataGridTemplateColumn Width="90" Header="匹配结果">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="10,4"
                                                HorizontalAlignment="Stretch"
                                                CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Data.IsMatch}" Value="False">
                                                                <Setter Property="Background" Value="#FFEBEE" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="OK" />
                                                            <Setter Property="Foreground" Value="#2E7D32" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Data.IsMatch}" Value="False">
                                                                    <Setter Property="Text" Value="NG" />
                                                                    <Setter Property="Foreground" Value="#C62828" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Width="150"
                                    Binding="{Binding Data.ErrorMessage}"
                                    Header="异常信息">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Margin" Value="5,0" />
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Data.IsMatch}" Value="False">
                                                    <Setter Property="Foreground" Value="Red" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.OcrText}"
                                    Header="OCR文本" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.Barcode1}"
                                    Header="条码1" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.Barcode2}"
                                    Header="条码2" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.Barcode3}"
                                    Header="条码3" />
                                <DataGridTextColumn
                                    Width="auto"
                                    Binding="{Binding Data.OperatorId}"
                                    Header="操作员工号" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Data.RecipeName}"
                                    Header="配方名称" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Background="#66FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <pf:LoadingCircle Width="50" Height="50" />
                                <TextBlock
                                    Margin="0,15,0,0"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    FontWeight="SemiBold"
                                    Foreground="#333"
                                    Text="正在查询生产数据..." />
                            </StackPanel>
                        </Grid>
                    </Grid>

                </Grid>

                <pf:Card.Footer>
                    <Grid Margin="10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <pf:Pagination
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            IsJumpEnabled="True"
                            MaxPageCount="{Binding MaxPageCount}"
                            PageIndex="{Binding PageIndex}">
                            <pf:Interaction.Triggers>
                                <pf:EventTrigger EventName="PageUpdated">
                                    <pf:EventToCommand Command="{Binding PageUpdatedCmd}" PassEventArgsToCommand="True" />
                                </pf:EventTrigger>
                            </pf:Interaction.Triggers>
                        </pf:Pagination>

                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="每页显示：" />
                            <ComboBox
                                Width="70"
                                Height="30"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                SelectedValue="{Binding PageSize}">
                                <sys:Int32>10</sys:Int32>
                                <sys:Int32>20</sys:Int32>
                                <sys:Int32>50</sys:Int32>
                                <sys:Int32>100</sys:Int32>
                            </ComboBox>
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="条" />
                        </StackPanel>
                    </Grid>
                </pf:Card.Footer>
            </pf:Card>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>