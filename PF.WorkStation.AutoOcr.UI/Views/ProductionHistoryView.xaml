<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.ProductionHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style
            x:Key="FilterLabelStyle"
            BasedOn="{StaticResource TextBlockBaseStyle}"
            TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,20,0" />
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox
            Grid.Row="0"
            pf:TitleElement.TitlePlacement="Left"
            BorderThickness="1">
            <GroupBox.Header>
                <TextBlock
                    Width="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="数据筛选"
                    TextWrapping="WrapWithOverflow">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </GroupBox.Header>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <pf:DateTimeSelector
                    Margin="10"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CheckBoxHeight="30"
                    EndTime="{Binding EndTime}"
                    ShowCheckBox="False"
                    StartTime="{Binding StartTime}" />


                <UniformGrid
                    Grid.Column="1"
                    Margin="10"
                    Columns="4">
                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="晶圆 ID:" />
                    <TextBox Height="30" Text="{Binding FilterWaferId, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="内部批次:" />
                    <TextBox Height="30" Text="{Binding FilterInternalBatchId, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="产品型号:" />
                    <TextBox Height="30" Text="{Binding FilterProductModel, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="比对结果:" />
                    <ComboBox
                        Height="30"
                        Margin="0,0,15,0"
                        HorizontalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        SelectedValue="{Binding FilterIsMatch}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem Content="全部" Tag="{x:Null}" />
                        <ComboBoxItem Content="完成 (OK)" Tag="True" />
                        <ComboBoxItem Content="异常 (NG)" Tag="False" />
                    </ComboBox>
                </UniformGrid>



                <UniformGrid
                    Grid.Column="2"
                    Margin="10"
                    Columns="1">
                    <Button
                        HorizontalAlignment="Stretch"
                        pf:IconElement.Geometry="{StaticResource SearchGeometry}"
                        Command="{Binding SearchCommand}"
                        Content="  查询"
                        Foreground="White" />
                    <Button
                        HorizontalAlignment="Stretch"
                        pf:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                        Command="{Binding ClearFiltersCommand}"
                        Content="清空条件" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="Blue"
                        Text="正在处理中...">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </UniformGrid>


            </Grid>


        </GroupBox>

        <DataGrid
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            HeadersVisibility="All"
            IsReadOnly="True"
            ItemsSource="{Binding Records}"
            RowHeight="30"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding RecordTime, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}"
                    Header="记录时间" />

                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Data.InternalBatchId}"
                    Header="内部批次号" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Data.CustomerBatch}"
                    Header="客户批次" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Data.WaferId}"
                    Header="晶圆ID" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Data.ProductModel}"
                    Header="产品型号" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Data.OcrText}"
                    Header="OCR文本" />

                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Data.IsMatch}"
                    Header="是否匹配" />

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding Data.ErrorMessage}"
                    Header="异常信息">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Data.IsMatch}" Value="False">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Data.Barcode1}"
                    Header="条码1" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Data.Barcode2}"
                    Header="条码2" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Data.Barcode3}"
                    Header="条码3" />

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Data.OperatorId}"
                    Header="操作员工号" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Data.RecipeName}"
                    Header="配方名称" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>