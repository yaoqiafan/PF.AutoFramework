<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.OcrRecipeManageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:StringListToStringConverter x:Key="StringListToStringConverter" />
    </UserControl.Resources>
    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65*" />
                <ColumnDefinition Width="30*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="10"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.H2.Title}"
                            FontWeight="Bold"
                            Text="OCR 程式列表" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button
                                MinHeight="32"
                                Margin="0,0,10,0"
                                Padding="15,0"
                                Command="{Binding LoadRecipesCommand}"
                                Content="刷新列表" />
                            <Button
                                MinHeight="32"
                                Margin="0,0,10,0"
                                Padding="15,0"
                                Command="{Binding NewRecipeCommand}"
                                Content="新建程式" />
                            <Button
                                MinHeight="32"
                                Padding="15,0"
                                Background="#E53E3E"
                                BorderThickness="0"
                                Command="{Binding DeleteRecipeCommand}"
                                Content="删除选中"
                                Foreground="White" />
                        </StackPanel>
                    </Grid>

                    <DataGrid
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        ColumnWidth="*"
                        GridLinesVisibility="Horizontal"
                        IsReadOnly="False"
                        ItemsSource="{Binding Parameters}"
                        SelectedItem="{Binding SelectedParameter}"
                        SelectionMode="Single">

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="auto" Header="程式名称">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding RecipeName, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="晶圆尺寸">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding WafeSize, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="关联相机程式">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding OCRRecipeName, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="条码个数">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding CodeCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="工位1 X,Y,Z (mm)">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding PosXYZ_1, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="工位2 X,Y,Z (mm)">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding PosXYZ_2, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="客批比对起始">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding GuestStartIndex, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="客批比对长度">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding GuestLength, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="OCR标签已张贴">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding IsOCRCodePate, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="auto" Header="关联程式名称">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            Text="{Binding AssociateProduct, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource StringListToStringConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Margin="15,0,15,0"
                Padding="10"
                Background="{DynamicResource SecondaryRegionColorBrush}"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        FontSize="{DynamicResource FontSize.H2.Title}"
                        FontWeight="Bold"
                        Text="程式参数设定" />

                    <pf:PropertyGrid Grid.Row="1" SelectedObject="{Binding SelectedParameter}" Margin="0,5,0,5" />

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                        <Button
                            MinHeight="35"
                            Margin="25,0,0,0"
                            Padding="25,0"
                            Command="{Binding ChangeRecipeNameCommand}"
                            Content="更改程式名称" />

                        <Button
                            MinHeight="35"
                            Margin="25,0,0,0"
                            Padding="25,0"
                            Command="{Binding UPLoadRecipeCommand}"
                            Content="程式上传" />


                    </StackPanel>



                    <StackPanel
                        Grid.Row="2"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button Style="{DynamicResource ButtonPrimary}" 
                                pf:IconElement.Geometry="{StaticResource DebugIcon}"
                                pf:IconElement.Height="20"
                                 pf:IconElement.Width="20"
                                
                            MinHeight="35"
                            Padding="10,0"
                            Command="{Binding ShowDebugViewCommand}"
                            Content="调试当前程式" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">



                        <Button
                            MinHeight="35"
                            Margin="25,0,0,0"
                            Padding="25,0"
                            Command="{Binding CloneRecipeCommand}"
                            Content="复制程式" />


                        <Button
                            MinHeight="35"
                            Margin="25,0,0,0"
                            Padding="25,0"
                            Command="{Binding SaveRecipeCommand}"
                            Content="保存更改" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>