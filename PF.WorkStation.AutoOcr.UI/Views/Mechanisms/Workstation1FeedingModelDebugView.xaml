<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.Mechanisms.Workstation1FeedingModelDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views.Mechanisms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#2C3E50"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="当前模组：" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding FeedingModule.MechanismName}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="已初始化 (IsInitialized)：" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#00E676"
                        Text="{Binding FeedingModule.IsInitialized}" />

                    <TextBlock
                        Margin="15,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text=" | 报警状态 (HasAlarm)：" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{Binding FeedingModule.HasAlarm}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#00E676" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FeedingModule.HasAlarm}" Value="True">
                                        <Setter Property="Foreground" Value="#E74C3C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="0,0,20,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="最后反馈：" />
                    <TextBlock
                        MaxWidth="300"
                        Margin="5,0,0,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#F1C40F"
                        Text="{Binding DebugMessage}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#3498DB"
                        BorderThickness="0"
                        Command="{Binding InitializeModuleCommand}"
                        Content=" 🔄 初始化 (Init) "
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#F39C12"
                        BorderThickness="0"
                        Command="{Binding ResetModuleCommand}"
                        Content=" ⚠️ 报警复位 (Reset) "
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Padding="15,0"
                        Background="#E74C3C"
                        BorderThickness="0"
                        Command="{Binding StopCommand}"
                        Content=" ⏹ 模组停止 (Stop) "
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">

            <TabItem FontSize="14" Header="模组运行调试">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Header="模组原子指令区">
                        <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text="基础初始化" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Command="{Binding InitStateCommand}"
                                    Content="1. 初始化上料状态 (安全复位)" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,15"
                                    Command="{Binding DetectSizeCommand}"
                                    Content="2. 识别料盒尺寸 (GetWaferBoxSize)" />

                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text="生产配方操作" />
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        Grid.Column="0"
                                        Height="35"
                                        Command="{Binding SwitchProductionCommand}"
                                        CommandParameter="8"
                                        Content="切换至 8寸 状态" />
                                    <Button
                                        Grid.Column="2"
                                        Height="35"
                                        Command="{Binding SwitchProductionCommand}"
                                        CommandParameter="12"
                                        Content="切换至 12寸 状态" />
                                </Grid>

                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text="安全互锁验证" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Command="{Binding CanMoveZCommand}"
                                    Content="验证: Z轴是否具备运动条件" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Command="{Binding CanMoveXCommand}"
                                    Content="验证: X轴是否具备运动条件" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,15"
                                    Command="{Binding CanPullOutCommand}"
                                    Content="验证: 是否具备拉出物料条件" />

                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text="核心业务流测试" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Command="{Binding SearchLayerCommand}"
                                    Content="执行: Z轴扫描寻层 (SearchLayer)" />

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="目标层数:" />
                                    <TextBox
                                        Grid.Column="1"
                                        Height="35"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding TargetLayer, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="2"
                                        Width="110"
                                        Height="35"
                                        Margin="10,0,0,0"
                                        Command="{Binding GoToLayerCommand}"
                                        Content="执行: 切换层" />
                                </Grid>

                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Command="{Binding WaitPullOutCommand}"
                                    Content="阻塞等待: 物料拉出完成" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Command="{Binding WaitReturnCommand}"
                                    Content="阻塞等待: 物料回退完成" />
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>

                    <GroupBox
                        Grid.Column="2"
                        FontSize="16"
                        FontWeight="Bold"
                        Header="硬件状态实时监控">
                        <StackPanel Margin="15">

                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    Padding="15"
                                    BorderBrush="#D5DBDB"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Text="Z轴 坐标 :" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding ZAxisHasAlarm}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Green" />
                                                        <Setter Property="Text" Value="[正常]" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ZAxisHasAlarm}" Value="True">
                                                                <Setter Property="Foreground" Value="Red" />
                                                                <Setter Property="Text" Value="[报警]" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="36"
                                            FontWeight="Bold"
                                            Foreground="#2980B9"
                                            Text="{Binding ZAxisPosition, StringFormat={}{0:F0} um}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="15"
                                    BorderBrush="#D5DBDB"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Text="X轴 坐标 :" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding XAxisHasAlarm}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Green" />
                                                        <Setter Property="Text" Value="[正常]" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding XAxisHasAlarm}" Value="True">
                                                                <Setter Property="Foreground" Value="Red" />
                                                                <Setter Property="Text" Value="[报警]" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="36"
                                            FontWeight="Bold"
                                            Foreground="#2980B9"
                                            Text="{Binding XAxisPosition, StringFormat={}{0:F0} um}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock
                                Margin="0,0,0,10"
                                Foreground="Gray"
                                Text="关键 IO 状态" />
                            <Border
                                Padding="20"
                                BorderBrush="#D5DBDB"
                                BorderThickness="1"
                                CornerRadius="5">
                                <StackPanel>
                                    <StackPanel.Resources>
                                        <Style x:Key="IoLightBaseStyle" TargetType="Ellipse">
                                            <Setter Property="Width" Value="24" />
                                            <Setter Property="Height" Value="24" />
                                            <Setter Property="Fill" Value="#E5E7E9" />
                                            <Setter Property="Stroke" Value="#BDC3C7" />
                                            <Setter Property="StrokeThickness" Value="1" />
                                        </Style>
                                    </StackPanel.Resources>

                                    <WrapPanel ItemHeight="40" ItemWidth="220">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse>
                                                <Ellipse.Style>
                                                    <Style BasedOn="{StaticResource IoLightBaseStyle}" TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBoxCommonInPlace}" Value="True">
                                                                <Setter Property="Fill" Value="#2ECC71" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                Text="料盒公用到位" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse>
                                                <Ellipse.Style>
                                                    <Style BasedOn="{StaticResource IoLightBaseStyle}" TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Is8InchInPlace}" Value="True">
                                                                <Setter Property="Fill" Value="#2ECC71" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                Text="8寸专属到位" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse>
                                                <Ellipse.Style>
                                                    <Style BasedOn="{StaticResource IoLightBaseStyle}" TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Is12InchInPlace}" Value="True">
                                                                <Setter Property="Fill" Value="#2ECC71" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                Text="12寸专属到位" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse>
                                                <Ellipse.Style>
                                                    <Style BasedOn="{StaticResource IoLightBaseStyle}" TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGripperOpen}" Value="True">
                                                                <Setter Property="Fill" Value="#2ECC71" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                Text="晶圆夹爪已张开" />
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="点位与阵列管理">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            Header="Z轴 原始基准点位 (可编辑)">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGrid
                                    Margin="0,0,0,5"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    ItemsSource="{Binding ZAxisOriginalPoints}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="1.5*"
                                            Binding="{Binding Name}"
                                            Header="点位名称"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                            Header="目标坐标(um)" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                                            Header="速度" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button
                                    Grid.Row="1"
                                    Height="30"
                                    Margin="0,5,0,0"
                                    Command="{Binding SaveZAxisPointsCommand}"
                                    Content="保存 Z轴 点位至底层" />
                            </Grid>
                        </GroupBox>

                        <GroupBox
                            Grid.Column="1"
                            Margin="5,0,0,5"
                            Header="X轴 原始基准点位 (可编辑)">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGrid
                                    Margin="0,0,0,5"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    ItemsSource="{Binding XAxisOriginalPoints}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="1.5*"
                                            Binding="{Binding Name}"
                                            Header="点位名称"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                            Header="目标坐标(um)" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                                            Header="速度" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button
                                    Grid.Row="1"
                                    Height="30"
                                    Margin="0,5,0,0"
                                    Command="{Binding SaveXAxisPointsCommand}"
                                    Content="保存 X轴 点位至底层" />
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox
                            Grid.Column="0"
                            Margin="0,0,5,0"
                            Header="1. 理论阵列坐标 (参考)">
                            <DataGrid
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                ItemsSource="{Binding ArrayedPoints}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Name}"
                                        Header="层名称" />
                                    <DataGridTextColumn
                                        Width="1.2*"
                                        Binding="{Binding TargetPosition, StringFormat={}{0:F0}}"
                                        Header="理论Z(um)" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox
                            Grid.Column="1"
                            Margin="5,0,5,0"
                            Header="2. 传感器1 原始数据">
                            <DataGrid
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                ItemsSource="{Binding RawMappingPoints1}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Index}"
                                        Header="序号" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding ZPosition, StringFormat={}{0:F0}}"
                                        Header="触发Z坐标(um)" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox
                            Grid.Column="2"
                            Margin="5,0,5,0"
                            Header="3. 传感器2 原始数据">
                            <DataGrid
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                ItemsSource="{Binding RawMappingPoints2}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Index}"
                                        Header="序号" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding ZPosition, StringFormat={}{0:F0}}"
                                        Header="触发Z坐标(um)" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox
                            Grid.Column="3"
                            Margin="5,0,0,0"
                            Header="4. 算法过滤数据 (防呆后)">
                            <DataGrid
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                ItemsSource="{Binding FilteredMappingPoints}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding LayerIndex}"
                                        Header="真实层号" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding ActualZ, StringFormat={}{0:F0}}"
                                        Header="带补偿中心Z(um)" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>