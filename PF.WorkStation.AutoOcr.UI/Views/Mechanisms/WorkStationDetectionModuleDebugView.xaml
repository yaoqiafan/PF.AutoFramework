<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.Mechanisms.WorkStationDetectionModuleDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views.Mechanisms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="1000"
    d:DesignWidth="1100"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#2C3E50"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=" auto" />
                    <ColumnDefinition Width=" auto" />
                    <ColumnDefinition Width=" *" />
                    <ColumnDefinition Width=" auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize=" 14"
                        Foreground=" #AAB7B8"
                        Text=" 当前模组 ：" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize=" 18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding DetectionModule.MechanismName}" />
                </StackPanel>


                <StackPanel
                    Grid.Column=" 1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize=" 14"
                        Foreground=" #aab7b8"
                        Text="已初始化（IsInitial):" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize=" 16"
                        FontWeight="Bold"
                        Foreground="#00e676"
                        Text="{Binding DetectionModule.IsInitialized}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize=" 14"
                        Foreground=" #aab7b8"
                        Text=" | 报警状态（HasAlarm):" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize=" 16"
                        FontWeight="Bold"
                        Text="{Binding DetectionModule.HasAlarm}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#00E676" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DetectionModule.HasAlarm}" Value="True">
                                        <Setter Property="Foreground" Value="#E74C3C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

                    </TextBlock>
                </StackPanel>


                <StackPanel
                    Grid.Column="2"
                    Margin="0,0,20,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="最后反馈：" />
                    <TextBlock
                        MaxWidth="300"
                        Margin="5,0,0,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#F1C40F"
                        Text="{Binding DebugMessage}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>


                <StackPanel
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#3498DB"
                        BorderThickness="0"
                        Command="{Binding InitializeModuleCommand}"
                        Content=" 🔄 初始化 (Init) "
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#F39C12"
                        BorderThickness="0"
                        Command="{Binding ResetModuleCommand}"
                        Content=" ⚠️ 报警复位 (Reset) "
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Padding="15,0"
                        Background="#E74C3C"
                        BorderThickness="0"
                        Command="{Binding StopCommand}"
                        Content=" ⏹ 模组停止 (Stop) "
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>


            </Grid>

        </Border>




        <TabControl Grid.Row=" 1">
            <TabItem FontSize="14" Header="模组运行调试">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox
                        Grid.Column=" 0"
                        FontSize=" 16 "
                        FontWeight="Bold"
                        Header=" 模组原子指令区">
                        <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text=" 基础初始化" />
                                <Button
                                    Height=" 35"
                                    Margin="0,0,0,5"
                                    Command="{Binding InitializeModuleCommand}"
                                    Content=" 模组初始化" />

                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text=" 动作流程" />
                                <Button
                                    Height=" 35"
                                    Margin="0,0,0,5"
                                    Command="{Binding MoveInitialCommand}"
                                    Content=" 移到到初始位置" />
                                <Button
                                    Height=" 35"
                                    Margin="0,0,0,5"
                                    Command="{Binding MoveStation1Command}"
                                    Content=" 移动到工位1检测位" />
                                <Button
                                    Height=" 35"
                                    Margin="0,0,0,5"
                                    Command="{Binding MoveStation2Command}"
                                    Content=" 移动到工位2检测位" />

                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text=" 相机" />
                                <Button
                                    Height=" 35"
                                    Margin="0,0,0,5"
                                    Command="{Binding CamTiggerCommand}"
                                    Content=" OCR相机触发" />
                                <Grid Margin="0,20,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width=" auto" />
                                        <ColumnDefinition Width=" *" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text=" 相机结果:" />
                                    <TextBlock
                                        Grid.Column=" 1"
                                        Margin="20,0,0,5"
                                        Text="{Binding CamRec}" />
                                </Grid>

                            </StackPanel>





                        </ScrollViewer>
                    </GroupBox>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="3*" />
                        </Grid.RowDefinitions>
                        <GroupBox
                            Grid.Row=" 0"
                            FontSize=" 16 "
                            FontWeight="Bold"
                            Header=" 模组状态监控区">
                            <StackPanel Margin="15">
                                <TextBlock
                                    Margin="0,0,0,10"
                                    Foreground="Gray"
                                    Text=" 机械轴实时坐标" />
                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width=" *" />
                                        <ColumnDefinition Width=" *" />
                                        <ColumnDefinition Width=" *" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column=" 0"
                                        Margin="0,0,10,0"
                                        Padding="15"
                                        BorderBrush=" #d5dbdb"
                                        BorderThickness="1"
                                        CornerRadius=" 5">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">

                                                <TextBlock
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Text="X轴 坐标 :" />
                                                <TextBlock Margin="10,0,0,0" Text="{Binding XAxisHasAlarm}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Green" />
                                                            <Setter Property="Text" Value="[正常]" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding XAxisHasAlarm}" Value="True">
                                                                    <Setter Property="Foreground" Value="Red" />
                                                                    <Setter Property="Text" Value="[报警]" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="36"
                                                FontWeight="Bold"
                                                Foreground="#2980B9"
                                                Text="{Binding XAxisPosition, StringFormat={}{0:F3} mm}" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column=" 1"
                                        Margin="0,0,10,0"
                                        Padding="15"
                                        BorderBrush=" #d5dbdb"
                                        BorderThickness="1"
                                        CornerRadius=" 5">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">

                                                <TextBlock
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Text="Y轴 坐标 :" />
                                                <TextBlock Margin="10,0,0,0" Text="{Binding YAxisHasAlarm}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Green" />
                                                            <Setter Property="Text" Value="[正常]" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding YAxisHasAlarm}" Value="True">
                                                                    <Setter Property="Foreground" Value="Red" />
                                                                    <Setter Property="Text" Value="[报警]" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="36"
                                                FontWeight="Bold"
                                                Foreground="#2980B9"
                                                Text="{Binding YAxisPosition, StringFormat={}{0:F3} mm}" />
                                        </StackPanel>
                                    </Border>


                                    <Border
                                        Grid.Column=" 2"
                                        Margin="0,0,10,0"
                                        Padding="15"
                                        BorderBrush=" #d5dbdb"
                                        BorderThickness="1"
                                        CornerRadius=" 5">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">

                                                <TextBlock
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Text="Z轴 坐标 :" />
                                                <TextBlock Margin="10,0,0,0" Text="{Binding XAxisHasAlarm}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Green" />
                                                            <Setter Property="Text" Value="[正常]" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ZAxisHasAlarm}" Value="True">
                                                                    <Setter Property="Foreground" Value="Red" />
                                                                    <Setter Property="Text" Value="[报警]" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="36"
                                                FontWeight="Bold"
                                                Foreground="#2980B9"
                                                Text="{Binding ZAxisPosition, StringFormat={}{0:F3} mm}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                            </StackPanel>
                        </GroupBox>


                        <GroupBox
                            Grid.Row=" 1"
                            pf:TitleElement.TitlePlacement="Left"
                            FontSize=" 16"
                            FontWeight="Bold"
                            Header=" 点位管理">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <GroupBox
                                    Grid.Row=" 0"
                                    Margin="0,0,0,5"
                                    pf:TitleElement.TitlePlacement="Left"
                                    Header=" X轴 原始基准点位">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width=" *" />
                                            <ColumnDefinition Width=" auto" />
                                        </Grid.ColumnDefinitions>
                                        <DataGrid
                                            Margin="0,0,0,5"
                                            AutoGenerateColumns="False"
                                            CanUserAddRows="False"
                                            ItemsSource="{Binding XAxisOriginalPoints}"
                                            Style="{StaticResource DataGrid.Small}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn
                                                    Width="1.5*"
                                                    Binding="{Binding Name}"
                                                    Header="点位名称"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="*"
                                                    Binding="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                                    Header="目标位置(mm)" />
                                                <DataGridTextColumn
                                                    Width="*"
                                                    Binding="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                                                    Header="速度" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Button
                                            Grid.Column=" 1"
                                            Margin="3"
                                            Command="{Binding SaveXAxisPointsCommand}"
                                            Content=" 点位保存" />



                                    </Grid>
                                </GroupBox>
                                <GroupBox
                                    Grid.Row=" 1"
                                    Margin="0,0,0,5"
                                    pf:TitleElement.TitlePlacement="Left"
                                    Header=" Y轴 原始基准点位">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width=" *" />
                                            <ColumnDefinition Width=" auto" />
                                        </Grid.ColumnDefinitions>
                                        <DataGrid
                                            Margin="0,0,0,5"
                                            AutoGenerateColumns="False"
                                            CanUserAddRows="False"
                                            ItemsSource="{Binding YAxisOriginalPoints}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn
                                                    Width="1.5*"
                                                    Binding="{Binding Name}"
                                                    Header="点位名称"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="*"
                                                    Binding="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                                    Header="目标位置(mm)" />
                                                <DataGridTextColumn
                                                    Width="*"
                                                    Binding="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                                                    Header="速度" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Button
                                            Grid.Column=" 1"
                                            Height=" 30"
                                            Margin="0,0,0,5"
                                            Command="{Binding SaveYAxisPointsCommand}"
                                            Content=" 保存点位" />

                                    </Grid>
                                </GroupBox>


                                <GroupBox
                                    Grid.Row=" 2"
                                    Margin="0,0,0,5"
                                    pf:TitleElement.TitlePlacement="Left"
                                    Header=" Z轴 原始基准点位">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width=" *" />
                                            <ColumnDefinition Width=" auto" />
                                        </Grid.ColumnDefinitions>
                                        <DataGrid
                                            Margin="0,0,0,5"
                                            AutoGenerateColumns="False"
                                            CanUserAddRows="False"
                                            ItemsSource="{Binding ZAxisOriginalPoints}"
                                            Style="{StaticResource DataGrid.Small}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn
                                                    Width="1.5*"
                                                    Binding="{Binding Name}"
                                                    Header="点位名称"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn
                                                    Width="*"
                                                    Binding="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                                    Header="目标位置(mm)" />
                                                <DataGridTextColumn
                                                    Width="*"
                                                    Binding="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                                                    Header="速度" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Button
                                            Grid.Column=" 1"
                                            Height=" 30"
                                            Margin="0,0,0,5"
                                            Command="{Binding SaveZAxisPointsCommand}"
                                            Content=" 保存点位" />

                                    </Grid>
                                </GroupBox>


                            </Grid>
                        </GroupBox>



                    </Grid>



                </Grid>
            </TabItem>




        </TabControl>






    </Grid>
</UserControl>
