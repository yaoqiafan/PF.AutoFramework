<UserControl x:Class="PF.WorkStation.AutoOcr.UI.Views.Mechanisms.WorkStationDetectionModuleDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views.Mechanisms"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100">
    <Grid Margin=" 10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="6" Padding="15,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions >
                    <ColumnDefinition Width=" auto"/>
                    <ColumnDefinition Width=" auto"/>
                    <ColumnDefinition Width=" *"/>
                    <ColumnDefinition Width=" auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"  VerticalAlignment="Center" Margin=" 0,0,30,0">
                    <TextBlock Text=" 当前模组 ：" Foreground=" #AAB7B8" FontSize=" 14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DetectionModule.MechanismName }" Foreground="White" FontSize=" 18" FontWeight="Bold" Margin=" 5,0,0,0"/>
                </StackPanel>


                <StackPanel  Grid.Column=" 1" Orientation="Horizontal" VerticalAlignment="Center" >
                    <TextBlock Text="已初始化（IsInitial):" Foreground=" #aab7b8" FontSize=" 14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DetectionModule.IsInitial}" Foreground="#00e676" FontSize=" 16" Margin=" 5,0,0,0" FontWeight="Bold" />
                    <TextBlock Text=" | 报警状态（HasAlarm):" Foreground=" #aab7b8" FontSize=" 14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DetectionModule.HasAlarm}"  FontSize=" 16" Margin=" 5,0,0,0" FontWeight="Bold" >
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#00E676"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FeedingModule.HasAlarm}" Value="True">
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

                    </TextBlock>
                </StackPanel>


                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <TextBlock Text="最后反馈：" Foreground="#AAB7B8" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DebugMessage}" Foreground="#F1C40F" FontSize="14" FontWeight="Bold" Margin="5,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                </StackPanel>


                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content=" 🔄 初始化 (Init) " Command="{Binding InitializeModuleCommand}" Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14" Height="35" Margin="0,0,10,0" Padding="15,0" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content=" ⚠️ 报警复位 (Reset) " Command="{Binding ResetModuleCommand}" Background="#F39C12" Foreground="White" FontWeight="Bold" FontSize="14" Height="35" Margin="0,0,10,0" Padding="15,0" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content=" ⏹ 模组停止 (Stop) " Command="{Binding StopCommand}" Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="14" Height="35" Padding="15,0" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>


            </Grid>

        </Border>




        <TabControl Grid.Row=" 1">
            <TabItem FontSize="14" Header="模组运行调试">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column=" 0" FontSize=" 16 " FontWeight="Bold" Header=" 模组原子指令区">
                        <ScrollViewer Padding=" 5,10" VerticalScrollBarVisibility="Auto" >
                            <StackPanel >
                                <TextBlock Margin=" 0,0,0,5" Foreground="Gray" Text=" 基础初始化"/>
                                <Button  Height=" 35" Margin=" 0,0,0,5" Content=" 模组初始化"  />
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>



                    <GroupBox Grid.Column=" 2" FontSize=" 16 " FontWeight="Bold" Header=" 模组状态监控区">
                        <StackPanel Margin=" 15">
                            <TextBlock Margin=" 0,0,0,10" Foreground="Gray" Text=" 机械轴实时坐标"/>
                            <Grid Margin=" 0,0,0,25">
                                <Grid.ColumnDefinitions >
                                    <ColumnDefinition Width=" *"/>
                                    <ColumnDefinition Width=" *"/>
                                    <ColumnDefinition Width=" *"/>
                                </Grid.ColumnDefinitions>

                                <Border  Grid.Column=" 0" Margin=" 0,0,10,0" Padding=" 15" BorderBrush=" #d5dbdb" BorderThickness=" 1" CornerRadius=" 5">
                                    <StackPanel >
                                        <StackPanel Margin=" 0,0,0,10" Orientation="Horizontal" >

                                            <TextBlock FontSize="16" FontWeight="Bold" Text="X轴 坐标 :" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding XAxisHasAlarm}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Green" />
                                                        <Setter Property="Text" Value="[正常]" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding XAxisHasAlarm}" Value="True">
                                                                <Setter Property="Foreground" Value="Red" />
                                                                <Setter Property="Text" Value="[报警]" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right" FontSize="36" FontWeight="Bold" Foreground="#2980B9" Text="{Binding XAxisPosition, StringFormat={}{0:F3} mm}" />
                                    </StackPanel>
                                </Border>

                                <Border  Grid.Column=" 1" Margin=" 0,0,10,0" Padding=" 15" BorderBrush=" #d5dbdb" BorderThickness=" 1" CornerRadius=" 5">
                                    <StackPanel >
                                        <StackPanel Margin=" 0,0,0,10" Orientation="Horizontal" >

                                            <TextBlock FontSize="16" FontWeight="Bold" Text="Y轴 坐标 :" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding YAxisHasAlarm}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Green" />
                                                        <Setter Property="Text" Value="[正常]" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding YAxisHasAlarm}" Value="True">
                                                                <Setter Property="Foreground" Value="Red" />
                                                                <Setter Property="Text" Value="[报警]" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right" FontSize="36" FontWeight="Bold" Foreground="#2980B9" Text="{Binding YAxisPosition, StringFormat={}{0:F3} mm}" />
                                    </StackPanel>
                                </Border>


                                <Border  Grid.Column=" 2" Margin=" 0,0,10,0" Padding=" 15" BorderBrush=" #d5dbdb" BorderThickness=" 1" CornerRadius=" 5">
                                    <StackPanel >
                                        <StackPanel Margin=" 0,0,0,10" Orientation="Horizontal" >

                                            <TextBlock FontSize="16" FontWeight="Bold" Text="Z轴 坐标 :" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding XAxisHasAlarm}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Green" />
                                                        <Setter Property="Text" Value="[正常]" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ZAxisHasAlarm}" Value="True">
                                                                <Setter Property="Foreground" Value="Red" />
                                                                <Setter Property="Text" Value="[报警]" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right" FontSize="36" FontWeight="Bold" Foreground="#2980B9" Text="{Binding ZAxisPosition, StringFormat={}{0:F3} mm}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                           
                        </StackPanel>
                    </GroupBox>

                </Grid>
            </TabItem>



            <TabItem Header=" 点位管理">

            </TabItem>
        </TabControl>






    </Grid>
</UserControl>
