<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.Mechanisms.WorkStationDataModuleDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views.Mechanisms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="1100"
    d:DesignWidth="1100"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部状态栏  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#2C3E50"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  当前模组  -->
                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="当前模组：" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding DataModule.MechanismName}" />
                </StackPanel>

                <!--  初始化 / 报警状态  -->
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="已初始化 (IsInitial):" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#00E676"
                        Text="{Binding DataModule.IsInitialized}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text=" | 报警状态 (HasAlarm):" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{Binding DataModule.HasAlarm}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#00E676" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataModule.HasAlarm}" Value="True">
                                        <Setter Property="Foreground" Value="#E74C3C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="0,0,20,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="最后反馈：" />
                    <TextBlock
                        MaxWidth="300"
                        Margin="5,0,0,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#F1C40F"
                        Text="{Binding DebugMessage}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#3498DB"
                        BorderThickness="0"
                        Command="{Binding InitializeModuleCommand}"
                        Content="🔄 初始化 (Init)"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#F39C12"
                        BorderThickness="0"
                        Command="{Binding ResetModuleCommand}"
                        Content="⚠ 报警复位 (Reset)"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Padding="15,0"
                        Background="#E74C3C"
                        BorderThickness="0"
                        Command="{Binding StopCommand}"
                        Content="⏹ 模组停止 (Stop)"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
