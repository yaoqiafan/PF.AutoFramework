<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.Mechanisms.WorkStationDataModuleDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.WorkStation.AutoOcr.UI.Views.Mechanisms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="1100"
    d:DesignWidth="1100"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部状态栏  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#2C3E50"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  当前模组  -->
                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="当前模组：" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding DataModule.MechanismName}" />
                </StackPanel>

                <!--  初始化 / 报警状态  -->
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="已初始化 (IsInitial):" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#00E676"
                        Text="{Binding DataModule.IsInitialized}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text=" | 报警状态 (HasAlarm):" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{Binding DataModule.HasAlarm}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#00E676" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataModule.HasAlarm}" Value="True">
                                        <Setter Property="Foreground" Value="#E74C3C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!--  最后反馈信息  -->
                <StackPanel
                    Grid.Column="2"
                    Margin="0,0,20,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAB7B8"
                        Text="最后反馈：" />
                    <TextBlock
                        MaxWidth="300"
                        Margin="5,0,0,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#F1C40F"
                        Text="{Binding DebugMessage}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!--  操作按钮  -->
                <StackPanel
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#3498DB"
                        BorderThickness="0"
                        Command="{Binding InitializeModuleCommand}"
                        Content="🔄 初始化 (Init)"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Background="#F39C12"
                        BorderThickness="0"
                        Command="{Binding ResetModuleCommand}"
                        Content="⚠ 报警复位 (Reset)"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button
                        Height="35"
                        Padding="15,0"
                        Background="#E74C3C"
                        BorderThickness="0"
                        Command="{Binding StopCommand}"
                        Content="⏹ 模组停止 (Stop)"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  主 Tab 区域  -->
        <TabControl Grid.Row="1">
            <TabItem FontSize="14" Header="模组运行调试">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  左侧：原子指令区  -->
                    <GroupBox
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Header="模组原子指令区">
                        <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,5"
                                    Foreground="Gray"
                                    Text="基础初始化" />
                                <Button
                                    Height="35"
                                    Margin="0,0,0,5"
                                    Content="模组初始化" />

                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontSize=" 16"
                                    FontWeight="Bold"
                                    Foreground="Gray"
                                    Text=" 测试操作" />
                                <Grid Margin="0,10,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width=" *" />
                                        <ColumnDefinition Width=" 15" />
                                        <ColumnDefinition Width=" *" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding Station1ChangeLotCommand}" Content=" 工位1切换物料" />
                                    <Button
                                        Grid.Column=" 2"
                                        Command="{Binding Station2ChangeLotCommand}"
                                        Content="工位2切换物料 " />
                                </Grid>

                                <Grid Margin="0,10,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width=" *" />
                                        <ColumnDefinition Width=" 15" />
                                        <ColumnDefinition Width=" *" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding AddStation1DetCommand}" Content=" 工位1添加检测数据" />
                                    <Button
                                        Grid.Column=" 2"
                                        Command="{Binding AddStation2DetCommand}"
                                        Content="工位2添加检测数据 " />
                                </Grid>


                            </StackPanel>




                        </ScrollViewer>
                    </GroupBox>

                    <!--  右侧：数据状态监控区  -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="3*" />
                        </Grid.RowDefinitions>

                        <GroupBox
                            Grid.Row="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Header="数据状态监控区" />
                        <!--  内部主 TabControl：MES / 机台检测 / 总数据  -->
                        <TabControl Grid.Row=" 1">
                            <!--  Tab1: MES 返回数据监控  -->
                            <TabItem FontSize="14" Header="MES 返回数据监控">
                                <Grid Margin="10">
                                    <TabControl>
                                        <!--  工位1 MES  -->
                                        <TabItem Header="工位1">
                                            <Grid Margin="5">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row=" 0" Orientation="Horizontal">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="#AAB7B8"
                                                        Text="内部批次号：" />
                                                    <TextBox
                                                        Width="250"
                                                        Margin="5,0,0,0"
                                                        IsReadOnly="True"
                                                        Text="{Binding Station1InternalBatches}" />
                                                </StackPanel>
                                                <StackPanel
                                                    Grid.Row="1"
                                                    Grid.Column=" 1"
                                                    Orientation="Horizontal">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize=" 14"
                                                        Foreground=" #aab7b8"
                                                        Text=" 配方名称：" />

                                                    <TextBox
                                                        Width="250"
                                                        Margin="15,0,0,0"
                                                        IsReadOnly="True"
                                                        Text="{Binding Station1RecipeName}" />
                                                </StackPanel>
                                                <ScrollViewer
                                                    Grid.Row=" 2"
                                                    Padding="5,10"
                                                    VerticalScrollBarVisibility="Auto">
                                                    <DataGrid
                                                        Grid.Row="2"
                                                        Margin="0,5,0,0"
                                                        AutoGenerateColumns="False"
                                                        CanUserAddRows="False"
                                                        ItemsSource="{Binding Station1MesDetection}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CustomerBatch}"
                                                                Header="客户批次" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding WaferID}"
                                                                Header="晶圆ID" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </ScrollViewer>

                                            </Grid>
                                        </TabItem>

                                        <!--  工位2 MES  -->
                                        <TabItem Header="工位2">
                                            <Grid Margin="5">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="#AAB7B8"
                                                        Text="内部批次号：" />
                                                    <TextBox
                                                        Width="250"
                                                        Margin="5,0,0,0"
                                                        IsReadOnly="True"
                                                        Text="{Binding Station2InternalBatches}" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize=" 14"
                                                        Foreground=" #aab7b8"
                                                        Text=" 配方名称：" />

                                                    <TextBox
                                                        Width="250"
                                                        Margin="15,0,0,0"
                                                        IsReadOnly="True"
                                                        Text="{Binding Station2RecipeName}" />
                                                </StackPanel>
                                                <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto" />
                                                <DataGrid
                                                    Grid.Row="2"
                                                    Margin="0,5,0,0"
                                                    AutoGenerateColumns="False"
                                                    CanUserAddRows="False"
                                                    ItemsSource="{Binding Station2MesDetection}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn
                                                            Width="*"
                                                            Binding="{Binding CustomerBatch}"
                                                            Header="客户批次" />
                                                        <DataGridTextColumn
                                                            Width="*"
                                                            Binding="{Binding WaferID}"
                                                            Header="晶圆ID" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                            </TabItem>

                            <!--  Tab2: 机台检测数据监控  -->
                            <TabItem FontSize="14" Header="机台检测数据监控">
                                <Grid Margin="10">
                                    <TabControl>
                                        <!--  工位1 检测数据  -->
                                        <TabItem Header="工位1">
                                            <Grid>
                                                <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                                                    <DataGrid
                                                        Margin="5"
                                                        AutoGenerateColumns="False"
                                                        CanUserAddRows="False"
                                                        ItemsSource="{Binding Station1MachineDetection}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding InternalBatches}"
                                                                Header="内部批次" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CustomerBatches}"
                                                                Header="客户批次" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding WaferID}"
                                                                Header="晶圆ID" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding OCRValue}"
                                                                Header="OCR值" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CodeValue1}"
                                                                Header="条码1" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CodeValue2}"
                                                                Header="条码2" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding OcrCodeValue}"
                                                                Header="OCR条码" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </ScrollViewer>
                                            </Grid>


                                        </TabItem>

                                        <!--  工位2 检测数据  -->
                                        <TabItem Header="工位2">
                                            <Grid>
                                                <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                                                    <DataGrid
                                                        Margin="5"
                                                        AutoGenerateColumns="False"
                                                        CanUserAddRows="False"
                                                        ItemsSource="{Binding Station2MachineDetection}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding InternalBatches}"
                                                                Header="内部批次" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CustomerBatches}"
                                                                Header="客户批次" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding WaferID}"
                                                                Header="晶圆ID" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding OCRValue}"
                                                                Header="OCR值" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CodeValue1}"
                                                                Header="条码1" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding CodeValue2}"
                                                                Header="条码2" />
                                                            <DataGridTextColumn
                                                                Width="*"
                                                                Binding="{Binding OcrCodeValue}"
                                                                Header="OCR条码" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </ScrollViewer>
                                            </Grid>


                                        </TabItem>
                                    </TabControl>
                                </Grid>
                            </TabItem>

                            <!--  Tab3: 检测总数据（汇总）  -->
                            <TabItem FontSize="14" Header="检测总数据">
                                <Grid Margin="10">
                                    <GroupBox
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Header="检测缓存数据 汇总">
                                        <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">

                                            <DataGrid
                                                Margin="5"
                                                AutoGenerateColumns="False"
                                                CanUserAddRows="False"
                                                ItemsSource="{Binding AllMachineDetection}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding InternalBatches}"
                                                        Header="内部批次" />
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding CustomerBatches}"
                                                        Header="客户批次" />
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding WaferID}"
                                                        Header="晶圆ID" />
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding OCRValue}"
                                                        Header="OCR值" />
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding CodeValue1}"
                                                        Header="条码1" />
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding CodeValue2}"
                                                        Header="条码2" />
                                                    <DataGridTextColumn
                                                        Width="*"
                                                        Binding="{Binding OcrCodeValue}"
                                                        Header="OCR条码" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </ScrollViewer>


                                    </GroupBox>
                                </Grid>
                            </TabItem>
                        </TabControl>

                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
