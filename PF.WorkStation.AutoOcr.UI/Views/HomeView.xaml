<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:usercontrol="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Standard}" />
        </Style>

        <!--  ButtonGroup 按钮模板：Tag 属性传入悬停字体颜色  -->
        <ControlTemplate x:Key="HoverButtonTemplate" TargetType="RadioButton">
            <Border
                x:Name="BorderRoot"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{Binding Path=(pf:BorderElement.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}">
                <ContentPresenter
                    x:Name="contentPresenter"
                    Margin="{TemplateBinding Padding}"
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                    RecognizesAccessKey="True"
                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>



            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <pf:Card
                    Grid.Column="0"
                    Margin="10"
                    FontSize="{DynamicResource FontSize.Body.Standard}">
                    <pf:Card.Header>
                        <TextBlock
                            Margin="10"
                            FontSize="{DynamicResource FontSize.H1.Large}"
                            FontWeight="Bold"
                            Text=" 工位1操作" />
                    </pf:Card.Header>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Margin="20,0,5,0"
                                Text="内批：" />
                            <TextBlock Grid.Column="1" Text="{Binding Station1InternalBatches}" />
                            <TextBlock
                                Grid.Column="2"
                                Margin="40,0,5,0"
                                Text="状态：" />
                            <TextBlock Grid.Column="3" Text="{Binding Station1DetStatus}" />
                            <TextBlock
                                Grid.Column="4"
                                Margin="40,0,5,0"
                                Text=" 程式名称:" />
                            <TextBlock Grid.Column="5" Text="{Binding Station1RecipeName}" />

                            <Button
                                Grid.Column="6"
                                Margin="0,0,50,0"
                                HorizontalAlignment="Right"
                                Command="{Binding Station1ChangeLotCommand}"
                                Content="切换批次"
                                FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>

                        <usercontrol:ZoomableImageViewer
                            Grid.Row="1"
                            Margin="5"
                            AnnotationContent="{Binding Station1CurrentMachineDetection}"
                            ErrorSource="{StaticResource DelateIcon_FFFFFF}"
                            Source="{Binding Station1CurrentMachineDetection.ImagePath}" />
                    </Grid>

                    <pf:Card.Footer>
                        <Grid Height="300">
                            <DataGrid
                                Margin="5"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                ItemsSource="{Binding Station1MachineDetection}"
                                SelectedItem="{Binding Station1CurrentMachineDetection}"
                                SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding CustomerBatch}"
                                        Header="客户批次"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding OcrText}"
                                        Header="OCR值"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Barcode1}"
                                        Header="条码"
                                        IsReadOnly="True" />
                                    <DataGridTemplateColumn Width="90" Header="匹配结果">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="10,4"
                                                    HorizontalAlignment="Stretch"
                                                    CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="OK" />
                                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                        <Setter Property="Text" Value="NG" />
                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </pf:Card.Footer>
                </pf:Card>

                <pf:Card
                    Grid.Column="1"
                    Margin="10"
                    FontSize="{DynamicResource FontSize.Body.Standard}">
                    <pf:Card.Header>
                        <TextBlock
                            Margin="10"
                            FontSize="{DynamicResource FontSize.H1.Large}"
                            FontWeight="Bold"
                            Text=" 工位2操作" />
                    </pf:Card.Header>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Margin="20,0,5,0"
                                Text="内批：" />
                            <TextBlock Grid.Column="1" Text="{Binding Station2InternalBatches}" />
                            <TextBlock
                                Grid.Column="2"
                                Margin="40,0,5,0"
                                Text="状态：" />
                            <TextBlock Grid.Column="3" Text="{Binding Station2DetStatus}" />
                            <TextBlock
                                Grid.Column="4"
                                Margin="40,0,5,0"
                                Text=" 程式名称:" />
                            <TextBlock Grid.Column="5" Text="{Binding Station2RecipeName}" />

                            <Button
                                Grid.Column="6"
                                Margin="0,0,50,0"
                                HorizontalAlignment="Right"
                                Command="{Binding Station2ChangeLotCommand}"
                                Content="切换批次"
                                FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                Style="{DynamicResource ButtonPrimary}" />
                        </Grid>

                        <usercontrol:ZoomableImageViewer
                            Grid.Row="1"
                            Margin="5"
                            AnnotationContent="{Binding Station2CurrentMachineDetection}"
                            ErrorSource="{StaticResource DelateIcon_FFFFFF}"
                            Source="{Binding Station2CurrentMachineDetection.ImagePath}" />
                    </Grid>

                    <pf:Card.Footer>
                        <Grid Height="300">
                            <DataGrid
                                Margin="5"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                ItemsSource="{Binding Station2MachineDetection}"
                                SelectedItem="{Binding Station2CurrentMachineDetection}"
                                SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding CustomerBatch}"
                                        Header="客户批次"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding OcrText}"
                                        Header="OCR值"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="2*"
                                        Binding="{Binding Barcode1}"
                                        Header="条码"
                                        IsReadOnly="True" />

                                    <DataGridTemplateColumn Width="90" Header="匹配结果">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="10,4"
                                                    HorizontalAlignment="Stretch"
                                                    CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="OK" />
                                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                        <Setter Property="Text" Value="NG" />
                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </pf:Card.Footer>
                </pf:Card>

                <Border
    Grid.Column="2"
     Margin="10"
    Padding="15"
    Background="{DynamicResource  DarkPrimaryBrush}"
    CornerRadius="5">

                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
                            <Ellipse
                Width="12"
                Height="12"
                Margin="0,0,8,0"
                Fill="{Binding StatusBrush}" />
                            <TextBlock
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{Binding StatusBrush}"
                Text="{Binding StatusText}" />
                        </StackPanel>

                        <Separator Grid.Row="1" Margin="0,5,0,15" Background="{DynamicResource BorderBrush}" Opacity="0.5"/>

                        <UniformGrid Grid.Row="2" Margin="0,0,0,15" HorizontalAlignment="Center">
                            <CheckBox 
                Content="清除机台记忆" 
                IsChecked="{Binding IsClearMemoryChecked}"
                IsEnabled="{Binding HasClearMemoryPermission}" 
                FontSize="14"
                FontWeight="Medium"
                Foreground="{DynamicResource PrimaryTextBrush}"
                ToolTip="需要管理员权限才能操作此选项" />
                        </UniformGrid>

                        <Separator Grid.Row="3" Margin="0,0,0,15" Background="{DynamicResource BorderBrush}" Opacity="0.5"/>

                        <Grid Grid.Row="4">

                            <pf:ButtonGroup Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Top"  >
                            <RadioButton
                MinHeight="80"
               
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{Binding InitializeCommand}"
                Content="💠 初始化"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Tag="{StaticResource InfoBrush}"
                Template="{StaticResource HoverButtonTemplate}" />

                            <RadioButton
                MinHeight="80"
              
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{Binding SmartStartCommand}"
                Content="{Binding SmartStartText}"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Tag="{StaticResource PrimaryBrush}"
                Template="{StaticResource HoverButtonTemplate}" />

                            <RadioButton
                MinHeight="80"
                
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{Binding PauseCommand}"
                Content="⏸ 暂停"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Tag="{StaticResource WarningBrush}"
                Template="{StaticResource HoverButtonTemplate}" />

                            <RadioButton
                MinHeight="80"
              
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{Binding ResetCommand}"
                Content="🔄️ 复位"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Tag="{DynamicResource SuccessBrush}"
                Template="{StaticResource HoverButtonTemplate}" />

                            <RadioButton
                MinHeight="80"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{Binding StopCommand}"
                Content="⏹ 停止"
                FontSize="{DynamicResource FontSize.H2.Title}"
                Tag="{StaticResource DangerBrush}"
                Template="{StaticResource HoverButtonTemplate}" />
                            </pf:ButtonGroup>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>