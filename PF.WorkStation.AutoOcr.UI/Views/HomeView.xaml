<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:PF.WorkStation.AutoOcr.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:usercontrol="clr-namespace:PF.WorkStation.AutoOcr.UI.UserControls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:WaferSlotStatusToColorConverter x:Key="SlotStatusConverter" />
        <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Standard}" />
        </Style>

        <!--  ButtonGroup 按钮模板：Tag 属性传入悬停字体颜色  -->
        <ControlTemplate x:Key="HoverButtonTemplate" TargetType="RadioButton">
            <Border
                x:Name="BorderRoot"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{Binding Path=(pf:BorderElement.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}">
                <ContentPresenter
                    x:Name="contentPresenter"
                    Margin="{TemplateBinding Padding}"
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                    RecognizesAccessKey="True"
                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  工位屏蔽参数变更后的重初始化提示横幅  -->
            <Border
                Grid.Row="0"
                Padding="12,8"
                Background="#FFF3CD"
                BorderBrush="#FFC107"
                BorderThickness="0,0,0,2"
                Visibility="{Binding NeedsReinitialize, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#856404"
                        Text="⚠  " />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#856404"
                        Text="工位屏蔽参数已修改，请重新初始化设备以使配置生效。" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10">
                    <pf:Card FontSize="{DynamicResource FontSize.Body.Standard}" IsEnabled="{Binding Station1IsEnabled}">
                        <pf:Card.Header>
                            <Grid Margin="10">
                                <TextBlock
                                    FontSize="{DynamicResource FontSize.H1.Large}"
                                    FontWeight="Bold"
                                    Text=" 工位1操作" />
                                <StackPanel
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Ellipse
                                        Width="10"
                                        Height="10"
                                        Margin="0,0,6,0"
                                        Fill="{Binding Door1StatusBrush}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{Binding Door1StatusBrush}"
                                        Text="{Binding Door1StatusText}" />
                                </StackPanel>
                            </Grid>
                        </pf:Card.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Margin="20,0,5,0"
                                    Text="内批：" />
                                <TextBlock Grid.Column="1" Text="{Binding Station1InternalBatches}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="40,0,5,0"
                                    Text="状态：" />
                                <TextBlock Grid.Column="3" Text="{Binding Station1DetStatus}" />
                                <TextBlock
                                    Grid.Column="4"
                                    Margin="40,0,5,0"
                                    Text=" 程式名称:" />
                                <TextBlock Grid.Column="5" Text="{Binding Station1RecipeName}" />

                                <Button
                                    Grid.Column="6"
                                    Margin="0,0,50,0"
                                    HorizontalAlignment="Right"
                                    Command="{Binding Station1ChangeLotCommand}"
                                    Content="切换批次"
                                    FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                    Style="{DynamicResource ButtonPrimary}" />
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>

                                <usercontrol:ZoomableImageViewer
                                    Grid.Column="0"
                                    Margin="5"
                                    AnnotationContent="{Binding Station1CurrentMachineDetection}"
                                    Source="{Binding Station1CurrentMachineDetection.ImagePath}" />

                                <!--  工位1晶圆盒槽位可视化：第1层在底部，第13层在顶部  -->
                                <Border
                                    Grid.Column="1"
                                    Margin="2,5,5,5"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <ItemsControl ItemsSource="{Binding Station1SlotStatesDisplay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1" Rows="13" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="2,1"
                                                    Background="{Binding Status, Converter={StaticResource SlotStatusConverter}}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2"
                                                    ToolTip="{Binding DisplayIndex, StringFormat=第 {0} 层}">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="8"
                                                        Foreground="#555555"
                                                        Text="{Binding DisplayIndex}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                        </Grid>

                        <pf:Card.Footer>
                            <Grid Height="300">
                                <DataGrid
                                    Margin="5"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    ItemsSource="{Binding Station1MachineDetection}"
                                    SelectedItem="{Binding Station1CurrentMachineDetection}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="2*"
                                            Binding="{Binding CustomerBatch}"
                                            Header="客户批次"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="2*"
                                            Binding="{Binding OcrText}"
                                            Header="OCR值"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="2*"
                                            Binding="{Binding Barcode1}"
                                            Header="条码"
                                            IsReadOnly="True" />
                                        <DataGridTemplateColumn Width="90" Header="匹配结果">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="10,4"
                                                        HorizontalAlignment="Stretch"
                                                        CornerRadius="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="OK" />
                                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                            <Setter Property="Text" Value="NG" />
                                                                            <Setter Property="Foreground" Value="#C62828" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </pf:Card.Footer>
                    </pf:Card>

                    <!--  工位1下料确认遮罩层  -->
                    <Border Background="#CC1A1A2E" Visibility="{Binding Station1UnloadMaskVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="物料已生产完毕，请下料后确认"
                                TextAlignment="Center" />
                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="#B0B0C0"
                                Text="确认前请勿操作设备"
                                TextAlignment="Center" />
                            <Button
                                Width="160"
                                Height="44"
                                Margin="0,28,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding Station1UnloadConfirmCommand}"
                                Content="确 认 下 料"
                                FontSize="16"
                                FontWeight="Bold"
                                Style="{DynamicResource ButtonPrimary}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Margin="10">
                    <pf:Card FontSize="{DynamicResource FontSize.Body.Standard}" IsEnabled="{Binding Station2IsEnabled}">
                        <pf:Card.Header>
                            <Grid Margin="10">
                                <TextBlock
                                    FontSize="{DynamicResource FontSize.H1.Large}"
                                    FontWeight="Bold"
                                    Text=" 工位2操作" />
                                <StackPanel
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Ellipse
                                        Width="10"
                                        Height="10"
                                        Margin="0,0,6,0"
                                        Fill="{Binding Door2StatusBrush}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{Binding Door2StatusBrush}"
                                        Text="{Binding Door2StatusText}" />
                                </StackPanel>
                            </Grid>
                        </pf:Card.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Margin="20,0,5,0"
                                    Text="内批：" />
                                <TextBlock Grid.Column="1" Text="{Binding Station2InternalBatches}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="40,0,5,0"
                                    Text="状态：" />
                                <TextBlock Grid.Column="3" Text="{Binding Station2DetStatus}" />
                                <TextBlock
                                    Grid.Column="4"
                                    Margin="40,0,5,0"
                                    Text=" 程式名称:" />
                                <TextBlock Grid.Column="5" Text="{Binding Station2RecipeName}" />

                                <Button
                                    Grid.Column="6"
                                    Margin="0,0,50,0"
                                    HorizontalAlignment="Right"
                                    Command="{Binding Station2ChangeLotCommand}"
                                    Content="切换批次"
                                    FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                    Style="{DynamicResource ButtonPrimary}" />
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>

                                <usercontrol:ZoomableImageViewer
                                    Grid.Column="0"
                                    Margin="5"
                                    AnnotationContent="{Binding Station2CurrentMachineDetection}"
                                    Source="{Binding Station2CurrentMachineDetection.ImagePath}" />

                                <!--  工位2晶圆盒槽位可视化：第1层在底部，第13层在顶部  -->
                                <Border
                                    Grid.Column="1"
                                    Margin="2,5,5,5"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <ItemsControl ItemsSource="{Binding Station2SlotStatesDisplay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1" Rows="13" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="2,1"
                                                    Background="{Binding Status, Converter={StaticResource SlotStatusConverter}}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2"
                                                    ToolTip="{Binding DisplayIndex, StringFormat=第 {0} 层}">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="8"
                                                        Foreground="#555555"
                                                        Text="{Binding DisplayIndex}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                        </Grid>

                        <pf:Card.Footer>
                            <Grid Height="300">
                                <DataGrid
                                    Margin="5"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    FontSize="{DynamicResource FontSize.Body.Standard}"
                                    ItemsSource="{Binding Station2MachineDetection}"
                                    SelectedItem="{Binding Station2CurrentMachineDetection}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="2*"
                                            Binding="{Binding CustomerBatch}"
                                            Header="客户批次"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="2*"
                                            Binding="{Binding OcrText}"
                                            Header="OCR值"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="2*"
                                            Binding="{Binding Barcode1}"
                                            Header="条码"
                                            IsReadOnly="True" />

                                        <DataGridTemplateColumn Width="90" Header="匹配结果">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="10,4"
                                                        HorizontalAlignment="Stretch"
                                                        CornerRadius="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="OK" />
                                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                            <Setter Property="Text" Value="NG" />
                                                                            <Setter Property="Foreground" Value="#C62828" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </pf:Card.Footer>
                    </pf:Card>

                    <!--  工位2下料确认遮罩层  -->
                    <Border Background="#CC1A1A2E" Visibility="{Binding Station2UnloadMaskVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="物料已生产完毕，请下料后确认"
                                TextAlignment="Center" />
                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="#B0B0C0"
                                Text="确认前请勿操作设备"
                                TextAlignment="Center" />
                            <Button
                                Width="160"
                                Height="44"
                                Margin="0,28,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding Station2UnloadConfirmCommand}"
                                Content="确 认 下 料"
                                FontSize="16"
                                FontWeight="Bold"
                                Style="{DynamicResource ButtonPrimary}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Grid.Column="2"
                    Margin="10"
                    Padding="15"
                    Background="{DynamicResource DarkPrimaryBrush}"
                    CornerRadius="5">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <Ellipse
                                Width="12"
                                Height="12"
                                Margin="0,0,8,0"
                                Fill="{Binding StatusBrush}" />
                            <TextBlock
                                FontSize="{DynamicResource FontSize.H2.Title}"
                                FontWeight="SemiBold"
                                Foreground="{Binding StatusBrush}"
                                Text="{Binding StatusText}" />
                        </StackPanel>

                        <Separator
                            Grid.Row="1"
                            Margin="0,5,0,15"
                            Background="{DynamicResource BorderBrush}"
                            Opacity="0.5" />
                        <Border
                            Grid.Row="2"
                            BorderBrush="{DynamicResource SecondaryBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                            <StackPanel Margin="15,0,15,15">

                                <TextBlock
                                    Margin="10"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    Text="设备记忆管理" />

                                <CheckBox
                                    Content="清除机台记忆"
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    IsChecked="{Binding IsSelectAllMemoryChecked, Mode=TwoWay}"
                                    IsEnabled="{Binding HasClearMemoryPermission}"
                                    IsThreeState="True"
                                    ToolTip="需要管理员权限才能操作此选项" />
                                <ItemsControl
                                    Margin="16,4,0,0"
                                    IsEnabled="{Binding HasClearMemoryPermission}"
                                    ItemsSource="{Binding StationMemoryItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                Margin="0,3"
                                                Content="{Binding DisplayName}"
                                                FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>




                        <Grid Grid.Row="4" Margin="0,15,0,15">

                            <pf:ButtonGroup
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                Orientation="Vertical">
                                <RadioButton
                                    MinHeight="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Command="{Binding InitializeCommand}"
                                    Content="💠 初始化"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    Tag="{StaticResource InfoBrush}"
                                    Template="{StaticResource HoverButtonTemplate}" />

                                <RadioButton
                                    MinHeight="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Command="{Binding SmartStartCommand}"
                                    Content="{Binding SmartStartText}"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    Tag="{StaticResource PrimaryBrush}"
                                    Template="{StaticResource HoverButtonTemplate}" />

                                <RadioButton
                                    MinHeight="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Command="{Binding PauseCommand}"
                                    Content="⏸ 暂停"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    Tag="{StaticResource WarningBrush}"
                                    Template="{StaticResource HoverButtonTemplate}" />

                                <RadioButton
                                    MinHeight="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Command="{Binding ResetCommand}"
                                    Content="🔄️ 复位"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    Tag="{DynamicResource SuccessBrush}"
                                    Template="{StaticResource HoverButtonTemplate}" />

                                <RadioButton
                                    MinHeight="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Command="{Binding StopCommand}"
                                    Content="⏹ 停止"
                                    FontSize="{DynamicResource FontSize.H2.Title}"
                                    Tag="{StaticResource DangerBrush}"
                                    Template="{StaticResource HoverButtonTemplate}" />
                            </pf:ButtonGroup>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>