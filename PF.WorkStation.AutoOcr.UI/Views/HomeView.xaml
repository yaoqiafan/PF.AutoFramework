<UserControl
    x:Class="PF.WorkStation.AutoOcr.UI.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Standard}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>



        <Grid Grid.Row=" 1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width=" *" />
                <ColumnDefinition Width=" *" />
            </Grid.ColumnDefinitions>

            <!--  工位1界面显示  -->
            <GroupBox
                Grid.Column=" 0"
                Margin="0,0,0,5"
                FontSize=" 18 "
                FontWeight="Bold"
                Header=" 工位1操作">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height=" auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row=" 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="内批："  Margin=" 20,0,5,0"/>
                            <TextBlock Grid.Column=" 1" Text="{Binding Station1InternalBatches}" />
                            <TextBlock
                                Grid.Column="2"
                                Margin="40,0,5,0"
                                Text="状态：" />
                            <TextBlock Grid.Column="3" Text="{Binding Station1DetStatus}" />
                            <TextBlock
                                Grid.Column=" 4"
                                Margin="40,0,5,0"
                                Text=" 程式名称:" />
                            <TextBlock Grid.Column="5" Text="{Binding Station1RecipeName}" />

                            <Button
                                Grid.Column="6"
                                Margin="60,0,0,0"
                                Command="{Binding Station1ChangeLotCommand}"  FontSize="{DynamicResource FontSize.H3.Subtitle}"  Height=" 40"
                                Content="切换批次" />
                        </Grid>
                    </StackPanel>
                    <Grid Grid.Row=" 1">
                        <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                            <DataGrid
                                Margin="0,0,0,5"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                FontSize="{DynamicResource FontSize.Body.Standard}"
                                ItemsSource="{Binding Station1MachineDetection}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width=" 2*"
                                        Binding="{Binding CustomerBatches}"
                                        Header="客户批次"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width=" 2*"
                                        Binding="{Binding OCRValue}"
                                        Header="OCR值"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width=" 2*"
                                        Binding="{Binding CodeValue1}"
                                        Header="条码"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width=" 1.2*"
                                        Binding="{Binding DetResult}"
                                        Header="结果"
                                        IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell"  BasedOn="{StaticResource DataGridCellStyle }">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="Black" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetResult}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush }"  />
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush }"  />
                                                    </DataTrigger>
                                                    <!--  Result 为 false 时背景红色  -->
                                                    <DataTrigger Binding="{Binding DetResult}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush }"  />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush }"  />

                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>


                    </Grid>

                </Grid>
            </GroupBox>
            <!--  工位2界面显示  -->
            <GroupBox
                Grid.Column=" 1"
                Margin="0,0,0,5"
                FontSize=" 18 "
                FontWeight="Bold"
                Header=" 工位2操作">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height=" auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row=" 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="内批：" Margin=" 20,0,0,0" />
                            <TextBlock Grid.Column=" 1" Text="{Binding Station2InternalBatches}" />
                            <TextBlock
                                Grid.Column="2"
                                Margin="40,0,5,0"
                                Text="状态：" />
                            <TextBlock Grid.Column="3" Text="{Binding Station2DetStatus}" />
                            <TextBlock
                                Grid.Column=" 4"
                                Margin="40,0,5,0"
                                Text=" 程式名称:" />
                            <TextBlock Grid.Column="5" Text="{Binding Station2RecipeName}" />

                            <Button
                                Grid.Column="6"
                                Margin="60,0,5,0"
                                Command="{Binding Station2ChangeLotCommand}" FontSize="{DynamicResource FontSize.H3.Subtitle}"  Height="40"
                                Content="切换批次" />
                        </Grid>
                    </StackPanel>
                    <Grid Grid.Row=" 1">
                        <ScrollViewer Padding="5,10" VerticalScrollBarVisibility="Auto">
                            <DataGrid
                                Margin="0,0,0,5"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                FontSize="12"
                                ItemsSource="{Binding Station2MachineDetection}">

                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width=" 2*"
                                        Binding="{Binding CustomerBatches}"
                                        Header="客户批次"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width=" 2*"
                                        Binding="{Binding OCRValue}"
                                        Header="OCR值"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width=" 2*"
                                        Binding="{Binding CodeValue1}"
                                        Header="条码"
                                        IsReadOnly="True" />
                                    
                                    
                                    
                                    <DataGridTextColumn
                                        Width=" 1.2*"
                                        Binding="{Binding DetResult}"
                                        Header="结果"
                                        IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle }">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="Black" />
                                                <Style.Triggers>
                                                    <!--  Result 为 true 时背景绿色  -->
                                                    <DataTrigger Binding="{Binding DetResult}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush }"  />
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush }"  />
                                                    </DataTrigger>
                                                    <!--  Result 为 false 时背景红色  -->
                                                    <DataTrigger Binding="{Binding DetResult}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush }"  />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush }"  />

                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>


                    </Grid>

                </Grid>
            </GroupBox>
        </Grid>


    </Grid>
</UserControl>