<UserControl
    x:Class="PF.Modules.SecsGem.Views.Controls.ParamDataGridControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,4">
            <Button
                Margin="0,0,4,0"
                Command="{Binding AddCommand, ElementName=Root}"
                Content="+ 新增行"
                Style="{DynamicResource ToolbarButtonStyle}" />
            <Button
                Margin="0,0,4,0"
                Command="{Binding DeleteCommand, ElementName=Root}"
                Content="- 删除选中"
                Style="{DynamicResource ToolbarButtonStyle}" />
        </WrapPanel>

        <DataGrid
            x:Name="PART_Grid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            ItemsSource="{Binding ItemsSource, ElementName=Root}"
            SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
            SelectionMode="Single" />
    </Grid>
</UserControl>
