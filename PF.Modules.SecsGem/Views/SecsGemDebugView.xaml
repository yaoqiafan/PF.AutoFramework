<UserControl
    x:Class="PF.Modules.SecsGem.Views.SecsGemDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:PF.Modules.SecsGem.ViewModels"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Bool → Visibility  -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--  Inverse Bool → Visibility (隐藏 LIST 节点的值输入框)  -->
        <vm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!--  Bool → 边框颜色（校验错误时红色）  -->
        <vm:BoolToBorderBrushConverter x:Key="BoolToBrush" />

        <!--  字符串非空 → Visibility  -->
        <vm:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />

        <!--  通用样式  -->
        <Style
            x:Key="ToolbarButtonStyle"
            BasedOn="{StaticResource ButtonBaseStyle}"
            TargetType="Button">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style
            x:Key="PrimaryButtonStyle"
            BasedOn="{StaticResource ButtonPrimary}"
            TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style
            x:Key="DangerButtonStyle"
            BasedOn="{StaticResource ButtonDanger}"
            TargetType="Button">
            <Setter Property="Background" Value="#C62828" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!--  命令树：分组节点模板  -->
        <HierarchicalDataTemplate DataType="{x:Type vm:CommandGroupViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Margin="2,2" Orientation="Horizontal">
                <TextBlock FontSize="12" Text="📁 " />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="{Binding GroupKey}" />
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem
                            Command="{Binding AddCommandCommand}"
                            FontWeight="SemiBold"
                            Header="➕ 添加命令" />
                    </ContextMenu>
                </StackPanel.ContextMenu>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!--  命令树：叶子节点模板  -->
        <DataTemplate DataType="{x:Type vm:CommandLeafViewModel}">
            <TextBlock
                Margin="4,2"
                Text="{Binding DisplayName}"
                ToolTip="{Binding DisplayName}">
                <TextBlock.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding DeleteCommand}" Header="🗑 删除命令" />
                    </ContextMenu>
                </TextBlock.ContextMenu>
            </TextBlock>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <!--  数据库空库警告 Banner  -->
            <RowDefinition Height="Auto" />
            <!--  顶部工具栏  -->
            <RowDefinition Height="52" />
            <!--  主内容区  -->
            <RowDefinition Height="*" />
            <!--  分隔线  -->
            <RowDefinition Height="5" />
            <!--  底部日志  -->
            <RowDefinition Height="230" />
        </Grid.RowDefinitions>

        <!--  ═══════════════════════════════════════════════════════════  -->
        <!--  Row 0: 空库警告 Banner  -->
        <!--  ═══════════════════════════════════════════════════════════  -->
        <Border
            Grid.Row="0"
            Padding="10,6"
            Background="#FFF3E0"
            BorderBrush="#FF6D00"
            BorderThickness="0,0,0,2"
            Visibility="{Binding IsDbEmpty, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="#E65100"
                    Text="⚠" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="#BF360C"
                    Text="{Binding DbEmptyMessage}" />
            </StackPanel>
        </Border>

        <!--  ═══════════════════════════════════════════════════════════  -->
        <!--  Row 1: 顶部工具栏  -->
        <!--  ═══════════════════════════════════════════════════════════  -->
        <Border Grid.Row="1" Margin="10,0,0,0">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                <Ellipse
                    Width="14"
                    Height="14"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Fill="{Binding StatusColor}" />

                <TextBlock
                    Margin="0,0,24,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{Binding ConnectionStatusText}" />

                <Button
                    Width="90"
                    Margin="5"
                    Command="{Binding InitializeCommand}"
                    Content="⚙ 初始化"
                    Style="{StaticResource ToolbarButtonStyle}" />

                <Button
                    Width="90"
                    Margin="5"
                    Command="{Binding ConnectCommand}"
                    Content="🔗 连接"
                    Style="{StaticResource PrimaryButtonStyle}" />

                <Button
                    Width="90"
                    Margin="5"
                    Command="{Binding DisconnectCommand}"
                    Content="✖ 断开"
                    Style="{StaticResource DangerButtonStyle}" />

                <!--  W-Bit 警告提示  -->
                <Border
                    Margin="20,0,0,0"
                    Padding="8,4"
                    Background="#FFF9C4"
                    BorderBrush="#F9A825"
                    BorderThickness="1"
                    CornerRadius="3"
                    Visibility="{Binding IsWBitWarningVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#E65100"
                        Text="⚠ 请求报文 (奇数Function) 建议勾选「等待回复」" />
                </Border>
            </StackPanel>
        </Border>



        <TabControl Grid.Row="2" Margin="0,6,0,0">

            <TabItem Header="报文命令管理">

                <Grid Grid.Row="2" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="500" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" MinWidth="300" />

                    </Grid.ColumnDefinitions>

                    <!--  ───────────────────────────────────────  -->
                    <!--  左侧面板：命令库  -->
                    <!--  ───────────────────────────────────────  -->
                    <GroupBox Grid.Column="0" Header="📚 命令库 (Command Library)">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  操作按钮  -->
                            <WrapPanel Grid.Row="0" Margin="2,4,2,6">
                                <Button
                                    Width="72"
                                    Margin="0,0,4,0"
                                    Command="{Binding ImportCommandsCommand}"
                                    Content="导入"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                                <Button
                                    Width="72"
                                    Margin="0,0,4,0"
                                    Command="{Binding ExportCommandsCommand}"
                                    Content="导出"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                                <Button
                                    Width="72"
                                    Command="{Binding ReloadCommandsCommand}"
                                    Content="重载"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                                <Button
                                    Margin="0,0,4,0"
                                    Command="{Binding AddNewCommandCommand}"
                                    Content="➕ 新建命令"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                            </WrapPanel>

                            <!--  主动/应答 Tab  -->
                            <TabControl Grid.Row="1">
                                <TabItem Header="主动命令">
                                    <TreeView
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding IncentiveCommandsTree}"
                                        MouseRightButtonDown="TreeView_MouseRightButtonDown"
                                        Style="{DynamicResource TreeViewBaseStyle}">
                                        <TreeView.ItemContainerStyle>
                                            <Style BasedOn="{StaticResource TreeViewItemBaseStyle}" TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="True" />
                                                <EventSetter Event="MouseLeftButtonUp" Handler="OnCommandTreeItemClicked" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>
                                </TabItem>
                                <TabItem Header="应答命令">
                                    <TreeView
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding ResponseCommandsTree}"
                                        MouseRightButtonDown="TreeView_MouseRightButtonDown">
                                        <TreeView.ItemContainerStyle>
                                            <Style BasedOn="{StaticResource TreeViewItemBaseStyle}" TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="True" />
                                                <EventSetter Event="MouseLeftButtonUp" Handler="OnCommandTreeItemClicked" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </GroupBox>



                    <!--  ───────────────────────────────────────  -->
                    <!--  中间面板：报文编辑器  -->
                    <!--  ───────────────────────────────────────  -->
                    <GroupBox Grid.Column="2" Header="✏ 报文编辑器 (Message Builder)">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  当前命令标题  -->
                            <Border
                                Grid.Row="0"
                                Margin="0,0,0,4"
                                Padding="8,5"
                                CornerRadius="{DynamicResource DefaultCornerRadius}">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Text="{Binding CurrentCommandHeader}" />
                            </Border>

                            <!--  报文节点树  -->
                            <TreeView
                                Grid.Row="1"
                                BorderThickness="1"
                                ItemsSource="{Binding CurrentMessageNodes}"
                                MouseRightButtonDown="TreeView_MouseRightButtonDown"
                                VirtualizingStackPanel.IsVirtualizing="False">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:SecsNodeViewModel}" ItemsSource="{Binding Children}">
                                        <Grid>
                                            <StackPanel Margin="2,2" Orientation="Horizontal">

                                                <!--  类型标签 (如 L / A / U4)  -->
                                                <Border
                                                    MinWidth="32"
                                                    Margin="0,0,6,0"
                                                    Padding="5,2"
                                                    HorizontalAlignment="Center"
                                                    CornerRadius="3">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource TextIconBrush}"
                                                        Text="{Binding ItemFormat}" />
                                                </Border>

                                                <!--  长度标签  -->
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextIconBrush}"
                                                    Text="[" />
                                                <TextBlock
                                                    Margin="5,0,5,0"
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextIconBrush}"
                                                    Text="{Binding Length}" />
                                                <TextBlock
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextIconBrush}"
                                                    Text="]" />

                                                <!--  值输入框（LIST 节点隐藏）  -->
                                                <TextBox
                                                    MinWidth="140"
                                                    MaxWidth="240"
                                                    Margin="0,0,6,0"
                                                    Padding="4,2"
                                                    VerticalContentAlignment="Center"
                                                    Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="{Binding IsListNode, Converter={StaticResource InverseBoolToVis}}">
                                                    <TextBox.Style>
                                                        <Style BasedOn="{StaticResource TextBoxBaseStyle}" TargetType="TextBox">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#E53935" />
                                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                    <TextBox.ToolTip>
                                                        <ToolTip Content="{Binding ValidationErrorMessage}" Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}" />
                                                    </TextBox.ToolTip>
                                                </TextBox>

                                                <!--  校验错误警告图标  -->
                                                <TextBlock
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    Foreground="#E53935"
                                                    Text="⚠"
                                                    ToolTip="{Binding ValidationErrorMessage}"
                                                    Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}" />

                                                <!--  VID 勾选框  -->
                                                <CheckBox
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Content="VID"
                                                    IsChecked="{Binding IsVariableNode}"
                                                    Visibility="{Binding IsListNode, Converter={StaticResource InverseBoolToVis}}" />

                                                <!--  已绑定的 VID 说明  -->
                                                <Border
                                                    Padding="4,1"
                                                    Background="#E8F5E9"
                                                    CornerRadius="3"
                                                    Visibility="{Binding VariableDescription, Converter={StaticResource StringNotEmptyToVis}}">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="#2E7D32"
                                                        Text="{Binding VariableDescription}" />
                                                </Border>

                                                <StackPanel.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem
                                                            Command="{Binding AddChildCommand}"
                                                            Header="➕ 添加子节点 (LIST)"
                                                            Visibility="{Binding IsListNode, Converter={StaticResource BoolToVis}}" />
                                                        <Separator Visibility="{Binding IsListNode, Converter={StaticResource BoolToVis}}" />
                                                        <MenuItem Command="{Binding RemoveNodeCommand}" Header="🗑 删除此节点" />
                                                    </ContextMenu>
                                                </StackPanel.ContextMenu>
                                            </StackPanel>
                                        </Grid>

                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style BasedOn="{StaticResource TreeViewItemBaseStyle}" TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>

                            <!--  底部操作栏  -->
                            <StackPanel
                                Grid.Row="2"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">

                                <CheckBox
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    Content="等待回复 (W-Bit)"
                                    IsChecked="{Binding WaitReply}" />

                                <Button
                                    Margin="0,0,4,0"
                                    Command="{Binding SaveMessageCommand}"
                                    Content="💾 保存报文"
                                    Style="{StaticResource ToolbarButtonStyle}" />

                                <Button
                                    Command="{Binding UpdateVariablesCommand}"
                                    Content="🔄 更新变量节点"
                                    Style="{StaticResource ToolbarButtonStyle}" />

                                <Button
                                    Width="120"
                                    Command="{Binding SendCommand}"
                                    Content="▶ 发送 (Send)"
                                    FontSize="13"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>




                </Grid>
            </TabItem>


            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  参数管理 Tab（分类展示 System / VID / CEID / ReportID / CommandID）  -->
            <!--  ═══════════════════════════════════════════════════════════  -->
            <TabItem Header="参数管理">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedParamTabIndex}">

                        <!--  系统参数  -->
                        <TabItem Header="🖥 系统参数">
                            <DataGrid
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                ItemsSource="{Binding ParamRows}"
                                SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="*" MinWidth="100" Binding="{Binding Name}" Header="名称" IsReadOnly="True" />
                                    <DataGridTextColumn Width="160" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Header="值" />
                                    <DataGridTextColumn Width="70" Binding="{Binding DataType}" Header="类型" IsReadOnly="True" />
                                    <DataGridTextColumn Width="*" MinWidth="80" Binding="{Binding Description}" Header="说明" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!--  VID  -->
                        <TabItem Header="📋 VID">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                                    <Button Margin="0,0,4,0" Command="{Binding AddVidCommand}" Content="+ 新增行" Style="{StaticResource ToolbarButtonStyle}" />
                                    <Button Margin="0,0,4,0" Command="{Binding DeleteVidCommand}" Content="- 删除选中" Style="{StaticResource ToolbarButtonStyle}" />
                                </WrapPanel>
                                <DataGrid
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    GridLinesVisibility="Horizontal"
                                    HeadersVisibility="Column"
                                    ItemsSource="{Binding VidRows}"
                                    SelectedItem="{Binding SelectedVidRow}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="60" Binding="{Binding Code, UpdateSourceTrigger=LostFocus}" Header="Code" />
                                        <DataGridTextColumn Width="*" MinWidth="80" Binding="{Binding Description, UpdateSourceTrigger=LostFocus}" Header="描述" />
                                        <DataGridTextColumn Width="80" Binding="{Binding DataType, UpdateSourceTrigger=LostFocus}" Header="类型" />
                                        <DataGridTextColumn Width="120" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Header="值" />
                                        <DataGridTextColumn Width="*" MinWidth="60" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!--  CEID  -->
                        <TabItem Header="📡 CEID">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                                    <Button Margin="0,0,4,0" Command="{Binding AddCeidCommand}" Content="+ 新增行" Style="{StaticResource ToolbarButtonStyle}" />
                                    <Button Margin="0,0,4,0" Command="{Binding DeleteCeidCommand}" Content="- 删除选中" Style="{StaticResource ToolbarButtonStyle}" />
                                </WrapPanel>
                                <DataGrid
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    GridLinesVisibility="Horizontal"
                                    HeadersVisibility="Column"
                                    ItemsSource="{Binding CeidRows}"
                                    SelectedItem="{Binding SelectedCeidRow}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="60" Binding="{Binding Code, UpdateSourceTrigger=LostFocus}" Header="Code" />
                                        <DataGridTextColumn Width="*" MinWidth="80" Binding="{Binding Description, UpdateSourceTrigger=LostFocus}" Header="描述" />
                                        <DataGridTextColumn Width="150" Binding="{Binding LinkReportIDs, UpdateSourceTrigger=LostFocus}" Header="关联 ReportID" />
                                        <DataGridTextColumn Width="*" MinWidth="60" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!--  ReportID  -->
                        <TabItem Header="📄 ReportID">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                                    <Button Margin="0,0,4,0" Command="{Binding AddReportIdCommand}" Content="+ 新增行" Style="{StaticResource ToolbarButtonStyle}" />
                                    <Button Margin="0,0,4,0" Command="{Binding DeleteReportIdCommand}" Content="- 删除选中" Style="{StaticResource ToolbarButtonStyle}" />
                                </WrapPanel>
                                <DataGrid
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    GridLinesVisibility="Horizontal"
                                    HeadersVisibility="Column"
                                    ItemsSource="{Binding ReportIdRows}"
                                    SelectedItem="{Binding SelectedReportIdRow}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="60" Binding="{Binding Code, UpdateSourceTrigger=LostFocus}" Header="Code" />
                                        <DataGridTextColumn Width="*" MinWidth="80" Binding="{Binding Description, UpdateSourceTrigger=LostFocus}" Header="描述" />
                                        <DataGridTextColumn Width="150" Binding="{Binding LinkVIDs, UpdateSourceTrigger=LostFocus}" Header="关联 VID" />
                                        <DataGridTextColumn Width="*" MinWidth="60" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!--  CommandID  -->
                        <TabItem Header="⌨ CommandID">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                                    <Button Margin="0,0,4,0" Command="{Binding AddCommandIdCommand}" Content="+ 新增行" Style="{StaticResource ToolbarButtonStyle}" />
                                    <Button Margin="0,0,4,0" Command="{Binding DeleteCommandIdCommand}" Content="- 删除选中" Style="{StaticResource ToolbarButtonStyle}" />
                                </WrapPanel>
                                <DataGrid
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    GridLinesVisibility="Horizontal"
                                    HeadersVisibility="Column"
                                    ItemsSource="{Binding CommandIdRows}"
                                    SelectedItem="{Binding SelectedCommandIdRow}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="60" Binding="{Binding Code, UpdateSourceTrigger=LostFocus}" Header="Code" />
                                        <DataGridTextColumn Width="*" MinWidth="80" Binding="{Binding Description, UpdateSourceTrigger=LostFocus}" Header="描述" />
                                        <DataGridTextColumn Width="80" Binding="{Binding RCMD, UpdateSourceTrigger=LostFocus}" Header="RCMD" />
                                        <DataGridTextColumn Width="150" Binding="{Binding LinkVIDs, UpdateSourceTrigger=LostFocus}" Header="关联 VID" />
                                        <DataGridTextColumn Width="*" MinWidth="60" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                    </TabControl>

                    <!--  底部操作按钮  -->
                    <WrapPanel
                        Grid.Row="1"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Right">
                        <Button
                            Margin="0,0,4,0"
                            Command="{Binding ImportSystemParamCommand}"
                            Content="📂 导入系统参数(JSON)"
                            Style="{StaticResource ToolbarButtonStyle}" />
                        <Button
                            Margin="0,0,4,0"
                            Command="{Binding ImportValidateParamCommand}"
                            Content="📊 导入变量参数(Excel)"
                            Style="{StaticResource ToolbarButtonStyle}" />
                        <Button
                            Width="70"
                            Margin="0,0,4,0"
                            Command="{Binding ExportParamsCommand}"
                            Content="导出"
                            Style="{StaticResource ToolbarButtonStyle}" />
                        <Button
                            Command="{Binding SaveParamCommand}"
                            Content="💾 保存参数"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  外围服务管理 Tab                                              -->
            <!--  ═══════════════════════════════════════════════════════════  -->
            <TabItem Header="外围服务管理">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  区域 A：Windows 服务管控  -->
                    <GroupBox Grid.Row="0" Header="🔧 Windows 服务管控" Margin="0,0,0,6">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  服务名称 + 状态  -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,6" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="服务名称: " />
                                <TextBox
                                    Width="200"
                                    Margin="0,0,16,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding ServiceNameForManagement, UpdateSourceTrigger=PropertyChanged}" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Fill="{Binding ServiceStatusColor}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{Binding ServiceStatusText}" />
                            </StackPanel>

                            <!--  EXE 路径  -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,6" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="服务 EXE 路径: " />
                                <TextBox
                                    Width="400"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding ServiceExePath, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  操作按钮  -->
                            <WrapPanel Grid.Row="2">
                                <Button
                                    Margin="0,0,4,0"
                                    Command="{Binding InstallServiceCommand}"
                                    Content="📥 安装服务"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                                <Button
                                    Margin="0,0,4,0"
                                    Command="{Binding UninstallServiceCommand}"
                                    Content="🗑 卸载服务"
                                    Style="{StaticResource DangerButtonStyle}" />
                                <Button
                                    Margin="0,0,4,0"
                                    Command="{Binding StartServiceCommand}"
                                    Content="▶ 启动服务"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                                <Button
                                    Command="{Binding RefreshServiceStatusCommand}"
                                    Content="🔄 刷新状态"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                            </WrapPanel>
                        </Grid>
                    </GroupBox>

                </Grid>
            </TabItem>

        </TabControl>



        <!--  ═══════════════════════════════════════════════════════════  -->
        <!--  Row 4: 实时通信日志  -->
        <!--  ═══════════════════════════════════════════════════════════  -->
        <GroupBox Grid.Row="4" Header="📋 实时通信日志 (Transaction Logs)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  日志列表 (双列：Raw Hex + SML)  -->
                <ListBox
                    x:Name="LogListBox"
                    Grid.Row="0"
                    Background="#263238"
                    BorderThickness="0"
                    ItemsSource="{Binding TransactionLogs}"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#37474F" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2E3C43" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TransactionLogEntry}">
                            <Grid Margin="2,1">
                                <Grid.ColumnDefinitions>
                                    <!--  方向箭头  -->
                                    <ColumnDefinition Width="28" />
                                    <!--  时间 + 报文头  -->
                                    <ColumnDefinition Width="190" />
                                    <!--  Raw Hex  -->
                                    <ColumnDefinition Width="280" />
                                    <!--  SML 文本  -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{Binding DirectionColor}"
                                    Text="{Binding Direction}" />

                                <TextBlock
                                    Grid.Column="1"
                                    Margin="4,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="#B0BEC5"
                                    Text="{Binding TimestampHeader}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip="{Binding TimestampHeader}" />

                                <TextBlock
                                    Grid.Column="2"
                                    Margin="6,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    Foreground="#78909C"
                                    Text="{Binding RawHex}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip="{Binding RawHex}" />

                                <TextBlock
                                    Grid.Column="3"
                                    Margin="6,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="#E0F2F1"
                                    Text="{Binding SmlText}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap"
                                    ToolTip="{Binding SmlText}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!--  日志底部操作栏  -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <CheckBox
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Content="自动滚动"
                        Foreground="#546E7A"
                        IsChecked="{Binding AutoScrollLog}" />
                    <Button
                        Command="{Binding ClearLogCommand}"
                        Content="🗑 清空日志"
                        Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
