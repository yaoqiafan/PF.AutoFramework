<UserControl x:Class="PF.Modules.SecsGem.Views.SecsGemDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:PF.Modules.SecsGem.ViewModels"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.Resources>
        <!-- Bool → Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Inverse Bool → Visibility (隐藏 LIST 节点的值输入框) -->
        <vm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Bool → 边框颜色（校验错误时红色）-->
        <vm:BoolToBorderBrushConverter x:Key="BoolToBrush"/>

        <!-- 字符串非空 → Visibility -->
        <vm:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis"/>

        <!-- 通用样式 -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- 命令树：分组节点模板 -->
        <HierarchicalDataTemplate x:Key="CommandGroupTemplate"
                                  DataType="{x:Type vm:CommandGroupViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <TextBlock Text="📁 " FontSize="12"/>
                <TextBlock Text="{Binding GroupKey}"
                           FontWeight="Bold"
                           Foreground="#1A237E"
                           VerticalAlignment="Center"/>
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="➕ 添加命令"
                                  Command="{Binding AddCommandCommand}"
                                  FontWeight="SemiBold"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- 命令树：叶子节点模板 -->
        <DataTemplate x:Key="CommandLeafTemplate"
                      DataType="{x:Type vm:CommandLeafViewModel}">
            <TextBlock Text="{Binding DisplayName}"
                       Margin="4,2"
                       ToolTip="{Binding DisplayName}"
                       Foreground="#37474F"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <!-- 数据库空库警告 Banner -->
            <RowDefinition Height="Auto"/>
            <!-- 顶部工具栏 -->
            <RowDefinition Height="52"/>
            <!-- 主内容区 -->
            <RowDefinition Height="*"/>
            <!-- 分隔线 -->
            <RowDefinition Height="5"/>
            <!-- 底部日志 -->
            <RowDefinition Height="230"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Row 0: 空库警告 Banner -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#FFF3E0"
                BorderBrush="#FF6D00"
                BorderThickness="0,0,0,2"
                Padding="10,6"
                Visibility="{Binding IsDbEmpty, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="16" Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding DbEmptyMessage}"
                           Foreground="#BF360C"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Row 1: 顶部工具栏 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="10,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- 状态指示灯 -->
                <Ellipse Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                         Fill="{Binding StatusColor}"/>

                <TextBlock Text="{Binding ConnectionStatusText}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,24,0"
                           Width="140"/>

                <Button Content="⚙ 初始化"
                        Command="{Binding InitializeCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="100"/>

                <Button Content="🔗 连接"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="90"/>

                <Button Content="✖ 断开"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Width="90"/>

                <!-- W-Bit 警告提示 -->
                <Border Background="#FFF9C4"
                        BorderBrush="#F9A825"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,4"
                        Margin="20,0,0,0"
                        Visibility="{Binding IsWBitWarningVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⚠ 请求报文 (奇数Function) 建议勾选「等待回复」"
                               Foreground="#E65100"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Row 2: 主内容区（三列布局） -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="310" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────── -->
            <!-- 左侧面板：命令库 -->
            <!-- ─────────────────────────────────────── -->
            <GroupBox Grid.Column="0" Header="📚 命令库 (Command Library)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 操作按钮 -->
                    <WrapPanel Grid.Row="0" Margin="2,4,2,6">
                        <Button Content="导入" Command="{Binding ImportCommandsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" Width="72" Margin="0,0,4,0"/>
                        <Button Content="导出" Command="{Binding ExportCommandsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" Width="72" Margin="0,0,4,0"/>
                        <Button Content="重载" Command="{Binding ReloadCommandsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" Width="72"/>
                    </WrapPanel>

                    <!-- 主动/应答 Tab -->
                    <TabControl Grid.Row="1">
                        <TabItem Header="主动命令">
                            <TreeView ItemsSource="{Binding IncentiveCommandsTree}"
                                      ItemTemplate="{StaticResource CommandGroupTemplate}"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <!-- 点击叶子节点 -->
                                        <EventSetter Event="MouseLeftButtonUp"
                                                     Handler="OnCommandTreeItemClicked"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </TabItem>
                        <TabItem Header="应答命令">
                            <TreeView ItemsSource="{Binding ResponseCommandsTree}"
                                      ItemTemplate="{StaticResource CommandGroupTemplate}"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <EventSetter Event="MouseLeftButtonUp"
                                                     Handler="OnCommandTreeItemClicked"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </TabItem>
                    </TabControl>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#E0E0E0"/>

            <!-- ─────────────────────────────────────── -->
            <!-- 中间面板：报文编辑器 -->
            <!-- ─────────────────────────────────────── -->
            <GroupBox Grid.Column="2" Header="✏ 报文编辑器 (Message Builder)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 当前命令标题 -->
                    <Border Grid.Row="0"
                            Background="#E3F2FD"
                            CornerRadius="3"
                            Padding="8,5"
                            Margin="0,0,0,4">
                        <TextBlock Text="{Binding CurrentCommandHeader}"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="#0D47A1"/>
                    </Border>

                    <!-- 报文节点树 -->
                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding CurrentMessageNodes}"
                              BorderBrush="#CFD8DC"
                              BorderThickness="1"
                              Background="#FAFAFA"
                              VirtualizingStackPanel.IsVirtualizing="False">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:SecsNodeViewModel}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,2">

                                    <!-- 类型标签 (如 L / A / U4) -->
                                    <Border Background="#E8EAF6"
                                            CornerRadius="3"
                                            Padding="5,2"
                                            Margin="0,0,6,0"
                                            MinWidth="32">
                                        <TextBlock Text="{Binding ItemFormat}"
                                                   Foreground="#283593"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- 长度标签 -->
                                    <TextBlock Text="[" Foreground="#78909C" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Length}"
                                               Foreground="#2E7D32"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               MinWidth="20"/>
                                    <TextBlock Text="]" Foreground="#78909C" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>

                                    <!-- 值输入框（LIST 节点隐藏）-->
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="140"
                                             MaxWidth="240"
                                             Margin="0,0,6,0"
                                             VerticalContentAlignment="Center"
                                             Padding="4,2"
                                             Visibility="{Binding IsListNode, Converter={StaticResource InverseBoolToVis}}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#E53935"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                        <TextBox.ToolTip>
                                            <ToolTip Content="{Binding ValidationErrorMessage}"
                                                     Visibility="{Binding HasValidationError,
                                                                  Converter={StaticResource BoolToVis}}"/>
                                        </TextBox.ToolTip>
                                    </TextBox>

                                    <!-- 校验错误警告图标 -->
                                    <TextBlock Text="⚠"
                                               Foreground="#E53935"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"
                                               ToolTip="{Binding ValidationErrorMessage}"
                                               Visibility="{Binding HasValidationError,
                                                            Converter={StaticResource BoolToVis}}"/>

                                    <!-- VID 勾选框 -->
                                    <CheckBox Content="VID"
                                              IsChecked="{Binding IsVariableNode}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0"/>

                                    <!-- 已绑定的 VID 说明 -->
                                    <Border Background="#E8F5E9"
                                            CornerRadius="3"
                                            Padding="4,1"
                                            Visibility="{Binding VariableDescription,
                                                         Converter={StaticResource StringNotEmptyToVis}}">
                                        <TextBlock Text="{Binding VariableDescription}"
                                                   Foreground="#2E7D32"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="➕ 添加子节点 (LIST)"
                                                      Command="{Binding AddChildCommand}"
                                                      Visibility="{Binding IsListNode,
                                                                   Converter={StaticResource BoolToVis}}"/>
                                            <Separator Visibility="{Binding IsListNode,
                                                                   Converter={StaticResource BoolToVis}}"/>
                                            <MenuItem Header="🗑 删除此节点"
                                                      Command="{Binding RemoveNodeCommand}"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <!-- 底部操作栏 -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0">

                        <CheckBox Content="等待回复 (W-Bit)"
                                  IsChecked="{Binding WaitReply}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"/>

                        <Button Content="🔄 更新变量节点"
                                Command="{Binding UpdateVariablesCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Width="130"/>

                        <Button Content="▶ 发送 (Send)"
                                Command="{Binding SendCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="120"
                                FontSize="13"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="#E0E0E0"/>

            <!-- ─────────────────────────────────────── -->
            <!-- 右侧面板：参数配置 -->
            <!-- ─────────────────────────────────────── -->
            <GroupBox Grid.Column="4" Header="⚙ 参数配置 (Parameters)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ComboBox Grid.Row="0"
                              SelectedIndex="{Binding SelectedParamIndex}"
                              Margin="0,0,0,6"
                              Height="30">
                        <ComboBoxItem Content="🖥 System Params (系统参数)"/>
                        <ComboBoxItem Content="✅ Validate Params (VID/CEID)"/>
                        <ComboBoxItem Content="📐 Formula Params (配方命令)"/>
                    </ComboBox>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ParamRows}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F5F5F5"
                              BorderBrush="#CFD8DC"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}"
                                                IsReadOnly="True" Width="*"
                                                MinWidth="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="ToolTip" Value="{Binding Name}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                Width="100" MinWidth="60"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding DataType}"
                                                IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="说明" Binding="{Binding Description}"
                                                IsReadOnly="True" Width="*" MinWidth="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding Description}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <WrapPanel Grid.Row="2" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="导入"
                                Command="{Binding ImportParamsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Width="70" Margin="0,0,4,0"/>
                        <Button Content="导出"
                                Command="{Binding ExportParamsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Width="70" Margin="0,0,4,0"/>
                        <Button Content="💾 保存参数"
                                Command="{Binding SaveParamCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Background="#E8F5E9"
                                Width="90"/>
                    </WrapPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Row 3: 分隔条 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                      Background="#E0E0E0"/>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Row 4: 实时通信日志 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <GroupBox Grid.Row="4" Header="📋 实时通信日志 (Transaction Logs)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 日志列表 (双列：Raw Hex + SML) -->
                <ListBox Grid.Row="0"
                         x:Name="LogListBox"
                         ItemsSource="{Binding TransactionLogs}"
                         BorderThickness="0"
                         Background="#263238"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#37474F"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2E3C43"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TransactionLogEntry}">
                            <Grid Margin="2,1">
                                <Grid.ColumnDefinitions>
                                    <!-- 方向箭头 -->
                                    <ColumnDefinition Width="28"/>
                                    <!-- 时间 + 报文头 -->
                                    <ColumnDefinition Width="190"/>
                                    <!-- Raw Hex -->
                                    <ColumnDefinition Width="280"/>
                                    <!-- SML 文本 -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Direction}"
                                           Foreground="{Binding DirectionColor}"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimestampHeader}"
                                           Foreground="#B0BEC5"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="4,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding TimestampHeader}"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding RawHex}"
                                           Foreground="#78909C"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="6,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding RawHex}"/>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding SmlText}"
                                           Foreground="#E0F2F1"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="6,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding SmlText}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 日志底部操作栏 -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,4,0,0"
                            HorizontalAlignment="Right">
                    <CheckBox Content="自动滚动"
                              IsChecked="{Binding AutoScrollLog}"
                              VerticalAlignment="Center"
                              Foreground="#546E7A"
                              Margin="0,0,12,0"/>
                    <Button Content="🗑 清空日志"
                            Command="{Binding ClearLogCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="100"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
