<UserControl
    x:Class="PF.Modules.SecsGem.Dialogs.VidSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.SecsGem.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinWidth="380"
    MinHeight="300"
    mc:Ignorable="d" FontSize="{DynamicResource FontSize.Body.Standard}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,8"
            FontWeight="SemiBold"
            Text="请从列表中选择要绑定的变量 (VID)：" />

        <ListBox
            Grid.Row="1"
            BorderBrush="#CFD8DC"
            BorderThickness="1"
            DisplayMemberPath="DisplayText"
            ItemsSource="{Binding VidItems}"
            SelectedItem="{Binding SelectedVidItem}">
            <ListBox.InputBindings>
                <MouseBinding
                    Command="{Binding ConfirmCommand}"
                    MouseAction="LeftDoubleClick" />
            </ListBox.InputBindings>
        </ListBox>

        <StackPanel
            Grid.Row="2"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="90"
                Height="32"
                Margin="0,0,8,0"
                Command="{Binding ConfirmCommand}"
                Content="确定 (OK)"
                IsDefault="True" />
            <Button
                Width="90"
                Height="32"
                Command="{Binding CancelCommand}"
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</UserControl>
