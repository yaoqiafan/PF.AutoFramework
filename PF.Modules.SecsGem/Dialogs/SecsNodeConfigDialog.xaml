<UserControl
    x:Class="PF.Modules.SecsGem.Dialogs.SecsNodeConfigDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.SecsGem.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock
                Margin="0,0,0,4"
                FontWeight="SemiBold"
                Text="数据类型 (DataType):" />
            <ComboBox
                x:Name="DataTypeComboBox"
                Height="28"
                 />
        </StackPanel>

        <CheckBox
            x:Name="IsVariableCheckBox"
            Grid.Row="1"
            Margin="0,0,0,12"
            
            Content="作为变量节点 (绑定 VID)"
            />

        <StackPanel
            x:Name="VariablePanel"
            Grid.Row="2"
            Margin="0,0,0,12"
            Visibility="Collapsed">
            <TextBlock
                Margin="0,0,0,4"
                FontWeight="SemiBold"
                Text="已绑定变量:" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="VariableDescTextBox"
                    Height="28"
                    Padding="4,0"
                    VerticalContentAlignment="Center"
                    Background="#F5F5F5"
                    IsReadOnly="True" />
                <Button
                    Grid.Column="1"
                    Width="80"
                    Margin="8,0,0,0"
                    Click="OnSelectVidClick"
                    Content="选择 VID" />
            </Grid>
        </StackPanel>

        <StackPanel
            x:Name="StaticValuePanel"
            Grid.Row="3"
            Margin="0,0,0,12">
            <TextBlock
                Margin="0,0,0,4"
                FontWeight="SemiBold"
                Text="节点初始值 (Value):" />
            <TextBox
              
                Height="28"
                Padding="4,0"
                VerticalContentAlignment="Center" />
            <TextBlock
                x:Name="ListTipTextBlock"
                Margin="0,4,0,0"
                FontSize="11"
                Foreground="#757575"
                Text="LIST 节点无需输入值，稍后可直接添加子节点。"
                Visibility="Collapsed" />
        </StackPanel>

        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                
                Content="确定"
                IsDefault="True" />
            <Button
                Width="80"
                Height="30"
               
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</UserControl>
