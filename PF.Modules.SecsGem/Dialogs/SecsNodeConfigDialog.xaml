<UserControl
    x:Class="PF.Modules.SecsGem.Dialogs.SecsNodeConfigDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.SecsGem.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinWidth="360"
    mc:Ignorable="d" FontSize="{DynamicResource FontSize.Body.Standard}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  数据类型选择  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock
                Margin="0,0,0,4"
                FontWeight="SemiBold"
                Text="数据类型 (DataType):" />
            <ComboBox
                Height="28"
                ItemsSource="{Binding DataTypeOptions}"
                SelectedItem="{Binding SelectedDataType}" />
        </StackPanel>

        <!--  变量绑定 CheckBox  -->
        <CheckBox
            Grid.Row="1"
            Margin="0,0,0,12"
            Content="作为变量节点 (绑定 VID)"
            IsChecked="{Binding IsVariableNode}"
            IsEnabled="{Binding CanBindVariable}" />

        <!--  变量选择面板（勾选变量绑定 且 非 LIST 时显示）  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,0,0,12"
            Visibility="{Binding IsVariablePanelVisible}">
            <TextBlock
                Margin="0,0,0,4"
                FontWeight="SemiBold"
                Text="已绑定变量:" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Height="28"
                    Padding="4,0"
                    VerticalContentAlignment="Center"
                    Background="#F5F5F5"
                    IsReadOnly="True"
                    Text="{Binding VariableDescription, Mode=OneWay}" />
                <Button
                    Grid.Column="1"
                    Width="80"
                    Margin="8,0,0,0"
                    Command="{Binding SelectVidCommand}"
                    Content="选择 VID" />
            </Grid>
        </StackPanel>

        <!--  静态值面板（非变量 且 非 LIST 时显示）  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,0,0,12"
            Visibility="{Binding IsValueInputVisible}">
            <TextBlock
                Margin="0,0,0,4"
                FontWeight="SemiBold"
                Text="节点初始值 (Value):" />
            <TextBox
                Height="28"
                Padding="4,0"
                VerticalContentAlignment="Center"
                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!--  LIST 提示（LIST 类型时显示）  -->
        <TextBlock
            Grid.Row="4"
            Margin="0,0,0,4"
            FontSize="11"
            Foreground="#757575"
            Text="LIST 节点无需输入值，稍后可直接添加子节点。"
            Visibility="{Binding IsListTipVisible}" />

        <!--  操作按钮  -->
        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Command="{Binding ConfirmCommand}"
                Content="确定"
                IsDefault="True" />
            <Button
                Width="80"
                Height="30"
                Command="{Binding CancelCommand}"
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</UserControl>
