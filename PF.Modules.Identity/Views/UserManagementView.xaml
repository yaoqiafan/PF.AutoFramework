<UserControl
    x:Class="PF.Modules.Identity.Views.UserManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.Modules.Identity.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    Width="800"
    Height="460"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="5">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" Margin="0,0,12,0">
                    <StackPanel
                        Margin="0,0,0,10"
                        DockPanel.Dock="Top"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding LoadUsersCommand}"
                            Content="刷新" />
                        <Button
                            Command="{Binding AddCommand}"
                            Content="新增用户"
                            Style="{StaticResource ButtonPrimary}" />
                    </StackPanel>

                    <DataGrid
                        AutoGenerateColumns="False"
                        BorderThickness="1"
                        IsReadOnly="True"
                        ItemsSource="{Binding Users}"
                        SelectedItem="{Binding SelectedUser}"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding UserName}"
                                Header="账户名称" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding Root}"
                                Header="用户等级" />
                            <DataGridTemplateColumn Width="80" Header="操作">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Command="{Binding Data.DeleteCommand, Source={StaticResource Proxy}}"
                                            CommandParameter="{Binding}"
                                            Content="删除"
                                            IsEnabled="{Binding UserName, Converter={StaticResource SystemUserToBoolConverter}}"
                                            Style="{StaticResource ButtonDashedDanger}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <Border
                    Grid.Column="1"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15" DataContext="{Binding SelectedUser}">
                            <TextBlock
                                Margin="0,0,0,15"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="用户信息编辑" />

                            <TextBlock Margin="0,0,0,5" Text="用户名" />
                            <TextBox Margin="0,0,0,15" Text="{Binding UserName}" />

                            <TextBlock Margin="0,0,0,5" Text="密码" />
                            <TextBox Margin="0,0,0,15" Text="{Binding Password}" />

                            <TextBlock Margin="0,0,0,5" Text="权限等级" />
                            <ComboBox
                                Margin="0,0,0,15"
                                ItemsSource="{Binding Data.UserLevels, Source={StaticResource Proxy}}"
                                SelectedItem="{Binding Root}" />

                            <TextBlock Margin="0,0,0,5" Text="可访问页面" />
                            <TextBlock
                                Height="80"
                                Margin="0,0,0,15"
                                Text="{Binding AccessibleViews}"
                                ToolTip="例如: ParameterView, LogView, HistoryView" />

                            <Button
                                Height="35"
                                Command="{Binding Data.SaveCommand, Source={StaticResource Proxy}}"
                                Content="保存更改"
                                Style="{StaticResource ButtonPrimary}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </pf:TransitioningContentControl>
</UserControl>
