<UserControl
    x:Class="PF.Workstation.Demo.UI.Views.GantryMechanismView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="500"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="StatusIndicatorStyle" TargetType="Border">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="Background" Value="Gray" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Background" Value="#FF28A745" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="False">
                    <Setter Property="Background" Value="#FFDC3545" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="12"
                BorderBrush="#DEE2E6"
                BorderThickness="1"
                CornerRadius="5">
                <DockPanel LastChildFill="False">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSize.H3.Subtitle}"
                        FontWeight="Bold"
                        Text="{Binding MechanismName}" />

                    <StackPanel
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <Border Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding HasAlarm}" />
                            <TextBlock
                                Width="40"
                                VerticalAlignment="Center"
                                Text="报警" />
                        </StackPanel>

                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <Border Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding IsInitialized}" />
                            <TextBlock
                                Width="55"
                                VerticalAlignment="Center"
                                Text="已初始化" />
                        </StackPanel>

                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <Border
                                Width="14"
                                Height="14"
                                Margin="4,0,8,0"
                                CornerRadius="7">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Background" Value="#FFFFC107" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock
                                Width="45"
                                VerticalAlignment="Center"
                                Text="忙碌中" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ScrollViewer
                Grid.Row="1"
                Margin="0,15"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox
                        Margin="0,0,0,15"
                        Padding="15"
                        Header="硬件状态监控">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="X轴位置 :" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource FontSize.H3.Subtitle}"
                                FontWeight="Bold"
                                Foreground="Blue"
                                Text="{Binding CurrentPosition, StringFormat={}{0:F3} mm}" />

                            <TextBlock
                                Grid.Row="2"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="真空状态 :" />
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="1"
                                Orientation="Horizontal">
                                <Border Style="{StaticResource StatusIndicatorStyle}" Tag="{Binding IsVacuumOn}" />
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="已关闭 (OFF)" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVacuumOn}" Value="True">
                                                    <Setter Property="Text" Value="已开启 (ON)" />
                                                    <Setter Property="Foreground" Value="#FF28A745" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox
                        Margin="0,0,0,15"
                        Padding="15"
                        Header="单轴与单点控制">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="目标位置 :" />
                                <TextBox
                                    Grid.Column="1"
                                    Height="30"
                                    Padding="5,0"
                                    VerticalContentAlignment="Center"
                                    Text="{Binding TargetPosition}" />
                                <Button
                                    Grid.Column="2"
                                    Width="80"
                                    Height="30"
                                    Margin="10,0,0,0"
                                    Command="{Binding MoveToCommand}"
                                    Content="绝对定位" />
                            </Grid>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Text="真空阀控制:" />
                                <Button
                                    Width="120"
                                    Height="30"
                                    Command="{Binding ToggleVacuumCommand}"
                                    Content="切换真空阀 (Toggle)" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Padding="15" Header="模组工序验证">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button
                                Grid.Column="0"
                                Height="40"
                                Margin="0,0,5,0"
                                Background="#FF007BFF"
                                Command="{Binding InitializeCommand}"
                                Content="初始化 (Home)"
                                Foreground="White" />
                            <Button
                                Grid.Column="1"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="#FF6C757D"
                                Command="{Binding ResetCommand}"
                                Content="复位报警 (Reset)"
                                Foreground="White" />
                            <Button
                                Grid.Column="2"
                                Height="40"
                                Margin="5,0,0,0"
                                Background="#FFDC3545"
                                Command="{Binding StopCommand}"
                                Content="紧急停止 (Stop)"
                                FontWeight="Bold"
                                Foreground="White" />

                            <Button
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="1"
                                Height="40"
                                Margin="0,0,5,0"
                                Background="#FF28A745"
                                Command="{Binding PickCommand}"
                                Content="测试取料 (Pick)"
                                Foreground="White" />
                            <Button
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="1"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="#FF20B2AA"
                                Command="{Binding PlaceCommand}"
                                Content="测试放料 (Place)"
                                Foreground="White" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="8"
                CornerRadius="3">
                <TextBlock
                    FontWeight="SemiBold"
                    Text="{Binding StatusMessage}"
                    TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>