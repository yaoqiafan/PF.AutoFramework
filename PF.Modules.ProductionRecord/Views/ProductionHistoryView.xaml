<UserControl
    x:Class="PF.Modules.Production.Views.ProductionHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <pf:TransitioningContentControl TransitionMode="Right2LeftWithFade" TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Border
                Grid.Row="0"
                Padding="12,8"
                Background="{DynamicResource ThirdlyRegionBrush}">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    Text="生产数据历史查询" />
            </Border>

            <!--  查询条件面板  -->
            <Border
                Grid.Row="1"
                Padding="10,8"
                Background="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="155" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="155" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="开始：" />
                    <DatePicker
                        Grid.Column="1"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        SelectedDate="{Binding StartTime}" />

                    <TextBlock
                        Grid.Column="2"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="结束：" />
                    <DatePicker
                        Grid.Column="3"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        SelectedDate="{Binding EndTime}" />

                    <TextBlock
                        Grid.Column="4"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="类型：" />
                    <TextBox
                        Grid.Column="5"
                        Margin="0,0,10,0"
                        Padding="4,2"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Text="{Binding RecordType, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Grid.Column="6"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="关键词：" />
                    <TextBox
                        Grid.Column="7"
                        Margin="0,0,10,0"
                        Padding="4,2"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />

                    <Button
                        Grid.Column="8"
                        Margin="0,0,6,0"
                        Padding="14,4"
                        Style="{DynamicResource ButtonPrimary}"
                        Command="{Binding QueryCommand}"
                        Content="查询" />

                    <Button
                        Grid.Column="9"
                        Padding="10,4"
                        Style="{DynamicResource ButtonDefault}"
                        Command="{Binding ResetCommand}"
                        Content="重置" />
                </Grid>
            </Border>

            <!--  主体区域：左侧结果列表 + 右侧 JSON 详情  -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="1*" MinWidth="200" />
                </Grid.ColumnDefinitions>

                <!--  结果列表  -->
                <ListView
                    Grid.Column="0"

                    BorderThickness="0"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    ItemsSource="{Binding QueryResults}"
                    SelectedItem="{Binding SelectedRecord}"
                    SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn
                                Width="155"
                                DisplayMemberBinding="{Binding RecordTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                Header="采集时间" />
                            <GridViewColumn
                                Width="100"
                                DisplayMemberBinding="{Binding RecordType}"
                                Header="类型" />
                            <GridViewColumn
                                Width="200"
                                DisplayMemberBinding="{Binding TypeFullName}"
                                Header="数据类型" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <GridSplitter
                    Grid.Column="1"
                    Width="4"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource BorderBrush}" />

                <!--  JSON 详情面板  -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Padding="8,4"
                        Background="{DynamicResource ThirdlyRegionBrush}">
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource ThirdlyTextBrush}"
                            Text="JSON 数据详情" />
                    </Border>
                    <TextBox
                        Grid.Row="1"
                        Padding="8"
                        AcceptsReturn="True"

                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Text="{Binding DetailJson, Mode=OneWay}"
                        VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>

            <!--  状态栏 + 导出按钮  -->
            <Border
                Grid.Row="3"
                Padding="10,4"
                Background="{DynamicResource ThirdlyRegionBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock Foreground="{DynamicResource ThirdlyTextBrush}">
                            <Run Text="共 " />
                            <Run
                                FontWeight="Bold"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Text="{Binding TotalCount}" />
                            <Run Text=" 条记录" />
                        </TextBlock>
                        <ProgressBar
                            Width="60"
                            Height="4"
                            Margin="12,0,0,0"
                            IsIndeterminate="{Binding IsLoading}"
                            Visibility="{Binding IsLoading, Converter={StaticResource Boolean2VisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button
                            Margin="0,0,6,0"
                            Padding="12,4"
                            Style="{DynamicResource ButtonSuccess}"
                            Command="{Binding ExportCommand}"
                            CommandParameter="excel"
                            Content="导出 Excel" />
                        <Button
                            Padding="12,4"
                            Style="{DynamicResource ButtonDefault}"
                            Command="{Binding ExportCommand}"
                            CommandParameter="csv"
                            Content="导出 CSV" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </pf:TransitioningContentControl>
</UserControl>
