<UserControl
    x:Class="PF.UI.Infrastructure.Dialog.MessageDialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.UI.Infrastructure.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="450"
    Height="300"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,10,0,20" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="10,0,20,0"
                VerticalAlignment="Center"
                FontSize="60"
                Foreground="{Binding IconColor}"
                Text="{Binding IconText}" />
            <ScrollViewer Grid.Column="1">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="35"
                    Text="{Binding Message}"
                    TextWrapping="Wrap" />
            </ScrollViewer>

        </Grid>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="40"
                Margin="10,0,0,0"
                Command="{Binding CloseDialogCommand}"
                CommandParameter="yes"
                Content="是(Y)"
                Style="{DynamicResource ButtonPrimary}"
                Visibility="{Binding YesVisibility}" />

            <Button
                Width="80"
                Height="40"
                Margin="10,0,0,0"
                Command="{Binding CloseDialogCommand}"
                CommandParameter="no"
                Content="否(N)"
                Visibility="{Binding NoVisibility}" />

            <Button
                Width="80"
                Height="40"
                Margin="10,0,0,0"
                Command="{Binding CloseDialogCommand}"
                CommandParameter="ok"
                Content="确定"
                Style="{DynamicResource ButtonPrimary}"
                Visibility="{Binding OkVisibility}" />

            <Button
                Width="80"
                Height="40"
                Margin="10,0,0,0"
                Command="{Binding CloseDialogCommand}"
                CommandParameter="cancel"
                Content="取消"
                Style="{DynamicResource ButtonDefault}"
                Visibility="{Binding CancelVisibility}" />
        </StackPanel>
    </Grid>
</UserControl>
