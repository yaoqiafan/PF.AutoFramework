<UserControl
    x:Class="PF.Modules.HardwareDebug.Views.AxisDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 状态指示灯样式：默认灰色，通过 Tag 传入 bool 值，用 DataTrigger 变色 -->
        <Style x:Key="StatusLightBase" TargetType="Ellipse">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Margin" Value="3,0,1,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="Gray" />
        </Style>
        <Style x:Key="StatusLightGreen" TargetType="Ellipse" BasedOn="{StaticResource StatusLightBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Fill" Value="LimeGreen" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLightEnable" TargetType="Ellipse" BasedOn="{StaticResource StatusLightBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                    <Setter Property="Fill" Value="DeepSkyBlue" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLightMoving" TargetType="Ellipse" BasedOn="{StaticResource StatusLightBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMoving}" Value="True">
                    <Setter Property="Fill" Value="DodgerBlue" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLightAlarm" TargetType="Ellipse" BasedOn="{StaticResource StatusLightBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasAlarm}" Value="True">
                    <Setter Property="Fill" Value="Red" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLightPosLimit" TargetType="Ellipse" BasedOn="{StaticResource StatusLightBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPositiveLimit}" Value="True">
                    <Setter Property="Fill" Value="Orange" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLightNegLimit" TargetType="Ellipse" BasedOn="{StaticResource StatusLightBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNegativeLimit}" Value="True">
                    <Setter Property="Fill" Value="Orange" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══ 顶部工具栏 ══════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,8"
            Padding="10,8"
            Background="{DynamicResource BorderBrush}"
            CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 轴选择 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="选择轴：" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,6,0" />
                    <ComboBox
                        Width="200"
                        ItemsSource="{Binding AvailableAxes}"
                        SelectedItem="{Binding SelectedAxis}"
                        DisplayMemberPath="DeviceName" />
                </StackPanel>

                <!-- 实时状态指示灯 -->
                <WrapPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <Ellipse Style="{StaticResource StatusLightGreen}" ToolTip="设备连接状态" />
                    <TextBlock Text="连接" Style="{StaticResource StatusLabel}" />

                    <Ellipse Style="{StaticResource StatusLightEnable}" ToolTip="伺服使能状态" />
                    <TextBlock Text="使能" Style="{StaticResource StatusLabel}" />

                    <Ellipse Style="{StaticResource StatusLightMoving}" ToolTip="轴运动中" />
                    <TextBlock Text="运动" Style="{StaticResource StatusLabel}" />

                    <Ellipse Style="{StaticResource StatusLightAlarm}" ToolTip="轴报警" />
                    <TextBlock Text="报警" Style="{StaticResource StatusLabel}" />

                    <Ellipse Style="{StaticResource StatusLightPosLimit}" ToolTip="正限位触发" />
                    <TextBlock Text="+限" Style="{StaticResource StatusLabel}" />

                    <Ellipse Style="{StaticResource StatusLightNegLimit}" ToolTip="负限位触发" />
                    <TextBlock Text="-限" Style="{StaticResource StatusLabel}" />

                    <!-- 当前位置数显 -->
                    <TextBlock Text="位置：" Style="{StaticResource StatusLabel}" Margin="16,0,4,0" FontWeight="Bold" />
                    <TextBlock Style="{StaticResource StatusLabel}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="14" FontWeight="Bold">
                        <Run Text="{Binding CurrentPosition, StringFormat={}{0:F3}}" />
                        <Run Text=" mm" />
                    </TextBlock>
                </WrapPanel>

                <!-- 使能 / 断使能 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button
                        Width="72" Margin="0,0,6,0"
                        Command="{Binding EnableCommand}"
                        Content="使能"
                        Style="{StaticResource ButtonSuccess}" />
                    <Button
                        Width="72"
                        Command="{Binding DisableCommand}"
                        Content="断使能"
                        Style="{StaticResource ButtonWarning}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 主体：左控制面板 + 右点表 ════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="260" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── 左侧：运动控制面板 ─────────────────────────────────────── -->
            <Border
                Grid.Column="0"
                Padding="10"
                Background="{DynamicResource BorderBrush}"
                CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="运动控制" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"
                               Foreground="{DynamicResource PrimaryTextBrush}" />

                    <!-- 绝对定位 -->
                    <GroupBox Header="绝对定位" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="目标位置(mm)" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11" />
                                <TextBox Grid.Column="1" Margin="5,0,0,0"
                                         Text="{Binding MoveTargetPosition, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="速度(mm/s)" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11" />
                                <TextBox Grid.Column="1" Margin="5,0,0,0"
                                         Text="{Binding MoveVelocity, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{Binding MoveAbsoluteCommand}"
                                Content="执行绝对定位"
                                Style="{StaticResource ButtonPrimary}" />
                        </StackPanel>
                    </GroupBox>

                    <!-- 相对移动 -->
                    <GroupBox Header="相对移动" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="距离(mm)" Grid.Column="0" VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="1" Margin="5,0,0,0"
                                         Text="{Binding MoveRelativeDistance, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Command="{Binding MoveRelativeForwardCommand}"
                                        Content="+ 正向"
                                        Style="{StaticResource ButtonPrimary}" />
                                <Button Grid.Column="2"
                                        Command="{Binding MoveRelativeBackwardCommand}"
                                        Content="- 负向"
                                        Style="{StaticResource ButtonPrimary}" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <!-- 点动 -->
                    <GroupBox Header="点动 (Jog)" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="点动速度" Grid.Column="0" VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="1" Margin="5,0,0,0"
                                         Text="{Binding JogVelocity, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Command="{Binding JogForwardCommand}"
                                        Content="▶ 正向"
                                        Style="{StaticResource ButtonPrimary}" />
                                <Button Grid.Column="2"
                                        Command="{Binding JogBackwardCommand}"
                                        Content="◀ 负向"
                                        Style="{StaticResource ButtonPrimary}" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <!-- 回原点 + 急停 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding HomeCommand}"
                                Content="回原点"
                                Style="{StaticResource ButtonWarning}" />
                        <Button Grid.Column="2"
                                Command="{Binding StopCommand}"
                                Content="急  停"
                                Style="{StaticResource ButtonDanger}"
                                FontWeight="Bold" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="Transparent" />

            <!-- ── 右侧：点表管理 ───────────────────────────────────────────── -->
            <Border
                Grid.Column="2"
                Padding="10"
                Background="{DynamicResource BorderBrush}"
                CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="点表管理" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource PrimaryTextBrush}" />

                    <!-- DataGrid -->
                    <Border
                        Grid.Row="1"
                        BorderBrush="{DynamicResource PrimaryTextBrush}"
                        BorderThickness="1"
                        CornerRadius="3">
                        <DataGrid
                            x:Name="PointTableGrid"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            ColumnWidth="*"
                            GridLinesVisibility="Horizontal"
                            IsReadOnly="False"
                            ItemsSource="{Binding PointTable}"
                            SelectedItem="{Binding SelectedPoint}"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="55"
                                    Binding="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}"
                                    Header="序号" />
                                <DataGridTextColumn Width="140"
                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                    Header="点位名称" />
                                <DataGridTextColumn Width="120"
                                    Binding="{Binding TargetPosition, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}"
                                    Header="目标位置(mm)" />
                                <DataGridTextColumn Width="100"
                                    Binding="{Binding SuggestedVelocity, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}"
                                    Header="速度(mm/s)" />
                                <DataGridTextColumn Width="*"
                                    Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    Header="备注" />
                                <DataGridTemplateColumn Width="76" Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Width="62" Height="22"
                                                Command="{Binding DataContext.GoToPointCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Content="移动到"
                                                Style="{StaticResource ButtonDashedSuccess}"
                                                FontSize="11" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- 点表操作按钮 -->
                    <StackPanel Grid.Row="2" Margin="0,8,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button
                            Margin="0,0,8,0"
                            pf:IconElement.Geometry="{StaticResource AddGeometry}"
                            pf:IconElement.Height="14"
                            pf:IconElement.Width="14"
                            Command="{Binding AddPointCommand}"
                            Style="{StaticResource ButtonSuccess}"
                            ToolTip="以当前位置新增点位">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="4,0,0,0" Text="添加" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="0,0,8,0"
                            pf:IconElement.Geometry="{StaticResource DeleteGeometry}"
                            pf:IconElement.Height="14"
                            pf:IconElement.Width="14"
                            Command="{Binding DeletePointCommand}"
                            Style="{StaticResource ButtonDanger}"
                            ToolTip="删除选中点位">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="4,0,0,0" Text="删除" />
                            </StackPanel>
                        </Button>
                        <Button
                            pf:IconElement.Geometry="{StaticResource SaveGeometry}"
                            pf:IconElement.Height="14"
                            pf:IconElement.Width="14"
                            Command="{Binding SavePointsCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            ToolTip="将点表保存到文件">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="4,0,0,0" Text="保存" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ 底部状态栏 ════════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="2" Margin="0,6,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="点表：" />
                    <Run Text="{Binding PointTable.Count}" />
                    <Run Text=" 条" />
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
