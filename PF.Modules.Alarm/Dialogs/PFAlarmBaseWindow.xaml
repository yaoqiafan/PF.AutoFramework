<pf:Window 
    x:Class="PF.Modules.Alarm.Dialogs.PFAlarmBaseWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:PF.Modules.Alarm.Dialogs"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    mc:Ignorable="d"
    Topmost="True"
    Title="{Binding Title}"
    FontSize="30"
    MaxWidth="1080"
    NonClientAreaHeight="50"
    ShowNonClientArea="True"
    Background="Transparent"
    MouseLeftButtonDown="Grid_MouseLeftButtonDown"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    Style="{StaticResource WindowWin10}"
    WindowStyle="ToolWindow">

    <Grid />

</pf:Window>