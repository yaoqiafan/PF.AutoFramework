<UserControl x:Class="PF.Modules.Alarm.Views.AlarmCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PF.Modules.Alarm.ViewModels"
             xmlns:conv="clr-namespace:PF.Modules.Alarm.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AlarmCenterViewModel}"
             d:DesignHeight="720" d:DesignWidth="1280">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <!-- Fatal → 红底粗体；Error → 橙底；Warning → 黄底 -->
        <Style x:Key="SeverityRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SeverityDisplay}" Value="致命">
                    <Setter Property="Background" Value="#FFCCCC"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SeverityDisplay}" Value="错误">
                    <Setter Property="Background" Value="#FFE0CC"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SeverityDisplay}" Value="警告">
                    <Setter Property="Background" Value="#FFF9CC"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <!-- 上：活跃报警 + SOP看板 -->
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="5"/>
            <!-- 下：历史查询 -->
            <RowDefinition Height="*" MinHeight="160"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════ 上半区：活跃报警 + SOP ════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="1*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- 左：活跃报警表格 -->
            <GroupBox Grid.Column="0" Header="🔴 活跃报警" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 操作栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                        <Button Content="⟳ 复位全部" Width="100" Height="28" Margin="0,0,8,0"
                                Command="{Binding ClearAllCommand}"
                                Background="#E53935" Foreground="White" FontWeight="Bold"
                                BorderThickness="0"/>
                        <Button Content="✓ 清除选中" Width="100" Height="28"
                                Command="{Binding ClearSelectedCommand}"
                                Background="#FB8C00" Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>

                    <!-- 表格 -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ActiveAlarms}"
                              SelectedItem="{Binding SelectedAlarm}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowStyle="{StaticResource SeverityRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="级别"   Binding="{Binding SeverityDisplay}" Width="58"/>
                            <DataGridTextColumn Header="分类"   Binding="{Binding Category}"        Width="80"/>
                            <DataGridTextColumn Header="代码"   Binding="{Binding ErrorCode}"       Width="110"/>
                            <DataGridTextColumn Header="来源"   Binding="{Binding Source}"          Width="120"/>
                            <DataGridTextColumn Header="描述"   Binding="{Binding Message}"         Width="*"/>
                            <DataGridTextColumn Header="触发时间"
                                                Binding="{Binding TriggerTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                Width="145"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- 右：SOP 排故看板 -->
            <GroupBox Grid.Column="2" Header="📋 排故指导 SOP" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 报警标题（仅选中时显示） -->
                    <Border Grid.Row="0"
                            Margin="2,0,2,4" Padding="8,6"
                            Background="#FFF3E0" CornerRadius="4"
                            BorderBrush="#FB8C00" BorderThickness="1"
                            Visibility="{Binding SelectedAlarm, Converter={StaticResource NullToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedAlarm.Message}"
                                       FontWeight="Bold" FontSize="13"
                                       TextWrapping="Wrap"
                                       Foreground="#BF360C"/>
                            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#555">
                                <Run Text="代码："/><Run Text="{Binding SelectedAlarm.ErrorCode, Mode=OneWay}"/>
                                <Run Text="    来源："/><Run Text="{Binding SelectedAlarm.Source, Mode=OneWay}"/>
                                <Run Text="    级别："/>
                                <Run Text="{Binding SelectedAlarm.SeverityDisplay, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- SOP 文本 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4">
                        <TextBlock Text="{Binding SelectedSolution}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="24"
                                   Foreground="#212121"
                                   Padding="6"/>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

        <!-- ════════════════════ 下半区：历史查询 ════════════════════ -->
        <GroupBox Grid.Row="2" Header="📜 历史报警查询" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 查询工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                    <TextBlock Text="年份：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="56" Height="26"
                             Text="{Binding QueryYear, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Margin="0,0,12,0"/>

                    <TextBlock Text="分类：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="90" Height="26"
                             Text="{Binding QueryCategory, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Margin="0,0,12,0"/>

                    <Button Content="🔍 查询" Width="80" Height="28"
                            Command="{Binding QueryHistoryCommand}"
                            Background="#1976D2" Foreground="White" FontWeight="Bold"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- 历史记录表格（选中时同步联动 SOP 看板） -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding HistoricalAlarms}"
                          SelectedItem="{Binding SelectedAlarm}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowStyle="{StaticResource SeverityRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="级别"   Binding="{Binding SeverityDisplay}" Width="58"/>
                        <DataGridTextColumn Header="分类"   Binding="{Binding Category}"        Width="80"/>
                        <DataGridTextColumn Header="代码"   Binding="{Binding ErrorCode}"       Width="110"/>
                        <DataGridTextColumn Header="来源"   Binding="{Binding Source}"          Width="120"/>
                        <DataGridTextColumn Header="描述"   Binding="{Binding Message}"         Width="*"/>
                        <DataGridTextColumn Header="触发时间"
                                            Binding="{Binding TriggerTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                            Width="145"/>
                        <DataGridTextColumn Header="清除时间"
                                            Binding="{Binding ClearTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                            Width="145"/>
                        <DataGridCheckBoxColumn Header="活跃" Binding="{Binding IsActive}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
